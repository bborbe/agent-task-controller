{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VdM6KDTzLv1vXLAe7PF6yu","type":"tool_result","content":"195\t\treturn nil\n196\t}\n197\t\n198\tfunc buildCreateTaskContent(ctx context.Context, cmd task.CreateCommand) ([]byte, error) {\n199\t\tfm := make(lib.TaskFrontmatter)\n200\t\tmaps.Copy(fm, cmd.Frontmatter)\n201\t\tfm[\"task_identifier\"] = string(cmd.TaskIdentifier)\n202\t\treturn marshalFileContent(ctx, fm, cmd.Body)\n203\t}\n204\t\n205\t// supersedePriorRecurringTask transitions the prior-period recurring-task instance\n206\t// to status: aborted after a new instance is materialized. It is a best-effort\n207\t// hook: every failure path (ineligible, no prior, read/parse/write error) is logged\n208\t// and swallowed so the already-written new instance is never rolled back.\n209\t// newRelPath is the repo-root-relative path of the just-written new instance\n210\t// (used as the superseded_by back-pointer).\n211\tfunc supersedePriorRecurringTask(\n212\t\tctx context.Context,\n213\t\tgitClient gitclient.GitClient,\n214\t\ttaskDir string,\n215\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n216\t\tcmd task.CreateCommand,\n217\t\tnewRelPath string,\n218\t) {\n219\t\tif !isEligibleForSupersede(cmd) {\n220\t\t\treturn\n221\t\t}\n222\t\tpriorTitle, err := decrementRecurringTaskTitle(ctx, cmd.Title)\n223\t\tif err != nil {\n224\t\t\tglog.Warningf(\n225\t\t\t\t\"auto-supersede: cannot decrement title %q for %s: %v\",\n226\t\t\t\tcmd.Title,\n227\t\t\t\tcmd.TaskIdentifier,\n228\t\t\t\terr,\n229\t\t\t)\n230\t\t\treturn\n231\t\t}\n232\t\tif strings.ContainsAny(priorTitle, \"/\\\\\") {\n233\t\t\tglog.Warningf(\n234\t\t\t\t\"auto-supersede: computed prior title %q contains path separator; skipping for %s\",\n235\t\t\t\tpriorTitle,\n236\t\t\t\tcmd.TaskIdentifier,\n237\t\t\t)\n238\t\t\treturn\n239\t\t}\n240\t\tpriorRelPath := filepath.Join(taskDir, priorTitle+\".md\")\n241\t\tpriorContent, err := readPriorForSupersede(ctx, gitClient, priorRelPath, cmd.TaskIdentifier)\n242\t\tif err != nil || priorContent == nil {\n243\t\t\treturn\n244\t\t}\n245\t\tif !priorIsInProgress(ctx, priorContent, priorRelPath, cmd.TaskIdentifier) {\n246\t\t\treturn\n247\t\t}\n248\t\ttransitionPrior(\n249\t\t\tctx,\n250\t\t\tgitClient,\n251\t\t\tcurrentDateTime,\n252\t\t\tpriorRelPath,\n253\t\t\tpriorTitle,\n254\t\t\tnewRelPath,\n255\t\t\tcmd.TaskIdentifier,\n256\t\t)\n257\t}\n258\t\n259\t// isEligibleForSupersede reports whether cmd is a recurring-task instance\n260\t// that should auto-supersede its prior. Returns true only when created_by is\n261\t// the recurring-task publisher AND auto_abort_prior is explicitly true (opt-in).\n262\t// Returns false (no supersede) when auto_abort_prior is absent or false — the\n263\t// safe default that prevents accidental supersede of audit-style tasks.\n264\tfunc isEligibleForSupersede(cmd task.CreateCommand) bool {\n265\t\tcreatedBy, _ := cmd.Frontmatter.String(\"created_by\")\n266\t\tif createdBy != \"recurring-task-creator\" {\n267\t\t\tglog.V(3).\n268\t\t\t\tInfof(\"auto-supersede: skip %s (created_by=%q != recurring-task-creator)\", cmd.TaskIdentifier, createdBy)\n269\t\t\treturn false"}]},"parent_tool_use_id":"call_function_ghy0qpx7lxsk_1","session_id":"39ee2fda-6615-4b39-af19-b21d581ad85c","uuid":"002203e1-505a-45b4-8c68-d0530fd56c70","timestamp":"2026-07-08T09:09:47.593Z","subagent_type":"dark-factory:prompt-auditor","task_description":"Audit prompt 1"}
