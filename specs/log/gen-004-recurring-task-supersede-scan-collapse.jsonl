{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Bz9Rtf3Q5g9xJJUtbAoZb","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage factory\n6\t\n7\timport (\n8\t\tlib \"github.com/bborbe/agent\"\n9\t\t\"github.com/bborbe/cqrs/base\"\n10\t\t\"github.com/bborbe/cqrs/cdb\"\n11\t\tlibkafka \"github.com/bborbe/kafka\"\n12\t\tlibkv \"github.com/bborbe/kv\"\n13\t\t\"github.com/bborbe/run\"\n14\t\tlibtime \"github.com/bborbe/time\"\n15\t\n16\t\t\"github.com/bborbe/agent-task-controller/pkg/command\"\n17\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n18\t\t\"github.com/bborbe/agent-task-controller/pkg/prcomment\"\n19\t\t\"github.com/bborbe/agent-task-controller/pkg/result\"\n20\t)\n21\t\n22\t// CreateCommandConsumer wires a CQRS command consumer for agent-task-v1-request.\n23\tfunc CreateCommandConsumer(\n24\t\tsaramaClientProvider libkafka.SaramaClientProvider,\n25\t\tsyncProducer libkafka.SyncProducer,\n26\t\tdb libkv.DB,\n27\t\ttopicPrefix base.TopicPrefix,\n28\t\tresultWriter result.ResultWriter,\n29\t\tgitClient gitclient.GitClient,\n30\t\ttaskDir string,\n31\t\tvaultName string,\n32\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n33\t\tprCommenter prcomment.PRCommenter,\n34\t) run.Func {\n35\t\tretryGate := command.NewPlanningRetryGate(gitClient, taskDir, currentDateTime, prCommenter)\n36\t\texecutors := cdb.CommandObjectExecutorTxs{\n37\t\t\tcommand.NewTaskResultExecutor(resultWriter, retryGate),\n38\t\t\tcommand.NewIncrementFrontmatterExecutor(gitClient, taskDir),\n39\t\t\tcommand.NewUpdateFrontmatterExecutor(gitClient, taskDir),\n40\t\t\tcommand.NewCreateTaskExecutor(gitClient, taskDir, vaultName, currentDateTime),\n41\t\t}\n42\t\treturn cdb.RunCommandConsumerTxDefault(\n43\t\t\tsaramaClientProvider,\n44\t\t\tsyncProducer,\n45\t\t\tdb,\n46\t\t\tlib