{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YMbM4VbizpFqVg3fuJkLEc","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage command\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"fmt\"\n10\t\t\"regexp\"\n11\t\t\"strconv\"\n12\t\t\"strings\"\n13\t\t\"time\"\n14\t\n15\t\t\"github.com/bborbe/errors\"\n16\t)\n17\t\n18\t// Regexps compiled at package scope (not inside functions).\n19\tvar (\n20\t\tdailyRe     = regexp.MustCompile(`^(\\d{4})-(\\d{2})-(\\d{2})$`)\n21\t\tweekdayRe   = regexp.MustCompile(`^(\\d{4})W(\\d{2})-([a-z]{3})$`)\n22\t\tweeklyRe    = regexp.MustCompile(`^(\\d{4})W(\\d{2})$`)\n23\t\tmonthlyRe   = regexp.MustCompile(`^(\\d{4})-(\\d{2})$`)\n24\t\tquarterlyRe = regexp.MustCompile(`^(\\d{4})Q([1-4])$`)\n25\t\tyearlyRe    = regexp.MustCompile(`^(\\d{4})$`)\n26\t)\n27\t\n28\t// decrementRecurringTaskTitle splits title into its slug prefix and period-token\n29\t// suffix on the final \" - \" separator, decrements the token to the prior period\n30\t// per docs/period-token-semantics.md, and returns \"<slug> - <prior-token>\".\n31\t// It returns an error if the title has no \" - <token>\" suffix or the token suffix\n32\t// matches none of the six recognized shapes (caller must no-op on error).\n33\tfunc decrementRecurringTaskTitle(ctx context.Context, title string) (string, error) {\n34\t\tidx := strings.LastIndex(title, \" - \")\n35\t\tif idx < 0 {\n36\t\t\treturn \"\", errors.Errorf(ctx, \"title %q has no period-token suffix\", title)\n37\t\t}\n38\t\tslug := title[:idx]\n39\t\ttoken := title[idx+len(\" - \"):]\n40\t\tpriorToken, err := decrementPeriodToken(ctx, token)\n41\t\tif err != nil {\n42\t\t\treturn \"\", errors.Wrapf(ctx, err, \"decrement period token %q\", token)\n43\t\t}\n44\t\treturn slug + \" - \" + priorToken, nil\n45\t}\n46\t\n47\t// decrementPeriodToken returns the prior-period token for a single period-token\n48\t// string, recognizing the kind by shape (order per docs/period-token-semantics.md).\n49\tfunc decrementPeriodToken(ctx context.Context, token string) (string, error) {\n50\t\t// Daily: YYYY-MM-DD\n51\t\tif m := dailyRe.FindStringSubmatch(token); m != nil {\n52\t\t\tyear, _ := strconv.Atoi(m[1])\n53\t\t\tmonth, _ := strconv.Atoi(m[2])\n54\t\t\tday, _ := strconv.Atoi(m[3])\n55\t\t\tt := time.Date(year, time.Month(month), day, 0, 0, 0, 0, time.UTC)\n56\t\t\tprior := t.AddDate(0, 0, -1)\n57\t\t\treturn prior.Format(\"2006-01-02\"), nil\n58\t\t}\n59\t\n60\t\t// Weekday (list): YYYYWww-<3-letter-abbrev>\n61\t\tif m := weekdayRe.FindStringSubmatch(token); m != nil {\n62\t\t\tisoYear, _ := strconv.Atoi(m[1])\n63\t\t\tweek, _ := strconv.Atoi(m[2])\n64\t\t\tabbrev := m[3]\n65\t\t\tpriorISOYear, priorWeek := decrementISOWeek(isoYear, week)\n66\t\t\treturn fmt.Sprintf(\"%04dW%02d-%s\", priorISOYear, priorWeek, abbrev), nil\n67\t\t}\n68\t\n69\t\t// Weekly: YYYYWww\n70\t\tif m := weeklyRe.FindStringSubmatch(token); m != nil {\n71\t\t\tisoYear, _ := strconv.Atoi(m[1])\n72\t\t\tweek, _ := strconv.Atoi(m[2])\n73\t\t\tpriorISOYear, priorWeek := decrementISOWeek(isoYear, week)\n74\t\t\treturn fmt.Sprintf(\"%04dW%02d\", priorISOYear, priorWeek), nil\n75\t\t}\n76\t\n77\t\t// Monthly: YYYY-MM\n78\t\tif m := monthlyRe.FindStringSubmatch(token); m != nil {\n79\t\t\tyear, _ := strconv.Atoi(m[1])\n80\t\t\tmonth, _ := strconv.Atoi(m[2])\n81\t\t\tt := time.Date(year, time.Month(month), 1, 0, 0, 0, 0, time.UTC)\n82\t\t\tprior := t.AddDate(0, -1, 0)\n83\t\t\treturn prior.Format(\"2006-01\"), nil\n84\t\t}\n85\t\n86\t\t// Quarterly: YYYYQq\n87\t\tif m := quarterlyRe.FindStringSubmatch(token); m != nil {\n88\t\t\tyear, _ := strconv.Atoi(m[1])\n89\t\t\tq, _ := strconv.Atoi(m[2])\n90\t\t\tif q > 1 {\n91\t\t\t\treturn fmt.Sprintf(\"%04dQ%d\", year, q-1), nil\n92\t\t\t}\n93\t\t\treturn fmt.Sprintf(\"%04dQ4\", year-1), nil\n94\t\t}\n95\t\n96\t\t// Yearly: YYYY\n97\t\tif m := yearlyRe.FindStringSubmatch(token); m != nil {\n98\t\t\tyear, _ := strconv.Atoi(m[1])\n99\t\t\treturn fmt.Sprintf(\"%04d\", year-1), nil\n100\t\t}\n101\t\n102\t\treturn \"\", errors.Errorf(ctx, \"period token %q matches no recognized shape\", token)\n103\t}\n104\t\n105\t// decrementISOWeek returns the ISO year and week number for the week immediately\n106\t// preceding the given ISO year and week.\n107\tfunc decrementISOWeek(isoYear, week int) (int, int) {\n108\t\t// Find the Monday of the given ISO week.\n109\t\t// Jan 4 is always in ISO week 1.\n110\t\tjan4 := time.Date(isoYear, time.January, 4, 0, 0, 0, 0, time.UTC)\n111\t\t// Weekday of Jan 4 (Monday = 1, ... Sunday = 7).\n112\t\tjan4Weekday := int(jan4.Weekday())\n113\t\tif jan4Weekday == 0 {\n114\t\t\tjan4Weekday = 7\n115\t\t}\n116\t\t// Monday of ISO week 1.\n117\t\tmondayOfWeek1 := jan4.AddDate(0, 0, -(jan4Weekday - 1))\n118\t\t// Monday of the target week.\n119\t\tmondayOfTargetWeek := mondayOfWeek1.AddDate(0, 0, (week-1)*7)\n120\t\t// Go back one week.\n121\t\tpriorMonday := mondayOfTargetWeek.AddDate(0, 0, -7)\n122\t\t// Get the ISO week of that Monday.\n123\t\tpriorISOYear, priorWeek := priorMonday.ISOWeek()\n124\t\treturn priorISOYear, priorWeek\n125\t}\n126\t"}]},"parent_tool_use_id":"call_function_9e58iwdnz9j9_1","session_id":"39ee2fda-6615-4b39-af19-b21d581ad85c","uuid":"21080fe2-5db4-494c-9af5-445dacfe0b46","timestamp":"2026-07-08T09:00:58.978Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
