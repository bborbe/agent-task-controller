{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VkHEM2cPLQ7JyUGxz2g1dA","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage main\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"net/http\"\n10\t\t\"os\"\n11\t\t\"strconv\"\n12\t\t\"time\"\n13\t\n14\t\tlib \"github.com/bborbe/agent\"\n15\t\tboltkv \"github.com/bborbe/boltkv\"\n16\t\t\"github.com/bborbe/cqrs/base\"\n17\t\t\"github.com/bborbe/cqrs/cdb\"\n18\t\t\"github.com/bborbe/errors\"\n19\t\tlibhttp \"github.com/bborbe/http\"\n20\t\tlibkafka \"github.com/bborbe/kafka\"\n21\t\t\"github.com/bborbe/log\"\n22\t\tlibmetrics \"github.com/bborbe/metrics\"\n23\t\t\"github.com/bborbe/run\"\n24\t\tlibsentry \"github.com/bborbe/sentry\"\n25\t\t\"github.com/bborbe/service\"\n26\t\tlibtime \"github.com/bborbe/time\"\n27\t\t\"github.com/golang/glog\"\n28\t\t\"github.com/gorilla/mux\"\n29\t\t\"github.com/prometheus/client_golang/prometheus/promhttp\"\n30\t\tbolt \"go.etcd.io/bbolt\"\n31\t\n32\t\t\"github.com/bborbe/agent-task-controller/pkg/factory\"\n33\t\t\"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n34\t\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n35\t\t\"github.com/bborbe/agent-task-controller/pkg/prcomment\"\n36\t\t\"github.com/bborbe/agent-task-controller/pkg/publisher\"\n37\t\t\"github.com/bborbe/agent-task-controller/pkg/result\"\n38\t\t\"github.com/bborbe/agent-task-controller/pkg/routing\"\n39\t\t\"github.com/bborbe/agent-task-controller/pkg/scanner\"\n40\t\tpkgsync \"github.com/bborbe/agent-task-controller/pkg/sync\"\n41\t)\n42\t\n43\tconst vaultLocalPath = \"/data/vault\"\n44\t\n45\tconst githubAPIBaseURL = \"https://api.github.com\"\n46\t\n47\tfunc main() {\n48\t\tapp := &application{}\n49\t\tos.Exit(service.Main(context.Background(), app, &app.SentryDSN, &app.SentryProxy))\n50\t}\n51\t\n52\ttype application struct {\n53\t\tSentryDSN                string            `required:\"true\"  arg:\"sentry-dsn\"                  env:\"SENTRY_DSN\"                  usage:\"SentryDSN\"                                                                                                                                               display:\"length\"`\n54\t\tSentryProxy              string            `required:\"false\" arg:\"sentry-proxy\"                env:\"SENTRY_PROXY\"                usage:\"Sentry Proxy\"`\n55\t\tListen                   string            `required:\"true\"  arg:\"listen\"                      env:\"LISTEN\"                      usage:\"address to listen to\"`\n56\t\tKafkaBrokers             string            `required:\"true\"  arg:\"kafka-brokers\"               env:\"KAFKA_BROKERS\"               usage:\"comma-separated Kafka broker addresses\"`\n57\t\tBranch                   base.Branch       `required:\"true\"  arg:\"branch\"                      env:\"BRANCH\"                      usage:\"Kafka topic prefix branch (develop/live)\"`\n58\t\tTopicPrefix              base.TopicPrefix  `required:\"false\" arg:\"topic-prefix\"                env:\"TOPIC_PREFIX\"                usage:\"Explicit Kafka topic prefix; empty means unprefixed topics\"`\n59\t\tPollInterval             time.Duration     `required:\"false\" arg:\"poll-interval\"               env:\"POLL_INTERVAL\"               usage:\"vault polling interval\"                                                                                                                                                   default:\"60s\"`\n60\t\tTaskDir                  string            `required:\"true\"  arg:\"task-dir\"                    env:\"TASK_DIR\"                    usage:\"task directory within vault (per-vault convention: openclaw=tasks, personal=24 Tasks)\"`\n61\t\tDataDir                  string            `required:\"true\"  arg:\"data-dir\"                    env:\"DATA_DIR\"                    usage:\"directory for BoltDB offset storage\"`\n62\t\tNoSync                   bool              `required:\"false\" arg:\"no-sync\"                     env:\"NO_SYNC\"                     usage:\"disable BoltDB fsync (for testing only)\"`\n63\t\tGitRestURL               string            `required:\"false\" arg:\"git-rest-url\"                env:\"GIT_REST_URL\"                usage:\"git-rest HTTP API base URL\"                                                                                                                                               default:\"http://vault-obsidian-openclaw:9090\"`\n64\t\tGatewaySecret            string            `required:\"false\" arg:\"gateway-secret\"              env:\"GATEWAY_SECRET\"              usage:\"shared secret for git-rest gateway auth (sent as X-Gateway-Secret header)\"                                                                               display:\"length\" default:\"\"`\n65\t\tBuildGitVersion          string            `required:\"false\" arg:\"build-git-version\"           env:\"BUILD_GIT_VERSION\"           usage:\"Build Git version (git describe --tags --always --dirty)\"                                                                                                                 default:\"dev\"`\n66\t\tBuildGitCommit           string            `required:\"false\" arg:\"build-git-commit\"            env:\"BUILD_GIT_COMMIT\"            usage:\"Build Git commit hash\"                                                                                                                                                    default:\"none\"`\n67\t\tBuildDate                *libtime.DateTime `required:\"false\" arg:\"build-date\"                  env:\"BUILD_DATE\"                  usage:\"Build timestamp (RFC3339)\"`\n68\t\tVaultName                string            `required:\"true\"  arg:\"vault-name\"                  env:\"VAULT_NAME\"                  usage:\"vault slug this controller serves (e.g. openclaw, personal); legacy empty targetVault defaults to openclaw\"`\n69\t\tAutoInjectTaskIdentifier string            `required:\"true\"  arg:\"auto-inject-task-identifier\" env:\"AUTO_INJECT_TASK_IDENTIFIER\" usage:\"allow this replica to backfill missing/invalid task_identifier fields (set true on exactly one replica per shared vault; false on all others); required\"`\n70\t\tGitHubToken              string            `required:\"false\" arg:\"github-token\"                env:\"GITHUB_TOKEN\"                usage:\"GitHub token with pull-requests:write scope for posting planning-retry COMMENT reviews; empty disables the comment (frontmatter escalation still fires)\" display:\"length\" default:\"\"`\n71\t}\n72\t\n73\t//nolint:funlen // +6 lines from spec-043 metrics.New() passed to scanner + sync loop; extraction would split tightly-coupled wiring.\n74\tfunc (a *application) Run(ctx context.Context, sentryClient libsentry.Client) error {\n75\t\tif err := routing.ValidateVaultName(ctx, a.VaultName); err != nil {\n76\t\t\treturn err\n77\t\t}\n78\t\tautoInject, err := strconv.ParseBool(a.AutoInjectTaskIdentifier)\n79\t\tif err != nil {\n80\t\t\treturn errors.Errorf(\n81\t\t\t\tctx,\n82\t\t\t\t\"AUTO_INJECT_TASK_IDENTIFIER must be parseable as bool (true/false), got %q\",\n83\t\t\t\ta.AutoInjectTaskIdentifier,\n84\t\t\t)\n85\t\t}\n86\t\tlibmetrics.NewBuildInfoMetrics().SetBuildInfo(a.BuildGitVersion, a.BuildGitCommit, a.BuildDate)\n87\t\tglog.V(1).\n88\t\t\tInfof(\"agent-task-controller started version=%s commit=%s\", a.BuildGitVersion, a.BuildGitCommit)\n89\t\n90\t\tif a.GitRestURL == \"\" {\n91\t\t\treturn errors.Errorf(ctx, \"GIT_REST_URL is required\")\n92\t\t}\n93\t\trestClient := gitrestclient.NewGitRestClient(\n94\t\t\ta.GitRestURL, a.GatewaySecret, \"agent-task-controller\", metrics.New(),\n95\t\t)\n96\t\tgitClient := gitrestclient.NewGitClient(restClient, vaultLocalPath)\n97\t\tif err := gitClient.EnsureCloned(ctx); err != nil {\n98\t\t\treturn errors.Wrapf(ctx, err, \"probe git-rest readiness\")\n99\t\t}\n100\t\tglog.V(1).Infof(\"using git-rest HTTP API at %s\", a.GitRestURL)\n101\t\n102\t\tsyncProducer, err := libkafka.NewSyncProducer(\n103\t\t\tctx,\n104\t\t\tlibkafka.ParseBrokersFromString(a.KafkaBrokers),\n105\t\t)\n106\t\tif err != nil {\n107\t\t\treturn errors.Wrapf(ctx, err, \"create kafka sync producer\")\n108\t\t}\n109\t\tdefer syncProducer.Close()\n110\t\n111\t\teventObjectSender := cdb.NewEventObjectSender(\n112\t\t\tlibkafka.NewJSONSender(syncProducer, log.DefaultSamplerFactory),\n113\t\t\ta.TopicPrefix,\n114\t\t\tlog.DefaultSamplerFactory,\n115\t\t)\n116\t\n117\t\tcurrentDateTime := libtime.NewCurrentDateTime()\n118\t\n119\t\tprCommenter := prcomment.NewPRCommenter(\n120\t\t\t&http.Client{Timeout: 30 * time.Second},\n121\t\t\tgithubAPIBaseURL,\n122\t\t\ta.GitHubToken,\n123\t\t)\n124\t\n125\t\ttrigger := make(chan struct{}, 1)\n126\t\tsyncLoop := pkgsync.NewSyncLoop(\n127\t\t\tscanner.NewGitRestVaultScanner(\n128\t\t\t\tgitClient,\n129\t\t\t\ta.TaskDir,\n130\t\t\t\ta.PollInterval,\n131\t\t\t\ttrigger,\n132\t\t\t\tmetrics.New(),\n133\t\t\t\tautoInject,\n134\t\t\t),\n135\t\t\tpublisher.NewTaskPublisher(eventObjectSender, lib.TaskV1SchemaID, currentDateTime),\n136\t\t\ttrigger,\n137\t\t\tmetrics.New(),\n138\t\t)\n139\t\n140\t\tvar boltOptions []boltkv.ChangeOptions\n141\t\tif a.NoSync {\n142\t\t\tboltOptions = append(boltOptions, func(opts *bolt.Options) {\n143\t\t\t\topts.NoSync = true\n144\t\t\t})\n145\t\t}\n146\t\tdb, err := boltkv.OpenDir(ctx, a.DataDir, boltOptions...)\n147\t\tif err != nil {\n148\t\t\treturn errors.Wrapf(ctx, err, \"open boltkv dir %s\", a.DataDir)\n149\t\t}\n150\t\tdefer db.Close()\n151\t\n152\t\tsaramaClientProvider, err := libkafka.NewSaramaClientProviderByType(\n153\t\t\tctx,\n154\t\t\tlibkafka.SaramaClientProviderTypeReused,\n155\t\t\tlibkafka.ParseBrokersFromString(a.KafkaBrokers),\n156\t\t)\n157\t\tif err != nil {\n158\t\t\treturn errors.Wrapf(ctx, err, \"create sarama client provider\")\n159\t\t}\n160\t\tdefer saramaClientProvider.Close()\n161\t\n162\t\tresultWriter := result.NewResultWriter(gitClient, a.TaskDir, currentDateTime)\n163\t\tcommandConsumer := factory.CreateCommandConsumer(\n164\t\t\tsaramaClientProvider,\n165\t\t\tsyncProducer,\n166\t\t\tdb,\n167\t\t\ta.TopicPrefix,\n168\t\t\tresultWriter,\n169\t\t\tgitClient,\n170\t\t\ta.TaskDir,\n171\t\t\ta.VaultName,\n172\t\t\tcurrentDateTime,\n173\t\t\tprCommenter,\n174\t\t)\n175\t\n176\t\treturn service.Run(\n177\t\t\tctx,\n178\t\t\tsyncLoop.Run,\n179\t\t\tcommandConsumer,\n180\t\t\ta.createHTTPServer(syncLoop, restClient),\n181\t\t)\n182\t}\n183\t\n184\tfunc (a *application) createHTTPServer(\n185\t\tsyncLoop pkgsync.SyncLoop,\n186\t\tgitRestClient gitrestclient.GitRestClient,\n187\t) run.Func {\n188\t\treturn func(ctx context.Context) error {\n189\t\t\trouter := mux.NewRouter()\n190\t\t\trouter.Path(\"/healthz\").Handler(libhttp.NewPrintHandler(\"OK\"))\n191\t\t\trouter.Path(\"/readiness\").HandlerFunc(func(w http.ResponseWriter, req *http.Request) {\n192\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain\")\n193\t\t\t\tready, err := gitRestClient.IsReady(req.Context())\n194\t\t\t\tif err != nil || !ready {\n195\t\t\t\t\tw.WriteHeader(http.StatusServiceUnavailable)\n196\t\t\t\t\t_, _ = w.Write([]byte(\"git-rest not ready\"))\n197\t\t\t\t\treturn\n198\t\t\t\t}\n199\t\t\t\t_, _ = w.Write([]byte(\"OK\"))\n200\t\t\t})\n201\t\t\trouter.Path(\"/metrics\").Handler(promhttp.Handler())\n202\t\t\trouter.Path(\"/setloglevel/{level}\").\n203\t\t\t\tHandler(log.NewSetLoglevelHandler(ctx, log.NewLogLevelSetter(2, 5*time.Minute)))\n204\t\t\trouter.Path(\"/trigger\").HandlerFunc(func(resp http.ResponseWriter, req *http.Request) {\n205\t\t\t\tsyncLoop.Trigger()\n206\t\t\t\tglog.V(2).Infof(\"trigger fired via HTTP\")\n207\t\t\t\t_, _ = resp.Write([]byte(\"trigger fired\"))\n208\t\t\t})\n209\t\n210\t\t\tglog.V(2).Infof(\"starting http server listen on %s\", a.Listen)\n211\t\t\treturn libhttp.NewServer(\n212\t\t\t\ta.Listen,\n213\t\t\t\trouter,\n214\t\t\t).Run(ctx)\n215\t\t}\n216\t}\n217\t"}]},"parent_tool_use_id":"call_function_9e58iwdnz9j9_1","session_id":"39ee2fda-6615-4b39-af19-b21d581ad85c","uuid":"f960e35c-8458-434e-8079-f1705b719b7e","timestamp":"2026-07-08T09:01:09.497Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
