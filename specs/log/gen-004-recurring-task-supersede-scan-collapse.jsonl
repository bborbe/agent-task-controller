{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JUNpZmRQ256KNnsiZUF4mD","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage command\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"maps\"\n10\t\t\"path/filepath\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\tlib \"github.com/bborbe/agent\"\n15\t\ttask \"github.com/bborbe/agent/command/task\"\n16\t\t\"github.com/bborbe/cqrs/base\"\n17\t\t\"github.com/bborbe/cqrs/cdb\"\n18\t\t\"github.com/bborbe/errors\"\n19\t\tlibkv \"github.com/bborbe/kv\"\n20\t\tlibtime \"github.com/bborbe/time\"\n21\t\t\"github.com/bborbe/validation\"\n22\t\t\"github.com/golang/glog\"\n23\t\n24\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n25\t\tresult \"github.com/bborbe/agent-task-controller/pkg/result\"\n26\t\t\"github.com/bborbe/agent-task-controller/pkg/routing\"\n27\t)\n28\t\n29\t// NewCreateTaskExecutor creates a cdb.CommandObjectExecutorTx that materializes\n30\t// a new vault task file for the given task_identifier. If cmd.Title passes validation\n31\t// the file is written at tasks/{title}.md; otherwise it falls back to tasks/{task_identifier}.md.\n32\t// If a file already exists at the resolved path the command returns ErrTaskAlreadyExists\n33\t// (a benign Failure on the result topic — no overwrite, no git write).\n34\t// Frontmatter must include \"assignee\" and \"status\"; missing fields return a wrapped validation error.\n35\t// Commands whose effective target vault (cmd.TargetVault or the legacy fallback) does not\n36\t// match vaultName are skipped without side effects (no git write, no error, no result event).\n37\tfunc NewCreateTaskExecutor(\n38\t\tgitClient gitclient.GitClient,\n39\t\ttaskDir string,\n40\t\tvaultName string,\n41\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n42\t) cdb.CommandObjectExecutorTx {\n43\t\treturn cdb.CommandObjectExecutorTxFunc(\n44\t\t\ttask.CreateCommandOperation,\n45\t\t\ttrue,\n46\t\t\tfunc(ctx context.Context, tx libkv.Tx, commandObject cdb.CommandObject) (*base.EventID, base.Event, error) {\n47\t\t\t\tvar cmd task.CreateCommand\n48\t\t\t\tif err := commandObject.Command.Data.MarshalInto(ctx, &cmd); err != nil {\n49\t\t\t\t\treturn nil, nil, errors.Wrapf(\n50\t\t\t\t\t\tctx,\n51\t\t\t\t\t\tcdb.ErrCommandObjectSkipped,\n52\t\t\t\t\t\t\"malformed CreateTaskCommand: %v\",\n53\t\t\t\t\t\terr,\n54\t\t\t\t\t)\n55\t\t\t\t}\n56\t\t\t\tif err := cmd.TaskIdentifier.Validate(ctx); err != nil {\n57\t\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate task_identifier\")\n58\t\t\t\t}\n59\t\t\t\tif !routing.ShouldProcess(cmd, vaultName) {\n60\t\t\t\t\teffective := cmd.TargetVault\n61\t\t\t\t\tif effective == \"\" {\n62\t\t\t\t\t\teffective = routing.LegacyDefaultVault\n63\t\t\t\t\t}\n64\t\t\t\t\tglog.V(2).Infof(\n65\t\t\t\t\t\t\"create-task: skipped vault mismatch target=%q effective=%q vault=%q task=%s\",\n66\t\t\t\t\t\tcmd.TargetVault, effective, vaultName, cmd.TaskIdentifier,\n67\t\t\t\t\t)\n68\t\t\t\t\treturn nil, nil, nil\n69\t\t\t\t}\n70\t\t\t\tif err := validateCreateTaskFrontmatter(ctx, cmd.Frontmatter); err != nil {\n71\t\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate frontmatter\")\n72\t\t\t\t}\n73\t\t\t\trelPath := resolveCreateTaskRelPath(ctx, taskDir, cmd)\n74\t\t\t\tif err := checkTitlePathFree(ctx, gitClient, relPath, cmd.TaskIdentifier); err != nil {\n75\t\t\t\t\treturn nil, nil, err\n76\t\t\t\t}\n77\t\t\t\tif err := writeTaskFile(ctx, gitClient, relPath, cmd); err != nil {\n78\t\t\t\t\treturn nil, nil, err\n79\t\t\t\t}\n80\t\t\t\tsupersedePriorRecurringTask(ctx, gitClient, taskDir, currentDateTime, cmd, relPath)\n81\t\t\t\treturn nil, nil, nil\n82\t\t\t},\n83\t\t)\n84\t}\n85\t\n86\t// checkTitlePathFree returns ErrTaskAlreadyExists when the title path is\n87\t// already occupied (benign Failure on the result topic — no overwrite, no\n88\t// git write). A transient git-rest read error is propagated. A \"not found\"\n89\t// read error is swallowed (title path is free).\n90\tfunc checkTitlePathFree(\n91\t\tctx context.Context,\n92\t\tgitClient gitclient.GitClient,\n93\t\trelPath string,\n94\t\ttaskIdentifier lib.TaskIdentifier,\n95\t) error {\n96\t\texisting, err := gitClient.ReadFile(ctx, relPath)\n97\t\tif err == nil {\n98\t\t\tglog.V(2).Infof(\n99\t\t\t\t\"create-task: title path %s already occupied (%d bytes), returning ErrTaskAlreadyExists for %s\",\n100\t\t\t\trelPath,\n101\t\t\t\tlen(existing),\n102\t\t\t\ttaskIdentifier,\n103\t\t\t)\n104\t\t\treturn errors.Wrapf(\n105\t\t\t\tctx, task.ErrTaskAlreadyExists, \"title path %s occupied\", relPath,\n106\t\t\t)\n107\t\t}\n108\t\tif !isNotFoundReadError(err) {\n109\t\t\treturn errors.Wrapf(\n110\t\t\t\tctx, err, \"check existing task file at %s for %s\", relPath, taskIdentifier,\n111\t\t\t)\n112\t\t}\n113\t\treturn nil\n114\t}\n115\t\n116\t// writeTaskFile builds the task content and writes it atomically to the vault\n117\t// via git-rest, then logs the creation.\n118\tfunc writeTaskFile(\n119\t\tctx context.Context,\n120\t\tgitClient gitclient.GitClient,\n121\t\trelPath string,\n122\t\tcmd task.CreateCommand,\n123\t) error {\n124\t\tcontent, err := buildCreateTaskContent(ctx, cmd)\n125\t\tif err != nil {\n126\t\t\treturn errors.Wrapf(ctx, err, \"build task file content for %s\", cmd.TaskIdentifier)\n127\t\t}\n128\t\tabsPath := filepath.Join(gitClient.Path(), relPath)\n129\t\tif err := gitClient.AtomicWriteAndCommitPush(\n130\t\t\tctx,\n131\t\t\tabsPath,\n132\t\t\tcontent,\n133\t\t\t\"[agent-task-controller] create task \"+string(cmd.TaskIdentifier),\n134\t\t); err != nil {\n135\t\t\treturn errors.Wrapf(ctx, err, \"atomic write and push for task %s\", cmd.TaskIdentifier)\n136\t\t}\n137\t\tglog.V(2).Infof(\"create-task: created task file at %s for %s\", relPath, cmd.TaskIdentifier)\n138\t\treturn nil\n139\t}\n140\t\n141\t// resolveCreateTaskRelPath returns the repo-root-relative path where the task\n142\t// file should be written. If cmd.Title passes validation and contains no path\n143\t// separators, the title-derived path is returned; otherwise a WARN is logged and\n144\t// the UUID-derived path is returned as fallback so the task is always materialized.\n145\t// Filename-collision detection is the caller's job (via gitClient.ReadFile) — this\n146\t// function no longer reads the vault or compares task_identifier.\n147\tfunc resolveCreateTaskRelPath(\n148\t\tctx context.Context,\n149\t\ttaskDir string,\n150\t\tcmd task.CreateCommand,\n151\t) string {\n152\t\tuuidRelPath := filepath.Join(taskDir, string(cmd.TaskIdentifier)+\".md\")\n153\t\n154\t\t// Re-validate the command (defense-in-depth: sender may have been bypassed).\n155\t\tif err := cmd.Validate(ctx); err != nil {\n156\t\t\tglog.Warningf(\n157\t\t\t\t\"create-task: Title validation failed for task %s (%v); falling back to UUID path\",\n158\t\t\t\tcmd.TaskIdentifier, err,\n159\t\t\t)\n160\t\t\treturn uuidRelPath\n161\t\t}\n162\t\n163\t\t// Reject titles containing path separators to prevent path traversal.\n164\t\tif strings.ContainsAny(cmd.Title, \"/\\\\\") {\n165\t\t\tglog.Warningf(\n166\t\t\t\t\"create-task: Title %q contains path separator; falling back to UUID path\",\n167\t\t\t\tcmd.Title,\n168\t\t\t)\n169\t\t\treturn uuidRelPath\n170\t\t}\n171\t\n172\t\treturn filepath.Join(taskDir, cmd.Title+\".md\")\n173\t}\n174\t\n175\t// isNotFoundReadError reports whether a gitClient.ReadFile error means the file\n176\t// does not exist (git-rest returns HTTP 404). git-rest's Get does not expose a\n177\t// typed not-found sentinel, so this matches the \"404\" status embedded in the\n178\t// wrapped error message produced by gitRestClient.Get\n179\t// (\"GET <path> returned 404: ...\"). A nil error is NOT a not-found error and must\n180\t// be handled by the caller before calling this helper.\n181\tfunc isNotFoundReadError(err error) bool {\n182\t\tif err == nil {\n183\t\t\treturn false\n184\t\t}\n185\t\treturn strings.Contains(err.Error(), \"returned 404\")\n186\t}\n187\t\n188\tfunc validateCreateTaskFrontmatter(ctx context.Context, fm lib.TaskFrontmatter) error {\n189\t\tif fm.Assignee() == \"\" {\n190\t\t\treturn errors.Wrap(ctx, validation.Error, \"frontmatter missing required field: assignee\")\n191\t\t}\n192\t\tif s, _ := fm.String(\"status\"); s == \"\" {\n193\t\t\treturn errors.Wrap(ctx, validation.Error, \"frontmatter missing required field: status\")\n194\t\t}\n195\t\treturn nil\n196\t}\n197\t\n198\tfunc buildCreateTaskContent(ctx context.Context, cmd task.CreateCommand) ([]byte, error) {\n199\t\tfm := make(lib.TaskFrontmatter)\n200\t\tmaps.Copy(fm, cmd.Frontmatter)\n201\t\tfm[\"task_identifier\"] = string(cmd.TaskIdentifier)\n202\t\treturn marshalFileContent(ctx, fm, cmd.Body)\n203\t}\n204\t\n205\t// supersedePriorRecurringTask transitions the prior-period recurring-task instance\n206\t// to status: aborted after a new instance is materialized. It is a best-effort\n207\t// hook: every failure path (ineligible, no prior, read/parse/write error) is logged\n208\t// and swallowed so the already-written new instance is never rolled back.\n209\t// newRelPath is the repo-root-relative path of the just-written new instance\n210\t// (used as the superseded_by back-pointer).\n211\tfunc supersedePriorRecurringTask(\n212\t\tctx context.Context,\n213\t\tgitClient gitclient.GitClient,\n214\t\ttaskDir string,\n215\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n216\t\tcmd task.CreateCommand,\n217\t\tnewRelPath string,\n218\t) {\n219\t\tif !isEligibleForSupersede(cmd) {\n220\t\t\treturn\n221\t\t}\n222\t\tpriorTitle, err := decrementRecurringTaskTitle(ctx, cmd.Title)\n223\t\tif err != nil {\n224\t\t\tglog.Warningf(\n225\t\t\t\t\"auto-supersede: cannot decrement title %q for %s: %v\",\n226\t\t\t\tcmd.Title,\n227\t\t\t\tcmd.TaskIdentifier,\n228\t\t\t\terr,\n229\t\t\t)\n230\t\t\treturn\n231\t\t}\n232\t\tif strings.ContainsAny(priorTitle, \"/\\\\\") {\n233\t\t\tglog.Warningf(\n234\t\t\t\t\"auto-supersede: computed prior title %q contains path separator; skipping for %s\",\n235\t\t\t\tpriorTitle,\n236\t\t\t\tcmd.TaskIdentifier,\n237\t\t\t)\n238\t\t\treturn\n239\t\t}\n240\t\tpriorRelPath := filepath.Join(taskDir, priorTitle+\".md\")\n241\t\tpriorContent, err := readPriorForSupersede(ctx, gitClient, priorRelPath, cmd.TaskIdentifier)\n242\t\tif err != nil || priorContent == nil {\n243\t\t\treturn\n244\t\t}\n245\t\tif !priorIsInProgress(ctx, priorContent, priorRelPath, cmd.TaskIdentifier) {\n246\t\t\treturn\n247\t\t}\n248\t\ttransitionPrior(\n249\t\t\tctx,\n250\t\t\tgitClient,\n251\t\t\tcurrentDateTime,\n252\t\t\tpriorRelPath,\n253\t\t\tpriorTitle,\n254\t\t\tnewRelPath,\n255\t\t\tcmd.TaskIdentifier,\n256\t\t)\n257\t}\n258\t\n259\t// isEligibleForSupersede reports whether cmd is a recurring-task instance\n260\t// that should auto-supersede its prior. Returns true only when created_by is\n261\t// the recurring-task publisher AND auto_abort_prior is explicitly true (opt-in).\n262\t// Returns false (no supersede) when auto_abort_prior is absent or false — the\n263\t// safe default that prevents accidental supersede of audit-style tasks.\n264\tfunc isEligibleForSupersede(cmd task.CreateCommand) bool {\n265\t\tcreatedBy, _ := cmd.Frontmatter.String(\"created_by\")\n266\t\tif createdBy != \"recurring-task-creator\" {\n267\t\t\tglog.V(3).\n268\t\t\t\tInfof(\"auto-supersede: skip %s (created_by=%q != recurring-task-creator)\", cmd.TaskIdentifier, createdBy)\n269\t\t\treturn false\n270\t\t}\n271\t\tif b, _ := cmd.Frontmatter[\"auto_abort_prior\"].(bool); b {\n272\t\t\treturn true\n273\t\t}\n274\t\tif s, _ := cmd.Frontmatter[\"auto_abort_prior\"].(string); s == \"true\" {\n275\t\t\treturn true\n276\t\t}\n277\t\tglog.V(3).\n278\t\t\tInfof(\"auto-supersede: skip %s (auto_abort_prior not true — opt-in required)\", cmd.TaskIdentifier)\n279\t\treturn false\n280\t}\n281\t\n282\t// readPriorForSupersede reads the prior file. Returns (nil, nil) on a\n283\t// not-found (first-ever instance — benign no-op). Returns (nil, err) on a\n284\t// transient git-rest error (logged by caller).\n285\tfunc readPriorForSupersede(\n286\t\tctx context.Context,\n287\t\tgitClient gitclient.GitClient,\n288\t\tpriorRelPath string,\n289\t\ttaskIdentifier lib.TaskIdentifier,\n290\t) ([]byte, error) {\n291\t\tcontent, err := gitClient.ReadFile(ctx, priorRelPath)\n292\t\tif err == nil {\n293\t\t\treturn content, nil\n294\t\t}\n295\t\tif isNotFoundReadError(err) {\n296\t\t\tglog.V(3).\n297\t\t\t\tInfof(\"auto-supersede: no prior instance at %s for %s (first-ever instance)\", priorRelPath, taskIdentifier)\n298\t\t\treturn nil, nil\n299\t\t}\n300\t\tglog.Warningf(\n301\t\t\t\"auto-supersede: read prior %s failed for %s: %v\",\n302\t\t\tpriorRelPath,\n303\t\t\ttaskIdentifier,\n304\t\t\terr,\n305\t\t)\n306\t\treturn nil, err\n307\t}\n308\t\n309\t// priorIsInProgress parses the prior file's frontmatter and reports whether\n310\t// its status is in_progress. Returns false (no-op) on parse error or any\n311\t// non-in_progress status.\n312\tfunc priorIsInProgress(\n313\t\tctx context.Context,\n314\t\tcontent []byte,\n315\t\tpriorRelPath string,\n316\t\ttaskIdentifier lib.TaskIdentifier,\n317\t) bool {\n318\t\tfrontmatterStr, err := result.ExtractFrontmatter(ctx, content)\n319\t\tif err != nil {\n320\t\t\tglog.Warningf(\n321\t\t\t\t\"auto-supersede: extract frontmatter from prior %s failed for %s: %v\",\n322\t\t\t\tpriorRelPath,\n323\t\t\t\ttaskIdentifier,\n324\t\t\t\terr,\n325\t\t\t)\n326\t\t\treturn false\n327\t\t}\n328\t\tpriorFm, err := parseTaskFrontmatter(frontmatterStr)\n329\t\tif err != nil {\n330\t\t\tglog.Warningf(\n331\t\t\t\t\"auto-supersede: parse prior frontmatter %s failed for %s: %v\",\n332\t\t\t\tpriorRelPath,\n333\t\t\t\ttaskIdentifier,\n334\t\t\t\terr,\n335\t\t\t)\n336\t\t\treturn false\n337\t\t}\n338\t\tstatus, _ := priorFm.String(\"status\")\n339\t\tif status != \"in_progress\" {\n340\t\t\tglog.V(3).\n341\t\t\t\tInfof(\"auto-supersede: prior %s status=%q (not in_progress), no-op for %s\", priorRelPath, status, taskIdentifier)\n342\t\t\treturn false\n343\t\t}\n344\t\treturn true\n345\t}\n346\t\n347\t// transitionPrior performs the read-modify-write that transitions the prior\n348\t// file to aborted. Best-effort: write errors are logged and swallowed.\n349\tfunc transitionPrior(\n350\t\tctx context.Context,\n351\t\tgitClient gitclient.GitClient,\n352\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n353\t\tpriorRelPath string,\n354\t\tpriorTitle string,\n355\t\tnewRelPath string,\n356\t\ttaskIdentifier lib.TaskIdentifier,\n357\t) {\n358\t\tts := currentDateTime.Now().UTC().Format(time.RFC3339)\n359\t\tpriorAbsPath := filepath.Join(gitClient.Path(), priorRelPath)\n360\t\tmodify := buildSupersedeModifyFn(ctx, newRelPath, ts)\n361\t\tmsg := \"[agent-task-controller] auto-supersede prior recurring task \" + priorTitle\n362\t\tif err := gitClient.AtomicReadModifyWriteAndCommitPush(ctx, priorAbsPath, modify, msg); err != nil {\n363\t\t\tglog.Warningf(\n364\t\t\t\t\"auto-supersede: write prior %s failed for %s: %v\",\n365\t\t\t\tpriorRelPath,\n366\t\t\t\ttaskIdentifier,\n367\t\t\t\terr,\n368\t\t\t)\n369\t\t\treturn\n370\t\t}\n371\t\tglog.Infof(\n372\t\t\t\"auto-supersede: %s -> %s (prior superseded by new instance)\",\n373\t\t\tpriorRelPath,\n374\t\t\tnewRelPath,\n375\t\t)\n376\t}\n377\t\n378\t// buildSupersedeModifyFn builds the modify closure for AtomicReadModifyWriteAndCommitPush\n379\t// that transitions a prior-period recurring-task instance to aborted.\n380\tfunc buildSupersedeModifyFn(\n381\t\tctx context.Context,\n382\t\tnewRelPath string,\n383\t\tts string,\n384\t) func([]byte) ([]byte, error) {\n385\t\treturn func(current []byte) ([]byte, error) {\n386\t\t\tfmStr, err := result.ExtractFrontmatter(ctx, current)\n387\t\t\tif err != nil {\n388\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract frontmatter\")\n389\t\t\t}\n390\t\t\tbody, err := result.ExtractBody(ctx, current)\n391\t\t\tif err != nil {\n392\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract body\")\n393\t\t\t}\n394\t\t\tfm, err := parseTaskFrontmatter(fmStr)\n395\t\t\tif err != nil {\n396\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"parse frontmatter\")\n397\t\t\t}\n398\t\t\tfm[\"status\"] = \"aborted\"\n399\t\t\tfm[\"phase\"] = \"done\"\n400\t\t\tfm[\"completed_date\"] = ts\n401\t\t\tfm[\"superseded_by\"] = newRelPath\n402\t\t\tfm[\"created_by\"] = \"recurring-task-creator\"\n403\t\t\treturn marshalFileContent(ctx, fm, body)\n404\t\t}\n405\t}\n406\t"}]},"parent_tool_use_id":"call_function_9e58iwdnz9j9_1","session_id":"39ee2fda-6615-4b39-af19-b21d581ad85c","uuid":"14d86a22-fd41-4be7-9ea5-61c5dba4cb9f","timestamp":"2026-07-08T09:00:58.456Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
