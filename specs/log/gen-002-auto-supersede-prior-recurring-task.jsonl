{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0131bhMjV4jBSSuRaKcFck95","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage command\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"fmt\"\n10\t\t\"path/filepath\"\n11\t\n12\t\tlib \"github.com/bborbe/agent\"\n13\t\ttask \"github.com/bborbe/agent/command/task\"\n14\t\tdelivery \"github.com/bborbe/agent/delivery\"\n15\t\t\"github.com/bborbe/cqrs/base\"\n16\t\t\"github.com/bborbe/cqrs/cdb\"\n17\t\t\"github.com/bborbe/errors\"\n18\t\tlibkv \"github.com/bborbe/kv\"\n19\t\t\"github.com/golang/glog\"\n20\t\n21\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n22\t\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n23\t\t\"github.com/bborbe/agent-task-controller/pkg/result\"\n24\t)\n25\t\n26\t// UpdateFrontmatterCommandOperation is the CQRS command operation name for partial frontmatter update.\n27\tconst UpdateFrontmatterCommandOperation base.CommandOperation = task.UpdateFrontmatterCommandOperation\n28\t\n29\t// NewUpdateFrontmatterExecutor creates a cdb.CommandObjectExecutorTx that atomically\n30\t// reads the task file, merges only the specified key-value pairs, and commits.\n31\t// All other frontmatter keys are left unchanged.\n32\tfunc NewUpdateFrontmatterExecutor(\n33\t\tgitClient gitclient.GitClient,\n34\t\ttaskDir string,\n35\t) cdb.CommandObjectExecutorTx {\n36\t\treturn cdb.CommandObjectExecutorTxFunc(\n37\t\t\tUpdateFrontmatterCommandOperation,\n38\t\t\ttrue,\n39\t\t\tfunc(ctx context.Context, tx libkv.Tx, commandObject cdb.CommandObject) (*base.EventID, base.Event, error) {\n40\t\t\t\tvar cmd task.UpdateFrontmatterCommand\n41\t\t\t\tif err := commandObject.Command.Data.MarshalInto(ctx, &cmd); err != nil {\n42\t\t\t\t\treturn nil, nil, errors.Wrapf(\n43\t\t\t\t\t\tctx,\n44\t\t\t\t\t\tcdb.ErrCommandObjectSkipped,\n45\t\t\t\t\t\t\"malformed UpdateFrontmatterCommand: %v\",\n46\t\t\t\t\t\terr,\n47\t\t\t\t\t)\n48\t\t\t\t}\n49\t\t\t\t// Empty updates with no body section is a no-op — nothing to write.\n50\t\t\t\tif len(cmd.Updates) == 0 && cmd.Body == nil {\n51\t\t\t\t\treturn nil, nil, nil\n52\t\t\t\t}\n53\t\t\t\tmatchedRelPath, _, err := result.FindTaskFilePath(\n54\t\t\t\t\tctx,\n55\t\t\t\t\tgitClient,\n56\t\t\t\t\ttaskDir,\n57\t\t\t\t\tcmd.TaskIdentifier,\n58\t\t\t\t)\n59\t\t\t\tif err != nil {\n60\t\t\t\t\tmetrics.FrontmatterCommandsTotal.WithLabelValues(\"update-frontmatter\", \"error\").\n61\t\t\t\t\t\tInc()\n62\t\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"find task file for update\")\n63\t\t\t\t}\n64\t\t\t\tif matchedRelPath == \"\" {\n65\t\t\t\t\tglog.Warningf(\n66\t\t\t\t\t\t\"update-frontmatter: task file not found for %s, skipping\",\n67\t\t\t\t\t\tcmd.TaskIdentifier,\n68\t\t\t\t\t)\n69\t\t\t\t\tmetrics.FrontmatterCommandsTotal.WithLabelValues(\"update-frontmatter\", \"not_found\").\n70\t\t\t\t\t\tInc()\n71\t\t\t\t\treturn nil, nil, nil\n72\t\t\t\t}\n73\t\t\t\tfullAbsPath := filepath.Join(gitClient.Path(), matchedRelPath)\n74\t\t\t\tif err := gitClient.AtomicReadModifyWriteAndCommitPush(\n75\t\t\t\t\tctx,\n76\t\t\t\t\tfullAbsPath,\n77\t\t\t\t\tbuildUpdateModifyFn(ctx, cmd.Updates, cmd.Body),\n78\t\t\t\t\tfmt.Sprintf(\"[agent-task-controller] update frontmatter for task %s\", cmd.TaskIdentifier),\n79\t\t\t\t); err != nil {\n80\t\t\t\t\tmetrics.FrontmatterCommandsTotal.WithLabelValues(\"update-frontmatter\", \"error\").\n81\t\t\t\t\t\tInc()\n82\t\t\t\t\treturn nil, nil, errors.Wrapf(\n83\t\t\t\t\t\tctx,\n84\t\t\t\t\t\terr,\n85\t\t\t\t\t\t\"atomic update for task %s\",\n86\t\t\t\t\t\tcmd.TaskIdentifier,\n87\t\t\t\t\t)\n88\t\t\t\t}\n89\t\t\t\tmetrics.FrontmatterCommandsTotal.WithLabelValues(\"update-frontmatter\", \"success\").Inc()\n90\t\t\t\treturn nil, nil, nil\n91\t\t\t},\n92\t\t)\n93\t}\n94\t\n95\tfunc buildUpdateModifyFn(\n96\t\tctx context.Context,\n97\t\tupdates lib.TaskFrontmatter,\n98\t\tbodySection *task.BodySection,\n99\t) func([]byte) ([]byte, error) {\n100\t\treturn func(current []byte) ([]byte, error) {\n101\t\t\tfrontmatterStr, err := result.ExtractFrontmatter(ctx, current)\n102\t\t\tif err != nil {\n103\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract frontmatter\")\n104\t\t\t}\n105\t\t\tbody, err := result.ExtractBody(ctx, current)\n106\t\t\tif err != nil {\n107\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract body\")\n108\t\t\t}\n109\t\t\tfm, err := parseTaskFrontmatter(frontmatterStr)\n110\t\t\tif err != nil {\n111\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"parse frontmatter\")\n112\t\t\t}\n113\t\t\tfor k, v := range updates {\n114\t\t\t\tfm[k] = v\n115\t\t\t}\n116\t\t\tif bodySection != nil {\n117\t\t\t\tbody = delivery.ReplaceOrAppendSection(body, bodySection.Heading, bodySection.Section)\n118\t\t\t}\n119\t\t\t// spec 042: enforce phase: human_review → assignee: \"\" doctrine on the\n120\t\t\t// merged frontmatter in the same atomic write. No-op when the merge\n121\t\t\t// does not produce phase: human_review.\n122\t\t\tresult.ClearAssigneeIfHumanReview(fm)\n123\t\t\treturn marshalFileContent(ctx, fm, body)\n124\t\t}\n125\t}\n126\t"}]},"parent_tool_use_id":"call_function_5jclw9a5ulel_1","session_id":"d24d929e-901e-43de-a918-963fd3b15361","uuid":"7867c81f-f248-43cc-8862-fe8e4d7081d0","timestamp":"2026-06-30T09:40:49.203Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate dark-factory prompts from spec"}
