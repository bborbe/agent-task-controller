{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CwkjQPtdcg2bVfp6EL43Lg","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage gitrestclient\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"path/filepath\"\n10\t\t\"strings\"\n11\t\n12\t\t\"github.com/bborbe/errors\"\n13\t\t\"github.com/golang/glog\"\n14\t)\n15\t\n16\t// NewGitClient creates a GitClient backed by git-rest HTTP calls.\n17\t// basePath is the logical root path used when computing relative paths\n18\t// (e.g. \"/data/vault\") — it does NOT need to exist on disk.\n19\t// gitRestClient is the HTTP client created by NewGitRestClient.\n20\tfunc NewGitClient(gitRestClient GitRestClient, basePath string) GitClient {\n21\t\treturn &gitRestGitClientAdapter{\n22\t\t\tclient:   gitRestClient,\n23\t\t\tbasePath: strings.TrimRight(basePath, \"/\"),\n24\t\t}\n25\t}\n26\t\n27\ttype gitRestGitClientAdapter struct {\n28\t\tclient   GitRestClient\n29\t\tbasePath string\n30\t}\n31\t\n32\t// Compile-time assertion — catches missing methods if the GitClient interface evolves.\n33\tvar _ GitClient = (*gitRestGitClientAdapter)(nil)\n34\t\n35\t// EnsureCloned probes git-rest readiness at startup.\n36\tfunc (a *gitRestGitClientAdapter) EnsureCloned(ctx context.Context) error {\n37\t\tready, err := a.client.IsReady(ctx)\n38\t\tif err != nil {\n39\t\t\treturn errors.Wrapf(ctx, err, \"probe git-rest readiness\")\n40\t\t}\n41\t\tif !ready {\n42\t\t\treturn errors.Errorf(\n43\t\t\t\tctx,\n44\t\t\t\t\"git-rest is not ready (503); check vault-obsidian-openclaw pod status\",\n45\t\t\t)\n46\t\t}\n47\t\tglog.V(2).Infof(\"git-rest readiness confirmed\")\n48\t\treturn nil\n49\t}\n50\t\n51\t// Pull is a no-op — git-rest manages its own pulls internally.\n52\tfunc (a *gitRestGitClientAdapter) Pull(ctx context.Context) error {\n53\t\tglog.V(4).Infof(\"gitRestGitClientAdapter.Pull: no-op (git-rest handles pull internally)\")\n54\t\treturn nil\n55\t}\n56\t\n57\t// CommitAndPush is a no-op — git-rest auto-commits on every Post/Delete.\n58\tfunc (a *gitRestGitClientAdapter) CommitAndPush(ctx context.Context, message string) error {\n59\t\tglog.V(4).Infof(\"gitRestGitClientAdapter.CommitAndPush: no-op (git-rest auto-commits)\")\n60\t\treturn nil\n61\t}\n62\t\n63\t// Path returns the logical base path. Note: this path does NOT exist on disk when\n64\t// using the gitrest adapter — callers must use ReadFile/WriteFile/ListFiles instead\n65\t// of direct filesystem operations.\n66\tfunc (a *gitRestGitClientAdapter) Path() string {\n67\t\treturn a.basePath\n68\t}\n69\t\n70\t// AtomicWriteAndCommitPush writes content to absPath via git-rest POST.\n71\t// Atomicity relies on per-task Kafka partitioning (no local mutex).\n72\tfunc (a *gitRestGitClientAdapter) AtomicWriteAndCommitPush(\n73\t\tctx context.Context,\n74\t\tabsPath string,\n75\t\tcontent []byte,\n76\t\tmessage string,\n77\t) error {\n78\t\trel, err := filepath.Rel(a.basePath, absPath)\n79\t\tif err != nil || strings.HasPrefix(rel, \"..\") {\n80\t\t\treturn errors.Errorf(ctx, \"absPath %q is not under basePath %q\", absPath, a.basePath)\n81\t\t}\n82\t\tglog.V(3).Infof(\"gitrest: POST %s (%s)\", rel, message)\n83\t\treturn a.client.Post(ctx, rel, content)\n84\t}\n85\t\n86\t// AtomicReadModifyWriteAndCommitPush reads absPath, calls modify, then writes the result via git-rest.\n87\t// Atomicity relies on per-task Kafka partitioning (no local mutex).\n88\tfunc (a *gitRestGitClientAdapter) AtomicReadModifyWriteAndCommitPush(\n89\t\tctx context.Context,\n90\t\tabsPath string,\n91\t\tmodify func(current []byte) ([]byte, error),\n92\t\tmessage string,\n93\t) error {\n94\t\trel, err := filepath.Rel(a.basePath, absPath)\n95\t\tif err != nil || strings.HasPrefix(rel, \"..\") {\n96\t\t\treturn errors.Errorf(ctx, \"absPath %q is not under basePath %q\", absPath, a.basePath)\n97\t\t}\n98\t\tcurrent, err := a.client.Get(ctx, rel)\n99\t\tif err != nil {\n100\t\t\treturn errors.Wrapf(ctx, err, \"read file before modify %s\", rel)\n101\t\t}\n102\t\tupdated, err := modify(current)\n103\t\tif err != nil {\n104\t\t\treturn errors.Wrapf(ctx, err, \"modify func failed for %s\", rel)\n105\t\t}\n106\t\tglog.V(3).Infof(\"gitrest: POST (read-modify-write) %s (%s)\", rel, message)\n107\t\treturn errors.Wrapf(ctx, a.client.Post(ctx, rel, updated), \"write after modify %s\", rel)\n108\t}\n109\t\n110\t// ListFiles delegates to GitRestClient.List.\n111\tfunc (a *gitRestGitClientAdapter) ListFiles(ctx context.Context, glob string) ([]string, error) {\n112\t\treturn a.client.List(ctx, glob)\n113\t}\n114\t\n115\t// ReadFile delegates to GitRestClient.Get.\n116\tfunc (a *gitRestGitClientAdapter) ReadFile(ctx context.Context, relPath string) ([]byte, error) {\n117\t\tcontent, err := a.client.Get(ctx, relPath)\n118\t\treturn content, errors.Wrapf(ctx, err, \"read file %s\", relPath)\n119\t}\n120\t\n121\t// WriteFile delegates to GitRestClient.Post.\n122\tfunc (a *gitRestGitClientAdapter) WriteFile(\n123\t\tctx context.Context,\n124\t\trelPath string,\n125\t\tcontent []byte,\n126\t) error {\n127\t\treturn errors.Wrapf(ctx, a.client.Post(ctx, relPath, content), \"write file %s\", relPath)\n128\t}\n129\t"}]},"parent_tool_use_id":"call_function_5jclw9a5ulel_1","session_id":"d24d929e-901e-43de-a918-963fd3b15361","uuid":"d6aca3e1-463f-4236-9950-7e854c853601","timestamp":"2026-06-30T09:40:34.631Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate dark-factory prompts from spec"}
