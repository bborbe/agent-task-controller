{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LkbfWjxMxF59ccjqTA8BmT","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage command\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"maps\"\n10\t\t\"path/filepath\"\n11\t\t\"strings\"\n12\t\n13\t\tlib \"github.com/bborbe/agent\"\n14\t\ttask \"github.com/bborbe/agent/command/task\"\n15\t\t\"github.com/bborbe/cqrs/base\"\n16\t\t\"github.com/bborbe/cqrs/cdb\"\n17\t\t\"github.com/bborbe/errors\"\n18\t\tlibkv \"github.com/bborbe/kv\"\n19\t\t\"github.com/bborbe/validation\"\n20\t\t\"github.com/golang/glog\"\n21\t\n22\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n23\t\t\"github.com/bborbe/agent-task-controller/pkg/routing\"\n24\t)\n25\t\n26\t// NewCreateTaskExecutor creates a cdb.CommandObjectExecutorTx that materializes\n27\t// a new vault task file for the given task_identifier. If cmd.Title passes validation\n28\t// the file is written at tasks/{title}.md; otherwise it falls back to tasks/{task_identifier}.md.\n29\t// If a file already exists at the resolved path the command returns ErrTaskAlreadyExists\n30\t// (a benign Failure on the result topic — no overwrite, no git write).\n31\t// Frontmatter must include \"assignee\" and \"status\"; missing fields return a wrapped validation error.\n32\t// Commands whose effective target vault (cmd.TargetVault or the legacy fallback) does not\n33\t// match vaultName are skipped without side effects (no git write, no error, no result event).\n34\tfunc NewCreateTaskExecutor(\n35\t\tgitClient gitclient.GitClient,\n36\t\ttaskDir string,\n37\t\tvaultName string,\n38\t) cdb.CommandObjectExecutorTx {\n39\t\treturn cdb.CommandObjectExecutorTxFunc(\n40\t\t\ttask.CreateCommandOperation,\n41\t\t\ttrue,\n42\t\t\tfunc(ctx context.Context, tx libkv.Tx, commandObject cdb.CommandObject) (*base.EventID, base.Event, error) {\n43\t\t\t\tvar cmd task.CreateCommand\n44\t\t\t\tif err := commandObject.Command.Data.MarshalInto(ctx, &cmd); err != nil {\n45\t\t\t\t\treturn nil, nil, errors.Wrapf(\n46\t\t\t\t\t\tctx,\n47\t\t\t\t\t\tcdb.ErrCommandObjectSkipped,\n48\t\t\t\t\t\t\"malformed CreateTaskCommand: %v\",\n49\t\t\t\t\t\terr,\n50\t\t\t\t\t)\n51\t\t\t\t}\n52\t\t\t\tif err := cmd.TaskIdentifier.Validate(ctx); err != nil {\n53\t\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate task_identifier\")\n54\t\t\t\t}\n55\t\t\t\tif !routing.ShouldProcess(cmd, vaultName) {\n56\t\t\t\t\teffective := cmd.TargetVault\n57\t\t\t\t\tif effective == \"\" {\n58\t\t\t\t\t\teffective = routing.LegacyDefaultVault\n59\t\t\t\t\t}\n60\t\t\t\t\tglog.V(2).Infof(\n61\t\t\t\t\t\t\"create-task: skipped vault mismatch target=%q effective=%q vault=%q task=%s\",\n62\t\t\t\t\t\tcmd.TargetVault, effective, vaultName, cmd.TaskIdentifier,\n63\t\t\t\t\t)\n64\t\t\t\t\treturn nil, nil, nil\n65\t\t\t\t}\n66\t\t\t\tif err := validateCreateTaskFrontmatter(ctx, cmd.Frontmatter); err != nil {\n67\t\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate frontmatter\")\n68\t\t\t\t}\n69\t\t\t\trelPath := resolveCreateTaskRelPath(ctx, taskDir, cmd)\n70\t\t\t\tif existing, err := gitClient.ReadFile(ctx, relPath); err == nil {\n71\t\t\t\t\t// File present at the title path → collision. Write nothing; return the\n72\t\t\t\t\t// sentinel so the CQRS framework emits a benign Failure on the result topic.\n73\t\t\t\t\tglog.V(2).Infof(\n74\t\t\t\t\t\t\"create-task: title path %s already occupied (%d bytes), returning ErrTaskAlreadyExists for %s\",\n75\t\t\t\t\t\trelPath,\n76\t\t\t\t\t\tlen(existing),\n77\t\t\t\t\t\tcmd.TaskIdentifier,\n78\t\t\t\t\t)\n79\t\t\t\t\treturn nil, nil, errors.Wrapf(\n80\t\t\t\t\t\tctx, task.ErrTaskAlreadyExists, \"title path %s occupied\", relPath,\n81\t\t\t\t\t)\n82\t\t\t\t} else if !isNotFoundReadError(err) {\n83\t\t\t\t\t// Transient / unexpected git-rest read error → propagate, do NOT write.\n84\t\t\t\t\treturn nil, nil, errors.Wrapf(\n85\t\t\t\t\t\tctx, err, \"check existing task file at %s for %s\", relPath, cmd.TaskIdentifier,\n86\t\t\t\t\t)\n87\t\t\t\t}\n88\t\t\t\t// err is a \"not found\" read error → title path is free, proceed to write.\n89\t\n90\t\t\t\tcontent, err := buildCreateTaskContent(ctx, cmd)\n91\t\t\t\tif err != nil {\n92\t\t\t\t\treturn nil, nil, errors.Wrapf(\n93\t\t\t\t\t\tctx,\n94\t\t\t\t\t\terr,\n95\t\t\t\t\t\t\"build task file content for %s\",\n96\t\t\t\t\t\tcmd.TaskIdentifier,\n97\t\t\t\t\t)\n98\t\t\t\t}\n99\t\t\t\tabsPath := filepath.Join(gitClient.Path(), relPath)\n100\t\t\t\tif err := gitClient.AtomicWriteAndCommitPush(\n101\t\t\t\t\tctx,\n102\t\t\t\t\tabsPath,\n103\t\t\t\t\tcontent,\n104\t\t\t\t\t\"[agent-task-controller] create task \"+string(cmd.TaskIdentifier),\n105\t\t\t\t); err != nil {\n106\t\t\t\t\treturn nil, nil, errors.Wrapf(\n107\t\t\t\t\t\tctx,\n108\t\t\t\t\t\terr,\n109\t\t\t\t\t\t\"atomic write and push for task %s\",\n110\t\t\t\t\t\tcmd.TaskIdentifier,\n111\t\t\t\t\t)\n112\t\t\t\t}\n113\t\t\t\tglog.V(2).\n114\t\t\t\t\tInfof(\"create-task: created task file at %s for %s\", relPath, cmd.TaskIdentifier)\n115\t\t\t\treturn nil, nil, nil\n116\t\t\t},\n117\t\t)\n118\t}\n119\t\n120\t// resolveCreateTaskRelPath returns the repo-root-relative path where the task\n121\t// file should be written. If cmd.Title passes validation and contains no path\n122\t// separators, the title-derived path is returned; otherwise a WARN is logged and\n123\t// the UUID-derived path is returned as fallback so the task is always materialized.\n124\t// Filename-collision detection is the caller's job (via gitClient.ReadFile) — this\n125\t// function no longer reads the vault or compares task_identifier.\n126\tfunc resolveCreateTaskRelPath(\n127\t\tctx context.Context,\n128\t\ttaskDir string,\n129\t\tcmd task.CreateCommand,\n130\t) string {\n131\t\tuuidRelPath := filepath.Join(taskDir, string(cmd.TaskIdentifier)+\".md\")\n132\t\n133\t\t// Re-validate the command (defense-in-depth: sender may have been bypassed).\n134\t\tif err := cmd.Validate(ctx); err != nil {\n135\t\t\tglog.Warningf(\n136\t\t\t\t\"create-task: Title validation failed for task %s (%v); falling back to UUID path\",\n137\t\t\t\tcmd.TaskIdentifier, err,\n138\t\t\t)\n139\t\t\treturn uuidRelPath\n140\t\t}\n141\t\n142\t\t// Reject titles containing path separators to prevent path traversal.\n143\t\tif strings.ContainsAny(cmd.Title, \"/\\\\\") {\n144\t\t\tglog.Warningf(\n145\t\t\t\t\"create-task: Title %q contains path separator; falling back to UUID path\",\n146\t\t\t\tcmd.Title,\n147\t\t\t)\n148\t\t\treturn uuidRelPath\n149\t\t}\n150\t\n151\t\treturn filepath.Join(taskDir, cmd.Title+\".md\")\n152\t}\n153\t\n154\t// isNotFoundReadError reports whether a gitClient.ReadFile error means the file\n155\t// does not exist (git-rest returns HTTP 404). git-rest's Get does not expose a\n156\t// typed not-found sentinel, so this matches the \"404\" status embedded in the\n157\t// wrapped error message produced by gitRestClient.Get\n158\t// (\"GET <path> returned 404: ...\"). A nil error is NOT a not-found error and must\n159\t// be handled by the caller before calling this helper.\n160\tfunc isNotFoundReadError(err error) bool {\n161\t\tif err == nil {\n162\t\t\treturn false\n163\t\t}\n164\t\treturn strings.Contains(err.Error(), \"returned 404\")\n165\t}\n166\t\n167\tfunc validateCreateTaskFrontmatter(ctx context.Context, fm lib.TaskFrontmatter) error {\n168\t\tif fm.Assignee() == \"\" {\n169\t\t\treturn errors.Wrap(ctx, validation.Error, \"frontmatter missing required field: assignee\")\n170\t\t}\n171\t\tif s, _ := fm.String(\"status\"); s == \"\" {\n172\t\t\treturn errors.Wrap(ctx, validation.Error, \"frontmatter missing required field: status\")\n173\t\t}\n174\t\treturn nil\n175\t}\n176\t\n177\tfunc buildCreateTaskContent(ctx context.Context, cmd task.CreateCommand) ([]byte, error) {\n178\t\tfm := make(lib.TaskFrontmatter)\n179\t\tmaps.Copy(fm, cmd.Frontmatter)\n180\t\tfm[\"task_identifier\"] = string(cmd.TaskIdentifier)\n181\t\treturn marshalFileContent(ctx, fm, cmd.Body)\n182\t}\n183\t"}]},"parent_tool_use_id":"call_function_5jclw9a5ulel_1","session_id":"d24d929e-901e-43de-a918-963fd3b15361","uuid":"66ebe6a1-4fa6-4218-b152-6e2fa4ea6815","timestamp":"2026-06-30T09:40:28.904Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate dark-factory prompts from spec"}
