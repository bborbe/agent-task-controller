rr, \"probe git-rest readiness\")\n84\t\t}\n85\t\tglog.V(1).Infof(\"using git-rest HTTP API at %s\", a.GitRestURL)\n86\t\n87\t\tsyncProducer, err := libkafka.NewSyncProducer(\n88\t\t\tctx,\n89\t\t\tlibkafka.ParseBrokersFromString(a.KafkaBrokers),\n90\t\t)\n91\t\tif err != nil {\n92\t\t\treturn errors.Wrapf(ctx, err, \"create kafka sync producer\")\n93\t\t}\n94\t\tdefer syncProducer.Close()\n95\t\n96\t\teventObjectSender := cdb.NewEventObjectSender(\n97\t\t\tlibkafka.NewJSONSender(syncProducer, log.DefaultSamplerFactory),\n98\t\t\ta.Branch,\n99\t\t\tlog.DefaultSamplerFactory,\n100\t\t)\n101\t\n102\t\tcurrentDateTime := libtime.NewCurrentDateTime()\n103\t\n104\t\ttrigger := make(chan struct{}, 1)\n105\t\tsyncLoop := pkgsync.NewSyncLoop(\n106\t\t\tscanner.NewGitRestVaultScanner(\n107\t\t\t\tgitClient,\n108\t\t\t\ta.TaskDir,\n109\t\t\t\ta.PollInterval,\n110\t\t\t\ttrigger,\n111\t\t\t\tmetrics.New(),\n112\t\t\t),\n113\t\t\tpublisher.NewTaskPublisher(eventObjectSender, lib.TaskV1SchemaID, currentDateTime),\n114\t\t\ttrigger,\n115\t\t\tmetrics.New(),\n116\t\t)\n117\t\n118\t\tvar boltOptions []boltkv.ChangeOptions\n119\t\tif a.NoSync {\n120\t\t\tboltOptions = append(boltOptions, func(opts *bolt.Options) {\n121\t\t\t\topts.NoSync = true\n122\t\t\t})\n123\t\t}\n124\t\tdb, err := boltkv.OpenDir(ctx, a.DataDir, boltOptions...)\n125\t\tif err != nil {\n126\t\t\treturn errors.Wrapf(ctx, err, \"open boltkv dir %s\", a.DataDir)\n127\t\t}\n128\t\tdefer db.Close()\n129\t\n130\t\tsaramaClientProvider, err := libkafka.NewSaramaClientProviderByType(\n131\t\t\tctx,\n132\t\t\tlibkafka.SaramaClientProviderTypeReused,\n133\t\t\tlibkafka.ParseBrokersFromString(a.KafkaBrokers),\n134\t\t)\n135\t\tif err != nil {\n136\t\t\treturn errors.Wrapf(ctx, err, \"create sarama client provider\")\n137\t\t}\n138\t\tdefer saramaClientProvider.Close()\n139\t\n140\t\tresultWriter := result.NewResultWriter(gitClient, a.TaskDir, currentDateTime)\n141\t\tcommandConsumer := factory.CreateCommandConsumer(\n142\t\t\tsaramaClientProvider,\n143\t\t\tsyncProducer,\n144\t\t\tdb,\n145\t\t\ta.Branch,\n146\t\t\tresultWriter,\n147\t\t\tgitClient,\n148\t\t\ta.TaskDir,\n149\t\t\ta.VaultName,\n150\t\t)\n151\t\n152\t\treturn service.Run(\n153\t\t\tctx,\n154\t\t\tsyncLoop.Run,\n155\t\t\tcommandConsumer,\n156\t\t\ta.createHTTPServer(syncLoop, restClient),\n157\t\t)\n158\t}\n159\t\n160\tfunc (a *application) createHTTPServer(\n161\t\tsyncLoop pkgsync.SyncLoop,\n162\t\tgitRestClient gitrestclient.GitRestClient,\n163\t) run.Func {\n164\t\treturn func(ctx context.Context) error {\n165\t\t\trouter := mux.NewRouter()\n166\t\t\trouter.Path(\"/healthz\").Handler(libhttp.NewPrintHandler(\"OK\"))\n167\t\t\trouter.Path(\"/readiness\").HandlerFunc(func(w http.ResponseWriter, req *http.Request) {\n168\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain\")\n169\t\t\t\tready, err := gitRestClient.IsReady(req.Context())\n170\t\t\t\tif err != nil || !ready {\n171\t\t\t\t\tw.WriteHeader(http.StatusServiceUnavailable)\n172\t\t\t\t\t_, _ = w.Write([]byte(\"git-rest not ready\"))\n173\t\t\t\t\treturn\n174\t\t\t\t}\n175\t\t\t\t_, _ = w.Write([]byte(\"OK\"))\n176\t\t\t})\n177\t\t\trouter.Path(\"/metrics\").Handler(promhttp.Handler())\n178\t\t\trouter.Path(\"/setloglevel/{level}\").\n179\t\t\t\tHandler(log.NewSetLoglevelHandler(ctx, log.NewLogLevelSetter(2, 5*time.Minute)))\n180\t\t\trouter.Path(\"/trigger\").HandlerFunc(func(resp http.ResponseWriter, req *http.Request) {\n181\t\t\t\tsyncLoop.Trigger()\n182\t\t\t\tglog.V(2).Infof(\"trigger fired via HTTP\")\n183\t\t\t\t_, _ = resp.Write([]byte(\"trigger fired\"))\n184\t\t\t})\n185\t\n186\t\t\tglog.V(2).Infof(\"starting http server listen on %s\", a.Listen)\n187\t\t\treturn libhttp.NewServer(\n188\t\t\t\ta.Listen,\n189\t\t\t\trouter,\n190\t\t\t).Run(ctx)\n191\t\t}\n192\t}\n193\t"}]},"parent_tool_use_id":"call_function_gndwq2feccxh_1","session_id":"213d66d0-dce3-49f1-a7b2-16c36173f959","uuid":"63bf80b0-992f-4ddd-8fe7-29d470f8fe71","timestamp":"2026-06-27T21:33:33