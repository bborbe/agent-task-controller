flect.Zero(underlyingType).Interface()\n52\t\t\t\tif ef.Interface() == zeroValue {\n53\t\t\t\t\treturn true, createError()\n54\t\t\t\t}\n55\t\t\t\treturn true, nil\n56\t\t\tcase reflect.Float64:\n57\t\t\t\t// For custom float64 types, check if value equals zero value of underlying type\n58\t\t\t\tzeroValue := reflect.Zero(underlyingType).Interface()\n59\t\t\t\tif ef.Interface() == zeroValue {\n60\t\t\t\t\treturn true, createError()\n61\t\t\t\t}\n62\t\t\t\treturn true, nil\n63\t\t\t}\n64\t\t}\n65\t\treturn false, nil\n66\t}\n67\t\n68\t// ValidateRequired fields are set and returns an error if not.\n69\tfunc ValidateRequired(ctx context.Context, data interface{}) error {\n70\t\te := reflect.ValueOf(data).Elem()\n71\t\tt := e.Type()\n72\t\tfor i := 0; i < e.NumField(); i++ {\n73\t\t\ttf := t.Field(i)\n74\t\t\tef := e.Field(i)\n75\t\t\targName, ok := tf.Tag.Lookup(\"required\")\n76\t\t\tif !ok || argName != \"true\" {\n77\t\t\t\tcontinue\n78\t\t\t}\n79\t\t\tif err := validateRequiredField(ctx, tf, ef); err != nil {\n80\t\t\t\treturn err\n81\t\t\t}\n82\t\t}\n83\t\treturn nil\n84\t}\n85\t\n86\t// validateRequiredField checks if a single required field is set.\n87\tfunc validateRequiredField(ctx context.Context, tf reflect.StructField, ef reflect.Value) error {\n88\t\tcreateError := func() error {\n89\t\t\tbuf := bytes.NewBufferString(\"Required field empty, \")\n90\t\t\targName, argOk := tf.Tag.Lookup(\"arg\")\n91\t\t\tif argOk {\n92\t\t\t\tfmt.Fprintf(buf, \"define parameter %s\", argName)\n93\t\t\t}\n94\t\t\tenvName, envOk := tf.Tag.Lookup(\"env\")\n95\t\t\tif envOk {\n96\t\t\t\tif argOk {\n97\t\t\t\t\tfmt.Fprintf(buf, \" or \")\n98\t\t\t\t}\n99\t\t\t\tfmt.Fprintf(buf, \"define env %s\", envName)\n100\t\t\t}\n101\t\t\treturn errors.New(ctx, buf.String())\n102\t\t}\n103\t\n104\t\tswitch ef.Interface().(type) {\n105\t\tcase string:\n106\t\t\tvar empty string\n107\t\t\tif empty == ef.Interface() {\n108\t\t\t\treturn createError()\n109\t\t\t}\n110\t\tcase bool:\n111\t\tcase