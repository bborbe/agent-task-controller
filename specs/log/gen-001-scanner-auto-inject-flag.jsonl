{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_019f0b008b9075a1b92df37c","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage scanner\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"crypto/sha256\"\n10\t\t\"os\"\n11\t\t\"path/filepath\"\n12\t\t\"time\"\n13\t\n14\t\tlib \"github.com/bborbe/agent\"\n15\t\t\"github.com/bborbe/errors\"\n16\t\t\"github.com/golang/glog\"\n17\t\t\"github.com/google/uuid\"\n18\t\t\"gopkg.in/yaml.v3\"\n19\t\n20\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n21\t\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n22\t)\n23\t\n24\t// ScanResult holds the outcome of a single vault scan cycle.\n25\ttype ScanResult struct {\n26\t\tChanged []lib.Task           // tasks whose content changed (new or modified)\n27\t\tDeleted []lib.TaskIdentifier // task identifiers that were previously known but are now gone\n28\t}\n29\t\n30\t//counterfeiter:generate -o ../../mocks/vault_scanner.go --fake-name VaultScanner . VaultScanner\n31\ttype VaultScanner interface {\n32\t\t// Run starts the polling loop. Blocks until ctx is cancelled.\n33\t\t// Results are sent to the provided channel; the caller owns the channel.\n34\t\tRun(ctx context.Context, results chan<- ScanResult) error\n35\t\t// RunCycle executes a single scan cycle (git pull + file scan + optional commit/push).\n36\t\t// Exported for use in scanner_test package; prefer Run() in production.\n37\t\tRunCycle(ctx context.Context, results chan<- ScanResult)\n38\t}\n39\t\n40\ttype fileEntry struct {\n41\t\thash           [32]byte\n42\t\ttaskIdentifier lib.TaskIdentifier\n43\t\tassignee       lib.TaskAssignee\n44\t}\n45\t\n46\t// fileOps holds pluggable file I/O functions so the scanner can operate over\n47\t// either a local filesystem or the git-rest HTTP API.\n48\ttype fileOps struct {\n49\t\tlistFiles func(ctx context.Context, glob string) ([]string, error)\n50\t\treadFile  func(ctx context.Context, relPath string) ([]byte, error)\n51\t\twriteFile func(ctx context.Context, relPath string, content []byte) error\n52\t}\n53\t\n54\ttype vaultScanner struct {\n55\t\tgitClient    gitclient.GitClient\n56\t\ttaskDir      string\n57\t\tpollInterval time.Duration\n58\t\thashes       map[string]fileEntry\n59\t\ttrigger      <-chan struct{}\n60\t\tmetrics      metrics.Metrics\n61\t\tops          fileOps\n62\t}\n63\t\n64\t// newLocalFileOps creates fileOps backed by the local filesystem rooted at basePath.\n65\tfunc newLocalFileOps(basePath string) fileOps {\n66\t\treturn fileOps{\n67\t\t\tlistFiles: func(_ context.Context, glob string) ([]string, error) {\n68\t\t\t\tmatches, err := filepath.Glob(filepath.Join(basePath, glob))\n69\t\t\t\tif err != nil {\n70\t\t\t\t\treturn nil, err\n71\t\t\t\t}\n72\t\t\t\trel := make([]string, 0, len(matches))\n73\t\t\t\tfor _, m := range matches {\n74\t\t\t\t\tr, relErr := filepath.Rel(basePath, m)\n75\t\t\t\t\tif relErr != nil {\n76\t\t\t\t\t\tcontinue\n77\t\t\t\t\t}\n78\t\t\t\t\trel = append(rel, r)\n79\t\t\t\t}\n80\t\t\t\treturn rel, nil\n81\t\t\t},\n82\t\t\treadFile: func(_ context.Context, relPath string) ([]byte, error) {\n83\t\t\t\treturn os.ReadFile(\n84\t\t\t\t\tfilepath.Join(basePath, relPath),\n85\t\t\t\t) // #nosec G304 -- basePath is a trusted vault path\n86\t\t\t},\n87\t\t\twriteFile: func(_ context.Context, relPath string, content []byte) error {\n88\t\t\t\treturn os.WriteFile(\n89\t\t\t\t\tfilepath.Join(basePath, relPath),\n90\t\t\t\t\tcontent,\n91\t\t\t\t\t0600,\n92\t\t\t\t) // #nosec G306 -- controlled task file\n93\t\t\t},\n94\t\t}\n95\t}\n96\t\n97\t// NewVaultScanner creates a VaultScanner that polls git and scans the task directory.\n98\tfunc NewVaultScanner(\n99\t\tgitClient gitclient.GitClient,\n100\t\ttaskDir string,\n101\t\tpollInterval time.Duration,\n102\t\ttrigger <-chan struct{},\n103\t\tm metrics.Metrics,\n104\t) VaultScanner {\n105\t\treturn &vaultScanner{\n106\t\t\tgitClient:    gitClient,\n107\t\t\ttaskDir:      taskDir,\n108\t\t\tpollInterval: pollInterval,\n109\t\t\thashes:       make(map[string]fileEntry),\n110\t\t\ttrigger:      trigger,\n111\t\t\tmetrics:      m,\n112\t\t\tops:          newLocalFileOps(gitClient.Path()),\n113\t\t}\n114\t}\n115\t\n116\t// NewGitRestVaultScanner creates a VaultScanner that reads and writes vault files\n117\t// via the gitclient.GitClient interface methods (ListFiles, ReadFile, WriteFile).\n118\t// Use this constructor when git-rest HTTP mode is enabled.\n119\tfunc NewGitRestVaultScanner(\n120\t\tgitClient gitclient.GitClient,\n121\t\ttaskDir string,\n122\t\tpollInterval time.Duration,\n123\t\ttrigger <-chan struct{},\n124\t\tm metrics.Metrics,\n125\t) VaultScanner {\n126\t\treturn &vaultScanner{\n127\t\t\tgitClient:    gitClient,\n128\t\t\ttaskDir:      taskDir,\n129\t\t\tpollInterval: pollInterval,\n130\t\t\thashes:       make(map[string]fileEntry),\n131\t\t\ttrigger:      trigger,\n132\t\t\tmetrics:      m,\n133\t\t\tops: fileOps{\n134\t\t\t\tlistFiles: gitClient.ListFiles,\n135\t\t\t\treadFile:  gitClient.ReadFile,\n136\t\t\t\twriteFile: gitClient.WriteFile,\n137\t\t\t},\n138\t\t}\n139\t}\n140\t\n141\tfunc (v *vaultScanner) Run(ctx context.Context, results chan<- ScanResult) error {\n142\t\tticker := time.NewTicker(v.pollInterval)\n143\t\tdefer ticker.Stop()\n144\t\tfor {\n145\t\t\tselect {\n146\t\t\tcase <-ctx.Done():\n147\t\t\t\treturn nil\n148\t\t\tcase <-ticker.C:\n149\t\t\t\tv.RunCycle(ctx, results)\n150\t\t\tcase <-v.trigger:\n151\t\t\t\tv.RunCycle(ctx, results)\n152\t\t\t}\n153\t\t}\n154\t}\n155\t\n156\t// RunCycle executes a single scan cycle (git pull + file scan + optional commit/push).\n157\t// Exported for use in scanner_test package; prefer Run() in production.\n158\tfunc (v *vaultScanner) RunCycle(ctx context.Context, results chan<- ScanResult) {\n159\t\tif err := v.gitClient.Pull(ctx); err != nil {\n160\t\t\tglog.Warningf(\"git pull failed: %v\", err)\n161\t\t\treturn\n162\t\t}\n163\t\tglog.V(3).Infof(\"git pull succeeded, scanning %s\", v.taskDir)\n164\t\n165\t\tchanged, deleted, written, writeError := v.scanFiles(ctx)\n166\t\n167\t\tif len(written) > 0 && !writeError {\n168\t\t\tif err := v.gitClient.CommitAndPush(ctx, \"[agent-task-controller] update task metadata\"); err != nil {\n169\t\t\t\tglog.Warningf(\"git commit+push failed, skipping publish: %v\", err)\n170\t\t\t\treturn\n171\t\t\t}\n172\t\t}\n173\t\n174\t\tresult := ScanResult{Changed: changed, Deleted: deleted}\n175\t\tselect {\n176\t\tcase results <- result:\n177\t\tdefault:\n178\t\t}\n179\t}\n180\t\n181\tfunc (v *vaultScanner) scanFiles(\n182\t\tctx context.Context,\n183\t) ([]lib.Task, []lib.TaskIdentifier, []string, bool) {\n184\t\tglob := v.taskDir + \"/*.md\"\n185\t\tpaths, err := v.ops.listFiles(ctx, glob)\n186\t\tif err != nil {\n187\t\t\tglog.Warningf(\"list %s failed: %v\", glob, err)\n188\t\t\treturn nil, nil, nil, false\n189\t\t}\n190\t\tseen := make(map[string]struct{})\n191\t\tvar changed []lib.Task\n192\t\tvar written []string\n193\t\twriteError := false\n194\t\tfor _, relPath := range paths {\n195\t\t\tselect {\n196\t\t\tcase <-ctx.Done():\n197\t\t\t\treturn nil, nil, nil, false\n198\t\t\tdefault:\n199\t\t\t}\n200\t\t\tseen[relPath] = struct{}{}\n201\t\t\ttask, wrote, werr := v.processFile(ctx, relPath)\n202\t\t\tif werr {\n203\t\t\t\twriteError = true\n204\t\t\t}\n205\t\t\tif wrote != \"\" {\n206\t\t\t\twritten = append(written, wrote)\n207\t\t\t}\n208\t\t\tif task != nil {\n209\t\t\t\tchanged = append(changed, *task)\n210\t\t\t}\n211\t\t}\n212\t\tdeleted, err := v.collectDeleted(ctx, seen)\n213\t\tif err != nil {\n214\t\t\tglog.V(4).Infof(\"collectDeleted: %v\", err)\n215\t\t}\n216\t\treturn changed, deleted, written, writeError\n217\t}\n218\t\n219\t// processFile handles a single .md file during a scan cycle.\n220\t// Returns (task, writtenRelPath, writeError).\n221\t//\n222\t//nolint:funlen // +5 statements from spec-043 counter calls at 5 skip sites; each site needs its own metric.\n223\tfunc (v *vaultScanner) processFile(\n224\t\tctx context.Context,\n225\t\trelPath string,\n226\t) (*lib.Task, string, bool) {\n227\t\tcontent, readErr := v.ops.readFile(ctx, relPath)\n228\t\tif readErr != nil {\n229\t\t\tglog.Warningf(\"failed to read %s: %v\", relPath, readErr)\n230\t\t\tv.metrics.SkippedFilesTotal(metrics.ReasonReadFailed).Inc()\n231\t\t\treturn nil, \"\", false\n232\t\t}\n233\t\thash := sha256.Sum256(content)\n234\t\tif existing, ok := v.hashes[relPath]; ok && existing.hash == hash {\n235\t\t\treturn nil, \"\", false\n236\t\t}\n237\t\tfmYAML, err := extractFrontmatter(ctx, content)\n238\t\tif err != nil {\n239\t\t\tglog.Errorf(\"skipping %s: invalid frontmatter: %v\", relPath, err)\n240\t\t\tv.metrics.SkippedFilesTotal(metrics.ReasonInvalidFrontmatter).Inc()\n241\t\t\treturn nil, \"\", false\n242\t\t}\n243\t\tdedupedYAML, hasDuplicates, dedupErr := DeduplicateFrontmatter(ctx, fmYAML)\n244\t\tif dedupErr != nil {\n245\t\t\tglog.Errorf(\"skipping %s: invalid frontmatter: %v\", relPath, dedupErr)\n246\t\t\tv.metrics.SkippedFilesTotal(metrics.ReasonDuplicateFrontmatterInvalid).Inc()\n247\t\t\treturn nil, \"\", false\n248\t\t}\n249\t\tif hasDuplicates {\n250\t\t\tglog.Warningf(\"file %s has duplicate frontmatter keys, deduplicating\", relPath)\n251\t\t}\n252\t\tvar fmMap map[string]interface{}\n253\t\tif err := yaml.Unmarshal([]byte(dedupedYAML), &fmMap); err != nil {\n254\t\t\tglog.Errorf(\"skipping %s: invalid frontmatter: %v\", relPath, err)\n255\t\t\tv.metrics.SkippedFilesTotal(metrics.ReasonInvalidFrontmatter).Inc()\n256\t\t\treturn nil, \"\", false\n257\t\t}\n258\t\tfrontmatter := lib.TaskFrontmatter(fmMap)\n259\t\ttaskID, _ := fmMap[\"task_identifier\"].(string)\n260\t\tcurrentFMAssignee := frontmatter.Assignee()\n261\t\tif taskID == \"\" {\n262\t\t\treturn v.injectAndStore(ctx, content, relPath, currentFMAssignee)\n263\t\t}\n264\t\tif !isValidUUID(taskID) {\n265\t\t\tglog.Warningf(\"replacing non-UUID task_identifier %q in %s\", taskID, relPath)\n266\t\t\treturn v.injectAndStore(ctx, removeTaskIdentifier(content), relPath, currentFMAssignee)\n267\t\t}\n268\t\tif !v.isIdentifierUnique(taskID, relPath) {\n269\t\t\tglog.Warningf(\"replacing duplicate task_identifier %q in %s\", taskID, relPath)\n270\t\t\treturn v.injectAndStore(ctx, removeTaskIdentifier(content), relPath, currentFMAssignee)\n271\t\t}\n272\t\tprevEntry := v.hashes[relPath]\n273\t\n274\t\t// Detect empty → named assignee transition (operator re-delegated a parked task).\n275\t\tif currentFMAssignee != \"\" && prevEntry.taskIdentifier != \"\" && prevEntry.assignee == \"\" {\n276\t\t\twrote, werr := v.writeCounterReset(ctx, relPath, content, fmMap)\n277\t\t\tif werr {\n278\t\t\t\treturn nil, \"\", true\n279\t\t\t}\n280\t\t\tif wrote != \"\" {\n281\t\t\t\t// Store zero-hash sentinel so next scan re-processes and publishes the task.\n282\t\t\t\t// Store new assignee so the transition is not re-triggered on the next pass.\n283\t\t\t\tv.hashes[relPath] = fileEntry{\n284\t\t\t\t\thash:           [32]byte{},\n285\t\t\t\t\ttaskIdentifier: lib.TaskIdentifier(taskID),\n286\t\t\t\t\tassignee:       currentFMAssignee,\n287\t\t\t\t}\n288\t\t\t\treturn nil, wrote, false\n289\t\t\t}\n290\t\t}\n291\t\n292\t\t// Normal path: update stored entry with current state.\n293\t\tv.hashes[relPath] = fileEntry{\n294\t\t\thash:           hash,\n295\t\t\ttaskIdentifier: lib.TaskIdentifier(taskID),\n296\t\t\tassignee:       currentFMAssignee,\n297\t\t}\n298\t\tif frontmatter.Status() == \"\" {\n299\t\t\tglog.Errorf(\"skipping %s: invalid frontmatter: status is empty\", relPath)\n300\t\t\tv.metrics.SkippedFilesTotal(metrics.ReasonEmptyStatus).Inc()\n301\t\t\treturn nil, \"\", false\n302\t\t}\n303\t\tif currentFMAssignee == \"\" {\n304\t\t\treturn nil, \"\", false\n305\t\t}\n306\t\tbody := extractBody(content)\n307\t\treturn &lib.Task{\n308\t\t\tTaskIdentifier: lib.TaskIdentifier(taskID),\n309\t\t\tFrontmatter:    frontmatter,\n310\t\t\tContent:        lib.TaskContent(body),\n311\t\t}, \"\", false\n312\t}\n313\t\n314\t// injectAndStore generates a UUID, writes it into the file via ops.writeFile,\n315\t// and records a sentinel hash entry with the file's current assignee.\n316\t// Returns (nil task, writtenRelPath, writeError).\n317\tfunc (v *vaultScanner) injectAndStore(\n318\t\tctx context.Context,\n319\t\tcontent []byte,\n320\t\trelPath string,\n321\t\tcurrentAssignee lib.TaskAssignee,\n322\t) (*lib.Task, string, bool) {\n323\t\tid := uuid.New().String()\n324\t\tnewContent, injectErr := InjectTaskIdentifier(ctx, content, id)\n325\t\tif injectErr != nil {\n326\t\t\tglog.Warningf(\"skipping %s: failed to inject task_identifier: %v\", relPath, injectErr)\n327\t\t\tv.metrics.SkippedFilesTotal(metrics.ReasonInjectTaskIdentifierFailed).Inc()\n328\t\t\treturn nil, \"\", false\n329\t\t}\n330\t\tif writeErr := v.ops.writeFile(ctx, relPath, newContent); writeErr != nil {\n331\t\t\tglog.Warningf(\"failed to write %s: %v\", relPath, writeErr)\n332\t\t\treturn nil, \"\", true\n333\t\t}\n334\t\tv.hashes[relPath] = fileEntry{\n335\t\t\thash:           [32]byte{},\n336\t\t\ttaskIdentifier: lib.TaskIdentifier(id),\n337\t\t\tassignee:       currentAssignee,\n338\t\t}\n339\t\treturn nil, relPath, false\n340\t}\n341\t\n342\t// writeCounterReset rewrites the task file with trigger_count: 0 and retry_count: 0.\n343\t// fmMap is the already-parsed frontmatter map for this file.\n344\t// Returns (relPath, false) on success, (\"\", true) on write error.\n345\tfunc (v *vaultScanner) writeCounterReset(\n346\t\tctx context.Context,\n347\t\trelPath string,\n348\t\tcontent []byte,\n349\t\tfmMap map[string]interface{},\n350\t) (string, bool) {\n351\t\tresetFm := make(map[string]interface{}, len(fmMap))\n352\t\tfor k, val := range fmMap {\n353\t\t\tresetFm[k] = val\n354\t\t}\n355\t\tresetFm[\"trigger_count\"] = 0\n356\t\tresetFm[\"retry_count\"] = 0\n357\t\n358\t\tnewFmYAML, err := yaml.Marshal(resetFm)\n359\t\tif err != nil {\n360\t\t\tglog.Warningf(\"writeCounterReset: marshal failed for %s: %v\", relPath, err)\n361\t\t\treturn \"\", false\n362\t\t}\n363\t\n364\t\tbody := extractBody(content)\n365\t\tnewContent := []byte(\"---\\n\" + string(newFmYAML) + \"---\\n\" + body)\n366\t\n367\t\tif writeErr := v.ops.writeFile(ctx, relPath, newContent); writeErr != nil {\n368\t\t\tglog.Warningf(\"writeCounterReset: write failed for %s: %v\", relPath, writeErr)\n369\t\t\treturn \"\", true\n370\t\t}\n371\t\tglog.V(2).Infof(\"writeCounterReset: reset trigger_count/retry_count for %s\", relPath)\n372\t\treturn relPath, false\n373\t}\n374\t\n375\tfunc (v *vaultScanner) collectDeleted(\n376\t\tctx context.Context,\n377\t\tseen map[string]struct{},\n378\t) ([]lib.TaskIdentifier, error) {\n379\t\tvar deleted []lib.TaskIdentifier\n380\t\tfor relPath, entry := range v.hashes {\n381\t\t\tselect {\n382\t\t\tcase <-ctx.Done():\n383\t\t\t\treturn deleted, errors.Wrap(ctx, ctx.Err(), \"collectDeleted cancelled\")\n384\t\t\tdefault:\n385\t\t\t}\n386\t\t\tif _, ok := seen[relPath]; !ok {\n387\t\t\t\tdeleted = append(deleted, entry.taskIdentifier)\n388\t\t\t\tdelete(v.hashes, relPath)\n389\t\t\t}\n390\t\t}\n391\t\treturn deleted, nil\n392\t}\n393\t"}]},"parent_tool_use_id":"call_function_gndwq2feccxh_1","session_id":"213d66d0-dce3-49f1-a7b2-16c36173f959","uuid":"9adc710b-5949-4fab-9517-d0a383a7cc18","timestamp":"2026-06-27T21:33:33.151Z","subagent_type":"dark-factory:prompt-auditor","task_description":"Audit prompt 1"}
