{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_019f0afd7a937ec2921a5a78","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage main\n6\t\n7\timport (\n8\t\t\"reflect\"\n9\t\t\"testing\"\n10\t)\n11\t\n12\tfunc TestApplicationBuildGitVersionFieldExists(t *testing.T) {\n13\t\ttyp := reflect.TypeOf(application{})\n14\t\tf, ok := typ.FieldByName(\"BuildGitVersion\")\n15\t\tif !ok {\n16\t\t\tt.Fatalf(\"application struct is missing BuildGitVersion field\")\n17\t\t}\n18\t\tif f.Type.Kind() != reflect.String {\n19\t\t\tt.Fatalf(\"BuildGitVersion must be string, got %s\", f.Type.Kind())\n20\t\t}\n21\t\tif got, want := f.Tag.Get(\"env\"), \"BUILD_GIT_VERSION\"; got != want {\n22\t\t\tt.Errorf(\"BuildGitVersion env tag = %q, want %q\", got, want)\n23\t\t}\n24\t\tif got, want := f.Tag.Get(\"arg\"), \"build-git-version\"; got != want {\n25\t\t\tt.Errorf(\"BuildGitVersion arg tag = %q, want %q\", got, want)\n26\t\t}\n27\t\tif got, want := f.Tag.Get(\"default\"), \"dev\"; got != want {\n28\t\t\tt.Errorf(\"BuildGitVersion default tag = %q, want %q\", got, want)\n29\t\t}\n30\t}\n31\t\n32\tfunc TestApplicationBuildGitVersionFieldOrder(t *testing.T) {\n33\t\ttyp := reflect.TypeOf(application{})\n34\t\tversionIdx, commitIdx := -1, -1\n35\t\tfor i := 0; i < typ.NumField(); i++ {\n36\t\t\tswitch typ.Field(i).Name {\n37\t\t\tcase \"BuildGitVersion\":\n38\t\t\t\tversionIdx = i\n39\t\t\tcase \"BuildGitCommit\":\n40\t\t\t\tcommitIdx = i\n41\t\t\t}\n42\t\t}\n43\t\tif versionIdx < 0 || commitIdx < 0 {\n44\t\t\tt.Fatalf(\n45\t\t\t\t\"both BuildGitVersion (%d) and BuildGitCommit (%d) must exist\",\n46\t\t\t\tversionIdx,\n47\t\t\t\tcommitIdx,\n48\t\t\t)\n49\t\t}\n50\t\tif versionIdx >= commitIdx {\n51\t\t\tt.Errorf(\n52\t\t\t\t\"BuildGitVersion (idx %d) must appear before BuildGitCommit (idx %d)\",\n53\t\t\