{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_019f0afd61de7c5191beb6c0","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage scanner\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\n10\t\t. \"github.com/onsi/ginkgo/v2\"\n11\t\t. \"github.com/onsi/gomega\"\n12\t\t\"github.com/prometheus/client_golang/prometheus\"\n13\t\n14\t\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n15\t)\n16\t\n17\tvar _ = Describe(\"injectAndStore\", func() {\n18\t\tcounterValue := func(reason string) float64 {\n19\t\t\tmfs, err := prometheus.DefaultGatherer.Gather()\n20\t\t\tExpect(err).NotTo(HaveOccurred())\n21\t\t\tfor _, mf := range mfs {\n22\t\t\t\tif mf.GetName() != \"agent_controller_vault_scanner_skipped_files_total\" {\n23\t\t\t\t\tcontinue\n24\t\t\t\t}\n25\t\t\t\tfor _, m := range mf.GetMetric() {\n26\t\t\t\t\tfor _, lp := range m.GetLabel() {\n27\t\t\t\t\t\tif lp.GetName() == \"reason\" && lp.GetValue() == reason {\n28\t\t\t\t\t\t\treturn m.GetCounter().GetValue()\n29\t\t\t\t\t\t}\n30\t\t\t\t\t}\n31\t\t\t\t}\n32\t\t\t}\n33\t\t\treturn 0\n34\t\t}\n35\t\n36\t\tIt(\n37\t\t\t\"increments inject_task_identifier_failed counter when InjectTaskIdentifier returns error\",\n38\t\t\tfunc() {\n39\t\t\t\tv := &vaultScanner{\n40\t\t\t\t\tmetrics: metrics.New(),\n41\t\t\t\t\tops: fileOps{\n42\t\t\t\t\t\treadFile: func(_ context.Context, _ string) ([]byte, error) {\n43\t\t\t\t\t\t\treturn nil, nil\n44\t\t\t\t\t\t},\n45\t\t\t\t\t\twriteFile: func(_ context.Context, _ string, _ []byte) error {\n46\t\t\t\t\t\t\treturn nil\n47\t\t\t\t\t\t},\n48\t\t\t\t\t},\n49\t\t\t\t}\n50\t\n51\t\t\t\tinitial := counterValue(metrics.ReasonInjectTaskIdentifierFailed)\n52\t\t\t\tinitialInvalid := counterValue(metrics.ReasonInvalidFrontmatter)\n53\t\t\t\tinitialDupInvalid := counterValue(metrics.ReasonDuplicateFrontmatterInvalid)\n54\t\t\t\tinitialEmptyStatus := counterValue(metrics.ReasonEmptyStatus)\n55\t\t\t\tinitialReadFailed := counterValue(metrics.ReasonReadFailed)\n56\t\n57\t\t\t\t// Content without frontmatter delimiter causes InjectTaskIdentifier to fail\n58\t\t\t\ttask, written, werr := v.injectAndStore(\n59\t\t\t\t\tcontext.Background(),\n60\t\t\t\t\t[]byte(\"no frontmatter at all\"),\n61\t\t\t\t\t\"rel.md\",\n62\t\t\t\t\t\"\",\n63\t\t\t\t)\n64\t\t\t\tExpect(task).To(BeNil())\n65\t\t\t\tExpect(written).To(Equal(\"\"))\n66\t\t\t\tExpect(werr).To(BeFalse())\n67\t\t\t\tExpect(counterValue(metrics.ReasonInjectTaskIdentifierFailed)).To(Equal(initial + 1))\n68\t\n69\t\t\t\t// Other reason labels must not tick (compared to initial values)\n70\t\t\t\tExpect(\n71\t\t\t\t\tcounterValue(metrics.ReasonInvalidFrontmatter),\n72\t\t\t\t).To(BeNumerically(\"==\", initialInvalid))\n73\t\t\t\tExpect(\n74\t\t\t\t\tcounterValue(metrics.ReasonDuplicateFrontmatterInvalid),\n75\t\t\t\t).To(BeNumerically(\"==\", initialDupInvalid))\n76\t\t\t\tExpect(\n77\t\t\t\t\tcounterValue(metrics.ReasonEmptyStatus),\n78\t\t\t\t).To(BeNumerically(\"==\", initialEmptyStatus))\n79\t\t\t\tExpect(\n80\t\t\t\t\tcounterValue(metrics.ReasonReadFailed),\n81\t\t\t\t).To(BeNumerically(\"==\", initialReadFailed))\n82\t\t\t},\n83\t\t)\n84\t})\n85\t"}]},"parent_tool_use_id":"call_function_8wnb4ldxeox3_1","session_id":"213d66d0-dce3-49f1-a7b2-16c36173f959","uuid":"7885e9bd-676c-4b68-862b-7aab9ca7bc00","timestamp":"2026-06-27T21:30:05.859Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_019f0afd61de7c5191beb6b3","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage scanner_test\n6\t\n7\t// NOTE: testGitClient is a hand-written test double rather than a Counterfeiter\n8\t// mock because importing the mocks package would create an import cycle:\n9\t// mocks/ imports scanner for scanner.ScanResult, so scanner cannot import mocks.\n10\t// This is a documented exception to the Counterfeiter-mocks rule.\n11\t\n12\timport (\n13\t\t\"context\"\n14\t\t\"os\"\n15\t\t\"os/exec\"\n16\t\t\"path/filepath\"\n17\t\t\"strings\"\n18\t\t\"time\"\n19\t\n20\t\t\"github.com/bborbe/vault-cli/pkg/domain\"\n21\t\t. \"github.com/onsi/ginkgo/v2\"\n22\t\t. \"github.com/onsi/gomega\"\n23\t\t\"github.com/prometheus/client_golang/prometheus\"\n24\t\t\"gopkg.in/yaml.v3\"\n25\t\n26\t\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n27\t\t\"github.com/bborbe/agent-task-controller/pkg/scanner\"\n28\t)\n29\t\n30\tfunc extractFrontmatterStr(fileContent string) string {\n31\t\tconst pfx = \"---\\n\"\n32\t\tif !strings.HasPrefix(fileContent, pfx) {\n33\t\t\treturn \"\"\n34\t\t}\n35\t\trest := fileContent[len(pfx):]\n36\t\tidx := strings.Index(rest, \"\\n---\")\n37\t\tif idx == -1 {\n38\t\t\treturn \"\"\n39\t\t}\n40\t\treturn rest[:idx]\n41\t}\n42\t\n43\ttype testGitClient struct {\n44\t\tpath          string\n45\t\tpullErr       error\n46\t\tcommitPushErr error\n47\t}\n48\t\n49\tfunc (t *testGitClient) EnsureCloned(_ context.Context) error { return nil }\n50\t\n51\tfunc (t *testGitClient) Pull(_ context.Context) error { return t.pullErr }\n52\t\n53\tfunc (t *testGitClient) Path() string { return t.path }\n54\t\n55\tfunc (t *testGitClient) CommitAndPush(_ context.Context, _ string) error {\n56\t\treturn t.commitPushErr\n57\t}\n58\t\n59\tfunc (t *testGitClient) AtomicWriteAndCommitPush(\n60\t\t_ context.Context,\n61\t\t_ string,\n62\t\t_ []byte,\n63\t\t_ string,\n64\t) error {\n65\t\treturn t.commitPushErr\n66\t}\n67\t\n68\tfunc (t *testGitClient) AtomicReadModifyWriteAndCommitPush(\n69\t\t_ context.Context,\n70\t\t_ string,\n71\t\t_ func([]byte) ([]byte, error),\n72\t\t_ string,\n73\t) error {\n74\t\treturn t.commitPushErr\n75\t}\n76\t\n77\tfunc (t *testGitClient) ListFiles(_ context.Context, _ string) ([]string, error) { return nil, nil }\n78\t\n79\tfunc (t *testGitClient) ReadFile(_ context.Context, _ string) ([]byte, error) { return nil, nil }\n80\t\n81\tfunc (t *testGitClient) WriteFile(_ context.Context, _ string, _ []byte) error { return nil }\n82\t\n83\t// fileOpsTestGitClient is a test double with real file I/O for NewGitRestVaultScanner tests.\n84\ttype fileOpsTestGitClient struct {\n85\t\tpath          string\n86\t\tpullErr       error\n87\t\tcommitPushErr error\n88\t}\n89\t\n90\tfunc (t *fileOpsTestGitClient) EnsureCloned(_ context.Context) error { return nil }\n91\t\n92\tfunc (t *fileOpsTestGitClient) Pull(_ context.Context) error { return t.pullErr }\n93\t\n94\tfunc (t *fileOpsTestGitClient) Path() string { return t.path }\n95\t\n96\tfunc (t *fileOpsTestGitClient) CommitAndPush(_ context.Context, _ string) error {\n97\t\treturn t.commitPushErr\n98\t}\n99\t\n100\tfunc (t *fileOpsTestGitClient) AtomicWriteAndCommitPush(\n101\t\t_ context.Context,\n102\t\t_ string,\n103\t\t_ []byte,\n104\t\t_ string,\n105\t) error {\n106\t\treturn t.commitPushErr\n107\t}\n108\t\n109\tfunc (t *fileOpsTestGitClient) AtomicReadModifyWriteAndCommitPush(\n110\t\t_ context.Context,\n111\t\t_ string,\n112\t\t_ func([]byte) ([]byte, error),\n113\t\t_ string,\n114\t) error {\n115\t\treturn t.commitPushErr\n116\t}\n117\t\n118\tfunc (t *fileOpsTestGitClient) ListFiles(_ context.Context, glob string) ([]string, error) {\n119\t\tmatches, err := filepath.Glob(filepath.Join(t.path, glob))\n120\t\tif err != nil {\n121\t\t\treturn nil, err\n122\t\t}\n123\t\tvar rel []string\n124\t\tfor _, m := range matches {\n125\t\t\tr, _ := filepath.Rel(t.path, m)\n126\t\t\trel = append(rel, r)\n127\t\t}\n128\t\treturn rel, nil\n129\t}\n130\t\n131\tfunc (t *fileOpsTestGitClient) ReadFile(_ context.Context, relPath string) ([]byte, error) {\n132\t\treturn os.ReadFile(filepath.Join(t.path, relPath)) // #nosec G304 -- test-only path\n133\t}\n134\t\n135\tfunc (t *fileOpsTestGitClient) WriteFile(_ context.Context, relPath string, content []byte) error {\n136\t\treturn os.WriteFile(filepath.Join(t.path, relPath), content, 0600)\n137\t}\n138\t\n139\t// failingReadFileOpsGitClient shadows ReadFile to always fail while keeping\n140\t// the real ListFiles implementation from fileOpsTestGitClient.\n141\ttype failingReadFileOpsGitClient struct {\n142\t\t*fileOpsTestGitClient\n143\t}\n144\t\n145\tfunc (f *failingReadFileOpsGitClient) ReadFile(_ context.Context, _ string) ([]byte, error) {\n146\t\treturn nil, os.ErrNotExist\n147\t}\n148\t\n149\tfunc mustInitGitRepo(dir string) {\n150\t\tcmds := [][]string{\n151\t\t\t{\"git\", \"-C\", dir, \"init\"},\n152\t\t\t{\"git\", \"-C\", dir, \"config\", \"user.email\", \"test@test.com\"},\n153\t\t\t{\"git\", \"-C\", dir, \"config\", \"user.name\", \"Test\"},\n154\t\t\t{\"git\", \"-C\", dir, \"commit\", \"--allow-empty\", \"-m\", \"init\"},\n155\t\t}\n156\t\tfor _, args := range cmds {\n157\t\t\t// #nosec G204 -- test helper: commands are hardcoded test setup git invocations\n158\t\t\tout, err := exec.Command(args[0], args[1:]...).CombinedOutput()\n159\t\t\tExpect(err).To(BeNil(), \"cmd %v failed: %s\", args, string(out))\n160\t\t}\n161\t}\n162\t\n163\tvar _ = Describe(\"VaultScanner\", func() {\n164\t\tvar (\n165\t\t\tctx     context.Context\n166\t\t\ts       scanner.VaultScanner\n167\t\t\ttmpDir  string\n168\t\t\ttaskDir string\n169\t\t\tfakeGit *testGitClient\n170\t\t\tresults chan scanner.ScanResult\n171\t\t)\n172\t\n173\t\tBeforeEach(func() {\n174\t\t\tctx = context.Background()\n175\t\t\tvar err error\n176\t\t\ttmpDir, err = os.MkdirTemp(\"\", \"scanner-test-*\")\n177\t\t\tExpect(err).To(BeNil())\n178\t\t\ttaskDir = \"24 Tasks\"\n179\t\t\tExpect(os.MkdirAll(filepath.Join(tmpDir, taskDir), 0750)).To(Succeed())\n180\t\t\tmustInitGitRepo(tmpDir)\n181\t\n182\t\t\tfakeGit = &testGitClient{path: tmpDir}\n183\t\t\tresults = make(chan scanner.ScanResult, 1)\n184\t\n185\t\t\ts = scanner.NewVaultScanner(\n186\t\t\t\tfakeGit,\n187\t\t\t\ttaskDir,\n188\t\t\t\ttime.Second,\n189\t\t\t\tmake(chan struct{}),\n190\t\t\t\tmetrics.New(),\n191\t\t\t)\n192\t\t})\n193\t\n194\t\tAfterEach(func() {\n195\t\t\tExpect(os.RemoveAll(tmpDir)).To(Succeed())\n196\t\t})\n197\t\n198\t\tDescribe(\"assignee transition → counter reset\", func() {\n199\t\t\tIt(\n200\t\t\t\t\"resets trigger_count and retry_count when assignee transitions from empty to named\",\n201\t\t\t\tfunc() {\n202\t\t\t\t\ttaskID := \"aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\"\n203\t\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"parked.md\")\n204\t\t\t\t\tinitialContent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: \\ntrigger_count: 3\\nretry_count: 2\\n---\\n# body\\n\"\n205\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(initialContent), 0600)).To(Succeed())\n206\t\n207\t\t\t\t\t// First scan: parked (assignee empty), no task published, no reset\n208\t\t\t\t\ts.RunCycle(ctx, results)\n209\t\t\t\t\tvar r1 scanner.ScanResult\n210\t\t\t\t\tExpect(results).To(Receive(&r1))\n211\t\t\t\t\tExpect(r1.Changed).To(BeEmpty())\n212\t\n213\t\t\t\t\t// Operator re-delegates: set assignee to claude\n214\t\t\t\t\tdelegatedContent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: claude\\ntrigger_count: 3\\nretry_count: 2\\n---\\n# body\\n\"\n215\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(delegatedContent), 0600)).To(Succeed())\n216\t\n217\t\t\t\t\t// Second scan: detects transition, writes reset, no task published yet (zero-hash sentinel)\n218\t\t\t\t\ts.RunCycle(ctx, results)\n219\t\t\t\t\tvar r2 scanner.ScanResult\n220\t\t\t\t\tExpect(results).To(Receive(&r2))\n221\t\t\t\t\tExpect(r2.Changed).To(BeEmpty())\n222\t\n223\t\t\t\t\t// Verify the file was rewritten with reset counters\n224\t\t\t\t\twritten, _ := os.ReadFile(absPath) // #nosec G304 -- test-only path\n225\t\t\t\t\tvar fm map[string]interface{}\n226\t\t\t\t\tExpect(\n227\t\t\t\t\t\tyaml.Unmarshal([]byte(extractFrontmatterStr(string(written))), &fm),\n228\t\t\t\t\t).To(Succeed())\n229\t\t\t\t\tExpect(fm[\"trigger_count\"]).To(BeNumerically(\"==\", 0))\n230\t\t\t\t\tExpect(fm[\"retry_count\"]).To(BeNumerically(\"==\", 0))\n231\t\t\t\t\tExpect(fm[\"assignee\"]).To(Equal(\"claude\"))\n232\t\n233\t\t\t\t\t// Third scan: reads reset file, publishes task with fresh counters\n234\t\t\t\t\ts.RunCycle(ctx, results)\n235\t\t\t\t\tvar r3 scanner.ScanResult\n236\t\t\t\t\tExpect(results).To(Receive(&r3))\n237\t\t\t\t\tExpect(r3.Changed).To(HaveLen(1))\n238\t\t\t\t\tExpect(string(r3.Changed[0].Frontmatter.Assignee())).To(Equal(\"claude\"))\n239\t\t\t\t\tExpect(r3.Changed[0].Frontmatter.TriggerCount()).To(Equal(0))\n240\t\t\t\t\tExpect(r3.Changed[0].Frontmatter.RetryCount()).To(Equal(0))\n241\t\t\t\t},\n242\t\t\t)\n243\t\n244\t\t\tIt(\n245\t\t\t\t\"does not reset counters when assignee changes from one name to another (named → named)\",\n246\t\t\t\tfunc() {\n247\t\t\t\t\ttaskID := \"bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb\"\n248\t\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"named-named.md\")\n249\t\t\t\t\tinitialContent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: claudeA\\ntrigger_count: 2\\nretry_count: 1\\n---\\n# body\\n\"\n250\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(initialContent), 0600)).To(Succeed())\n251\t\n252\t\t\t\t\t// First scan: task published with claudeA\n253\t\t\t\t\ts.RunCycle(ctx, results)\n254\t\t\t\t\tExpect(results).To(Receive())\n255\t\n256\t\t\t\t\t// Operator changes to claudeB\n257\t\t\t\t\tchangedContent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: claudeB\\ntrigger_count: 2\\nretry_count: 1\\n---\\n# body\\n\"\n258\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(changedContent), 0600)).To(Succeed())\n259\t\n260\t\t\t\t\t// Second scan: named → named, no reset, task published with new assignee\n261\t\t\t\t\ts.RunCycle(ctx, results)\n262\t\t\t\t\tvar r2 scanner.ScanResult\n263\t\t\t\t\tExpect(results).To(Receive(&r2))\n264\t\t\t\t\tExpect(r2.Changed).To(HaveLen(1))\n265\t\n266\t\t\t\t\t// Counters must NOT have been reset\n267\t\t\t\t\twritten, _ := os.ReadFile(absPath) // #nosec G304 -- test-only path\n268\t\t\t\t\tvar fm map[string]interface{}\n269\t\t\t\t\tExpect(\n270\t\t\t\t\t\tyaml.Unmarshal([]byte(extractFrontmatterStr(string(written))), &fm),\n271\t\t\t\t\t).To(Succeed())\n272\t\t\t\t\tExpect(fm[\"trigger_count\"]).To(BeNumerically(\"==\", 2))\n273\t\t\t\t\tExpect(fm[\"retry_count\"]).To(BeNumerically(\"==\", 1))\n274\t\t\t\t},\n275\t\t\t)\n276\t\n277\t\t\tIt(\n278\t\t\t\t\"does not reset counters when assignee is cleared from named to empty (named → empty)\",\n279\t\t\t\tfunc() {\n280\t\t\t\t\ttaskID := \"cccccccc-cccc-4ccc-8ccc-cccccccccccc\"\n281\t\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"named-empty.md\")\n282\t\t\t\t\tinitialContent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: claude\\ntrigger_count: 2\\nretry_count: 1\\n---\\n# body\\n\"\n283\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(initialContent), 0600)).To(Succeed())\n284\t\n285\t\t\t\t\t// First scan: task published with claude\n286\t\t\t\t\ts.RunCycle(ctx, results)\n287\t\t\t\t\tExpect(results).To(Receive())\n288\t\n289\t\t\t\t\t// Operator clears assignee\n290\t\t\t\t\tclearedContent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: \\ntrigger_count: 2\\nretry_count: 1\\n---\\n# body\\n\"\n291\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(clearedContent), 0600)).To(Succeed())\n292\t\n293\t\t\t\t\t// Second scan: named → empty, no reset, task skipped (empty assignee)\n294\t\t\t\t\ts.RunCycle(ctx, results)\n295\t\t\t\t\tvar r2 scanner.ScanResult\n296\t\t\t\t\tExpect(results).To(Receive(&r2))\n297\t\t\t\t\tExpect(r2.Changed).To(BeEmpty())\n298\t\n299\t\t\t\t\t// File counters must NOT have changed\n300\t\t\t\t\twritten, _ := os.ReadFile(absPath) // #nosec G304 -- test-only path\n301\t\t\t\t\tvar fm map[string]interface{}\n302\t\t\t\t\tExpect(\n303\t\t\t\t\t\tyaml.Unmarshal([]byte(extractFrontmatterStr(string(written))), &fm),\n304\t\t\t\t\t).To(Succeed())\n305\t\t\t\t\tExpect(fm[\"trigger_count\"]).To(BeNumerically(\"==\", 2))\n306\t\t\t\t\tExpect(fm[\"retry_count\"]).To(BeNumerically(\"==\", 1))\n307\t\t\t\t},\n308\t\t\t)\n309\t\n310\t\t\tIt(\n311\t\t\t\t\"emits counter reset exactly once even if the same empty→named transition is observed twice in consecutive scans\",\n312\t\t\t\tfunc() {\n313\t\t\t\t\ttaskID := \"dddddddd-dddd-4ddd-8ddd-dddddddddddd\"\n314\t\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"idempotent.md\")\n315\t\t\t\t\tinitialContent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: \\ntrigger_count: 3\\nretry_count: 2\\n---\\n# body\\n\"\n316\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(initialContent), 0600)).To(Succeed())\n317\t\n318\t\t\t\t\t// First scan: parked, no task\n319\t\t\t\t\ts.RunCycle(ctx, results)\n320\t\t\t\t\tExpect(results).To(Receive())\n321\t\n322\t\t\t\t\t// Operator re-delegates\n323\t\t\t\t\tdelegatedContent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: claude\\ntrigger_count: 3\\nretry_count: 2\\n---\\n# body\\n\"\n324\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(delegatedContent), 0600)).To(Succeed())\n325\t\n326\t\t\t\t\t// Second scan: detects transition, writes reset once\n327\t\t\t\t\ts.RunCycle(ctx, results)\n328\t\t\t\t\tExpect(results).To(Receive())\n329\t\n330\t\t\t\t\t// Capture file state after first reset\n331\t\t\t\t\tafterFirstReset, _ := os.ReadFile(absPath) // #nosec G304 -- test-only path\n332\t\t\t\t\tvar fm1 map[string]interface{}\n333\t\t\t\t\tExpect(\n334\t\t\t\t\t\tyaml.Unmarshal([]byte(extractFrontmatterStr(string(afterFirstReset))), &fm1),\n335\t\t\t\t\t).To(Succeed())\n336\t\t\t\t\tExpect(fm1[\"trigger_count\"]).To(BeNumerically(\"==\", 0))\n337\t\t\t\t\tExpect(fm1[\"retry_count\"]).To(BeNumerically(\"==\", 0))\n338\t\n339\t\t\t\t\t// Third scan: zero-hash sentinel forces re-process, but prevEntry.assignee = \"claude\"\n340\t\t\t\t\t// → no second transition detected → no second reset\n341\t\t\t\t\ts.RunCycle(ctx, results)\n342\t\t\t\t\tExpect(results).To(Receive())\n343\t\n344\t\t\t\t\t// File content must be byte-identical to post-first-reset (no second write)\n345\t\t\t\t\tafterSecondScan, _ := os.ReadFile(absPath) // #nosec G304 -- test-only path\n346\t\t\t\t\tExpect(afterSecondScan).To(Equal(afterFirstReset))\n347\t\n348\t\t\t\t\tvar fm2 map[string]interface{}\n349\t\t\t\t\tExpect(\n350\t\t\t\t\t\tyaml.Unmarshal([]byte(extractFrontmatterStr(string(afterSecondScan))), &fm2),\n351\t\t\t\t\t).To(Succeed())\n352\t\t\t\t\tExpect(fm2[\"trigger_count\"]).To(BeNumerically(\"==\", 0))\n353\t\t\t\t\tExpect(fm2[\"retry_count\"]).To(BeNumerically(\"==\", 0))\n354\t\t\t\t},\n355\t\t\t)\n356\t\n357\t\t\tIt(\n358\t\t\t\t\"does not reset counters on first scan of a file that already has a non-empty assignee\",\n359\t\t\t\tfunc() {\n360\t\t\t\t\ttaskID := \"eeeeeeee-eeee-4eee-8eee-eeeeeeeeeeee\"\n361\t\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"already-assigned.md\")\n362\t\t\t\t\tcontent := \"---\\ntask_identifier: \" + taskID + \"\\nstatus: in_progress\\nphase: ai_review\\nassignee: claude\\ntrigger_count: 5\\nretry_count: 4\\n---\\n# body\\n\"\n363\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n364\t\n365\t\t\t\t\t// First scan ever — prevEntry.taskIdentifier == \"\" (zero value)\n366\t\t\t\t\ts.RunCycle(ctx, results)\n367\t\t\t\t\tvar r1 scanner.ScanResult\n368\t\t\t\t\tExpect(results).To(Receive(&r1))\n369\t\t\t\t\tExpect(r1.Changed).To(HaveLen(1))\n370\t\n371\t\t\t\t\t// Counters must NOT have been reset\n372\t\t\t\t\twritten, _ := os.ReadFile(absPath) // #nosec G304 -- test-only path\n373\t\t\t\t\tvar fm map[string]interface{}\n374\t\t\t\t\tExpect(\n375\t\t\t\t\t\tyaml.Unmarshal([]byte(extractFrontmatterStr(string(written))), &fm),\n376\t\t\t\t\t).To(Succeed())\n377\t\t\t\t\tExpect(fm[\"trigger_count\"]).To(BeNumerically(\"==\", 5))\n378\t\t\t\t\tExpect(fm[\"retry_count\"]).To(BeNumerically(\"==\", 4))\n379\t\t\t\t},\n380\t\t\t)\n381\t\t})\n382\t\n383\t\tDescribe(\"processFile edge cases\", func() {\n384\t\t\tIt(\"processes file with duplicate task_identifier (last wins)\", func() {\n385\t\t\t\tcontent := \"---\\ntask_identifier: 11111111-1111-4111-8111-111111111121\\nstatus: todo\\nassignee: claude\\ntask_identifier: 22222222-2222-4222-8222-222222222221\\n---\\n# Dup task\"\n386\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"dup-key.md\")\n387\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n388\t\n389\t\t\t\ts.RunCycle(ctx, results)\n390\t\t\t\tvar result scanner.ScanResult\n391\t\t\t\tExpect(results).To(Receive(&result))\n392\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n393\t\t\t\tExpect(\n394\t\t\t\t\tstring(result.Changed[0].TaskIdentifier),\n395\t\t\t\t).To(Equal(\"22222222-2222-4222-8222-222222222221\"))\n396\t\t\t})\n397\t\n398\t\t\tIt(\"passes through file with non-empty unknown status\", func() {\n399\t\t\t\tcontent := \"---\\ntask_identifier: 55555555-5555-4555-8555-555555555555\\nstatus: definitely_invalid_status\\nassignee: claude\\n---\\n\"\n400\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"bad-status.md\")\n401\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n402\t\n403\t\t\t\ts.RunCycle(ctx, results)\n404\t\t\t\tvar result scanner.ScanResult\n405\t\t\t\tExpect(results).To(Receive(&result))\n406\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n407\t\t\t\tExpect(\n408\t\t\t\t\tstring(result.Changed[0].Frontmatter.Status()),\n409\t\t\t\t).To(Equal(\"definitely_invalid_status\"))\n410\t\t\t})\n411\t\n412\t\t\tIt(\"handles CRLF line endings in full cycle\", func() {\n413\t\t\t\tcontent := \"---\\r\\ntask_identifier: 66666666-6666-4666-8666-666666666666\\r\\nstatus: todo\\r\\nassignee: claude\\r\\n---\\r\\n# Task\"\n414\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"crlf-cycle.md\")\n415\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n416\t\n417\t\t\t\ts.RunCycle(ctx, results)\n418\t\t\t\tvar result scanner.ScanResult\n419\t\t\t\tExpect(results).To(Receive(&result))\n420\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n421\t\t\t\tExpect(string(result.Changed[0].Frontmatter.Assignee())).To(Equal(\"claude\"))\n422\t\t\t})\n423\t\n424\t\t\tIt(\n425\t\t\t\t\"skips file when YAML is invalid and fails DeduplicateFrontmatter first unmarshal\",\n426\t\t\t\tfunc() {\n427\t\t\t\t\t// Content with a bare '[' character is invalid YAML (unclosed flow sequence).\n428\t\t\t\t\t// DeduplicateFrontmatter returns an error, causing processFile to skip the file.\n429\t\t\t\t\t// RunCycle always sends an empty ScanResult to the channel, so we verify\n430\t\t\t\t\t// that Changed is empty (file was not published).\n431\t\t\t\t\tcontent := \"---\\ntask_identifier: aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\\nstatus: todo\\nassignee: [invalid\\n---\\n# Invalid\"\n432\t\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"invalid-yaml-frontmatter.md\")\n433\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n434\t\n435\t\t\t\t\ts.RunCycle(ctx, results)\n436\t\t\t\t\tvar result scanner.ScanResult\n437\t\t\t\t\tExpect(results).To(Receive(&result))\n438\t\t\t\t\tExpect(result.Changed).To(BeEmpty())\n439\t\t\t\t},\n440\t\t\t)\n441\t\t})\n442\t\n443\t\tDescribe(\"DeduplicateFrontmatter\", func() {\n444\t\t\tIt(\"returns original YAML unchanged when no duplicates\", func() {\n445\t\t\t\tinput := \"task_identifier: abc-123\\nstatus: todo\\nassignee: claude\\n\"\n446\t\t\t\tout, hasDup, err := scanner.DeduplicateFrontmatter(ctx, input)\n447\t\t\t\tExpect(err).To(BeNil())\n448\t\t\t\tExpect(hasDup).To(BeFalse())\n449\t\t\t\tExpect(out).To(Equal(input))\n450\t\t\t})\n451\t\n452\t\t\tIt(\"deduplicates a single repeated key, last value wins\", func() {\n453\t\t\t\tinput := \"task_identifier: first\\nstatus: next\\ntask_identifier: second\\n\"\n454\t\t\t\tout, hasDup, err := scanner.DeduplicateFrontmatter(ctx, input)\n455\t\t\t\tExpect(err).To(BeNil())\n456\t\t\t\tExpect(hasDup).To(BeTrue())\n457\t\t\t\tvar result map[string]interface{}\n458\t\t\t\tExpect(yaml.Unmarshal([]byte(out), &result)).To(Succeed())\n459\t\t\t\tExpect(result[\"task_identifier\"]).To(Equal(\"second\"))\n460\t\t\t\tExpect(result[\"status\"]).To(Equal(\"next\"))\n461\t\t\t})\n462\t\n463\t\t\tIt(\"deduplicates multiple repeated keys, last value wins each\", func() {\n464\t\t\t\tinput := \"task_identifier: first\\nstatus: todo\\ntask_identifier: second\\nstatus: in_progress\\n\"\n465\t\t\t\tout, hasDup, err := scanner.DeduplicateFrontmatter(ctx, input)\n466\t\t\t\tExpect(err).To(BeNil())\n467\t\t\t\tExpect(hasDup).To(BeTrue())\n468\t\t\t\tvar result map[string]interface{}\n469\t\t\t\tExpect(yaml.Unmarshal([]byte(out), &result)).To(Succeed())\n470\t\t\t\tExpect(result[\"task_identifier\"]).To(Equal(\"second\"))\n471\t\t\t\tExpect(result[\"status\"]).To(Equal(\"in_progress\"))\n472\t\t\t})\n473\t\t})\n474\t\n475\t\tDescribe(\"InjectTaskIdentifier\", func() {\n476\t\t\tIt(\"injects task_identifier with LF line endings\", func() {\n477\t\t\t\tinput := []byte(\"---\\nstatus: todo\\n---\\n\")\n478\t\t\t\tresult, err := scanner.InjectTaskIdentifier(context.Background(), input, \"test-id\")\n479\t\t\t\tExpect(err).To(BeNil())\n480\t\t\t\tExpect(string(result)).To(Equal(\"---\\ntask_identifier: test-id\\nstatus: todo\\n---\\n\"))\n481\t\t\t})\n482\t\n483\t\t\tIt(\"injects task_identifier with CRLF line endings\", func() {\n484\t\t\t\tinput := []byte(\"---\\r\\nstatus: todo\\r\\n---\\r\\n\")\n485\t\t\t\tresult, err := scanner.InjectTaskIdentifier(context.Background(), input, \"test-id\")\n486\t\t\t\tExpect(err).To(BeNil())\n487\t\t\t\tExpect(\n488\t\t\t\t\tstring(result),\n489\t\t\t\t).To(Equal(\"---\\r\\ntask_identifier: test-id\\r\\nstatus: todo\\r\\n---\\r\\n\"))\n490\t\t\t})\n491\t\n492\t\t\tIt(\"returns error when content does not start with frontmatter delimiter\", func() {\n493\t\t\t\tinput := []byte(\"no frontmatter\")\n494\t\t\t\tresult, err := scanner.InjectTaskIdentifier(context.Background(), input, \"test-id\")\n495\t\t\t\tExpect(err).NotTo(BeNil())\n496\t\t\t\tExpect(result).To(BeNil())\n497\t\t\t})\n498\t\t})\n499\t\n500\t\tDescribe(\"NewVaultScanner\", func() {\n501\t\t\tIt(\"returns a non-nil VaultScanner\", func() {\n502\t\t\t\tvs := scanner.NewVaultScanner(fakeGit, taskDir, time.Hour, nil, metrics.New())\n503\t\t\t\tExpect(vs).NotTo(BeNil())\n504\t\t\t})\n505\t\t})\n506\t\n507\t\tDescribe(\"NewGitRestVaultScanner\", func() {\n508\t\t\tIt(\"uses fileOps (ListFiles/ReadFile/WriteFile) through the fileOps interface\", func() {\n509\t\t\t\t// fileOpsTestGitClient provides real ListFiles/ReadFile/WriteFile implementations\n510\t\t\t\tgitClient := &fileOpsTestGitClient{path: tmpDir}\n511\t\t\t\tvs := scanner.NewGitRestVaultScanner(gitClient, taskDir, time.Hour, nil, metrics.New())\n512\t\t\t\tExpect(vs).NotTo(BeNil())\n513\t\n514\t\t\t\t// Write a task file and run a cycle to exercise ListFiles/ReadFile/WriteFile\n515\t\t\t\tcontent := \"---\\ntask_identifier: aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\\nstatus: todo\\nassignee: claude\\n---\\n# Test\"\n516\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"gitrest-cycle.md\")\n517\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n518\t\n519\t\t\t\tresultsCh := make(chan scanner.ScanResult, 1)\n520\t\t\t\tvs.RunCycle(ctx, resultsCh)\n521\t\n522\t\t\t\tvar result scanner.ScanResult\n523\t\t\t\tExpect(resultsCh).To(Receive(&result))\n524\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n525\t\t\t\tExpect(string(result.Changed[0].Frontmatter.Assignee())).To(Equal(\"claude\"))\n526\t\t\t})\n527\t\t})\n528\t\n529\t\tDescribe(\"Run\", func() {\n530\t\t\tIt(\"returns nil when context is cancelled\", func() {\n531\t\t\t\tvs := scanner.NewVaultScanner(fakeGit, taskDir, time.Hour, nil, metrics.New())\n532\t\t\t\trunCtx, cancel := context.WithCancel(ctx)\n533\t\t\t\tdone := make(chan error, 1)\n534\t\t\t\tgo func() {\n535\t\t\t\t\tdone <- vs.Run(runCtx, make(chan scanner.ScanResult, 1))\n536\t\t\t\t}()\n537\t\t\t\tcancel()\n538\t\t\t\tEventually(done, 200*time.Millisecond).Should(Receive(BeNil()))\n539\t\t\t})\n540\t\n541\t\t\tIt(\"runs cycle when trigger fires\", func() {\n542\t\t\t\tcontent := \"---\\ntask_identifier: 44444444-4444-4444-8444-444444444444\\nstatus: todo\\nassignee: claude\\n---\\n# Triggered task\"\n543\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"trigger-task.md\")\n544\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n545\t\n546\t\t\t\ttrigger := make(chan struct{}, 1)\n547\t\t\t\tvs := scanner.NewVaultScanner(fakeGit, taskDir, time.Hour, trigger, metrics.New())\n548\t\t\t\tscanResults := make(chan scanner.ScanResult, 1)\n549\t\t\t\trunCtx, cancel := context.WithCancel(ctx)\n550\t\t\t\tdefer cancel()\n551\t\n552\t\t\t\tdone := make(chan error, 1)\n553\t\t\t\tgo func() {\n554\t\t\t\t\tdone <- vs.Run(runCtx, scanResults)\n555\t\t\t\t}()\n556\t\n557\t\t\t\ttrigger <- struct{}{}\n558\t\n559\t\t\t\tvar result scanner.ScanResult\n560\t\t\t\tEventually(scanResults, time.Second).Should(Receive(&result))\n561\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n562\t\t\t\tExpect(\n563\t\t\t\t\tstring(result.Changed[0].TaskIdentifier),\n564\t\t\t\t).To(Equal(\"44444444-4444-4444-8444-444444444444\"))\n565\t\n566\t\t\t\tcancel()\n567\t\t\t\tEventually(done, 200*time.Millisecond).Should(Receive(BeNil()))\n568\t\t\t})\n569\t\t})\n570\t\n571\t\tDescribe(\"runCycle\", func() {\n572\t\t\tIt(\"new file appears in Changed\", func() {\n573\t\t\t\tcontent := \"---\\ntask_identifier: 11111111-1111-4111-8111-111111111111\\nstatus: todo\\nassignee: claude\\n---\\n# New task\"\n574\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"new-task.md\")\n575\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n576\t\n577\t\t\t\ts.RunCycle(ctx, results)\n578\t\n579\t\t\t\tvar result scanner.ScanResult\n580\t\t\t\tExpect(results).To(Receive(&result))\n581\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n582\t\t\t\tExpect(string(result.Changed[0].Frontmatter.Assignee())).To(Equal(\"claude\"))\n583\t\t\t})\n584\t\n585\t\t\tIt(\"unchanged file is not in Changed on second cycle\", func() {\n586\t\t\t\tcontent := \"---\\ntask_identifier: 11111111-1111-4111-8111-111111111112\\nstatus: todo\\nassignee: claude\\n---\\n# Stable task\"\n587\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"stable-task.md\")\n588\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n589\t\n590\t\t\t\ts.RunCycle(ctx, results)\n591\t\t\t\tvar first scanner.ScanResult\n592\t\t\t\tExpect(results).To(Receive(&first))\n593\t\t\t\tExpect(first.Changed).To(HaveLen(1))\n594\t\n595\t\t\t\ts.RunCycle(ctx, results)\n596\t\t\t\tvar second scanner.ScanResult\n597\t\t\t\tExpect(results).To(Receive(&second))\n598\t\t\t\tExpect(second.Changed).To(BeEmpty())\n599\t\t\t})\n600\t\n601\t\t\tIt(\"modified file appears in Changed on next cycle\", func() {\n602\t\t\t\tcontent := \"---\\ntask_identifier: 22222222-2222-4222-8222-222222222222\\nstatus: todo\\nassignee: claude\\n---\\n# Original\"\n603\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"modified-task.md\")\n604\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n605\t\n606\t\t\t\ts.RunCycle(ctx, results)\n607\t\t\t\tExpect(results).To(Receive())\n608\t\n609\t\t\t\tupdated := \"---\\ntask_identifier: 22222222-2222-4222-8222-222222222222\\nstatus: in_progress\\nassignee: claude\\n---\\n# Updated\"\n610\t\t\t\tExpect(os.WriteFile(absPath, []byte(updated), 0600)).To(Succeed())\n611\t\n612\t\t\t\ts.RunCycle(ctx, results)\n613\t\t\t\tvar result scanner.ScanResult\n614\t\t\t\tExpect(results).To(Receive(&result))\n615\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n616\t\t\t\tExpect(string(result.Changed[0].Frontmatter.Status())).To(Equal(\"in_progress\"))\n617\t\t\t})\n618\t\n619\t\t\tIt(\"drops result when channel is already full\", func() {\n620\t\t\t\t// Pre-fill the results channel (capacity 1)\n621\t\t\t\tresults <- scanner.ScanResult{}\n622\t\n623\t\t\t\tcontent := \"---\\ntask_identifier: 11111111-1111-4111-8111-111111111113\\nstatus: todo\\nassignee: claude\\n---\\n# Task\"\n624\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"drop-task.md\")\n625\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n626\t\n627\t\t\t\t// runCycle should not block even though channel is full\n628\t\t\t\ts.RunCycle(ctx, results)\n629\t\t\t\t// drain the pre-filled result (not the one we just tried to send)\n630\t\t\t\tExpect(results).To(Receive())\n631\t\t\t})\n632\t\n633\t\t\tIt(\"skips cycle when git pull fails\", func() {\n634\t\t\t\tfakeGit.pullErr = context.DeadlineExceeded\n635\t\n636\t\t\t\tcontent := \"---\\ntask_identifier: 11111111-1111-4111-8111-111111111114\\nstatus: todo\\nassignee: claude\\n---\\n# Task\"\n637\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"pull-fail.md\")\n638\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n639\t\n640\t\t\t\ts.RunCycle(ctx, results)\n641\t\t\t\tConsistently(results, 50*time.Millisecond).ShouldNot(Receive())\n642\t\t\t})\n643\t\n644\t\t\tIt(\"deleted file appears in Deleted on next cycle\", func() {\n645\t\t\t\tcontent := \"---\\ntask_identifier: 33333333-3333-4333-8333-333333333333\\nstatus: todo\\nassignee: claude\\n---\\n# Task\"\n646\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"deleted-task.md\")\n647\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n648\t\n649\t\t\t\ts.RunCycle(ctx, results)\n650\t\t\t\tExpect(results).To(Receive())\n651\t\n652\t\t\t\tExpect(os.Remove(absPath)).To(Succeed())\n653\t\n654\t\t\t\ts.RunCycle(ctx, results)\n655\t\t\t\tvar result scanner.ScanResult\n656\t\t\t\tExpect(results).To(Receive(&result))\n657\t\t\t\tExpect(result.Deleted).To(HaveLen(1))\n658\t\t\t\tExpect(string(result.Deleted[0])).To(Equal(\"33333333-3333-4333-8333-333333333333\"))\n659\t\t\t})\n660\t\n661\t\t\tIt(\"UUID injected when task_identifier absent\", func() {\n662\t\t\t\tcontent := \"---\\nstatus: todo\\nassignee: claude\\n---\\n# Task without UUID\"\n663\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"no-uuid-task.md\")\n664\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n665\t\n666\t\t\t\ts.RunCycle(ctx, results)\n667\t\n668\t\t\t\t// Not published this cycle (write-back happened)\n669\t\t\t\tvar result scanner.ScanResult\n670\t\t\t\tExpect(results).To(Receive(&result))\n671\t\t\t\tExpect(result.Changed).To(BeEmpty())\n672\t\n673\t\t\t\t// File on disk now contains task_identifier\n674\t\t\t\twritten, err := os.ReadFile(absPath) // #nosec G304 -- test-only path\n675\t\t\t\tExpect(err).To(BeNil())\n676\t\t\t\tExpect(string(written)).To(ContainSubstring(\"task_identifier:\"))\n677\t\t\t})\n678\t\n679\t\t\tIt(\"task published on second cycle after injection\", func() {\n680\t\t\t\tcontent := \"---\\nstatus: todo\\nassignee: claude\\n---\\n# Task without UUID\"\n681\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"no-uuid-task2.md\")\n682\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n683\t\n684\t\t\t\t// First cycle: injects UUID, does not publish\n685\t\t\t\ts.RunCycle(ctx, results)\n686\t\t\t\tvar first scanner.ScanResult\n687\t\t\t\tExpect(results).To(Receive(&first))\n688\t\t\t\tExpect(first.Changed).To(BeEmpty())\n689\t\n690\t\t\t\t// Second cycle: publishes with UUID\n691\t\t\t\ts.RunCycle(ctx, results)\n692\t\t\t\tvar second scanner.ScanResult\n693\t\t\t\tExpect(results).To(Receive(&second))\n694\t\t\t\tExpect(second.Changed).To(HaveLen(1))\n695\t\t\t\tExpect(\n696\t\t\t\t\tstring(second.Changed[0].TaskIdentifier),\n697\t\t\t\t).To(MatchRegexp(`^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$`))\n698\t\t\t})\n699\t\n700\t\t\tIt(\"non-UUID task_identifier is replaced with generated UUID\", func() {\n701\t\t\t\tcontent := \"---\\ntask_identifier: my-custom-id\\nstatus: todo\\nassignee: claude\\n---\\n# Task with non-UUID id\"\n702\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"non-uuid-task.md\")\n703\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n704\t\n705\t\t\t\t// First cycle: replaces non-UUID id, writes file, no task published\n706\t\t\t\ts.RunCycle(ctx, results)\n707\t\t\t\tvar first scanner.ScanResult\n708\t\t\t\tExpect(results).To(Receive(&first))\n709\t\t\t\tExpect(first.Changed).To(BeEmpty())\n710\t\n711\t\t\t\t// File on disk now contains a valid UUID\n712\t\t\t\twritten, err := os.ReadFile(absPath) // #nosec G304 -- test-only path\n713\t\t\t\tExpect(err).To(BeNil())\n714\t\t\t\tExpect(string(written)).To(ContainSubstring(\"task_identifier:\"))\n715\t\t\t\tExpect(string(written)).NotTo(ContainSubstring(\"my-custom-id\"))\n716\t\n717\t\t\t\t// Second cycle: publishes with generated UUID\n718\t\t\t\ts.RunCycle(ctx, results)\n719\t\t\t\tvar second scanner.ScanResult\n720\t\t\t\tExpect(results).To(Receive(&second))\n721\t\t\t\tExpect(second.Changed).To(HaveLen(1))\n722\t\t\t\tExpect(\n723\t\t\t\t\tstring(second.Changed[0].TaskIdentifier),\n724\t\t\t\t).To(MatchRegexp(`^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$`))\n725\t\t\t})\n726\t\n727\t\t\tIt(\"duplicate task_identifier across files is replaced with fresh UUID\", func() {\n728\t\t\t\tsharedUUID := \"77777777-7777-4777-8777-777777777777\"\n729\t\t\t\tcontent1 := \"---\\ntask_identifier: \" + sharedUUID + \"\\nstatus: todo\\nassignee: claude\\n---\\n# First file\"\n730\t\t\t\tcontent2 := \"---\\ntask_identifier: \" + sharedUUID + \"\\nstatus: todo\\nassignee: claude\\n---\\n# Second file (duplicate)\"\n731\t\t\t\tabsPath1 := filepath.Join(tmpDir, taskDir, \"dup-first.md\")\n732\t\t\t\tabsPath2 := filepath.Join(tmpDir, taskDir, \"dup-second.md\")\n733\t\t\t\tExpect(os.WriteFile(absPath1, []byte(content1), 0600)).To(Succeed())\n734\t\t\t\tExpect(os.WriteFile(absPath2, []byte(content2), 0600)).To(Succeed())\n735\t\n736\t\t\t\t// First cycle: first-seen keeps UUID, second gets replaced\n737\t\t\t\ts.RunCycle(ctx, results)\n738\t\t\t\tvar result scanner.ScanResult\n739\t\t\t\tExpect(results).To(Receive(&result))\n740\t\t\t\t// One file published (the first-seen), one replaced (the duplicate)\n741\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n742\t\t\t\tExpect(string(result.Changed[0].TaskIdentifier)).To(Equal(sharedUUID))\n743\t\n744\t\t\t\t// Replaced file now has a different UUID on disk\n745\t\t\t\twritten, err := os.ReadFile(absPath2) // #nosec G304 -- test-only path\n746\t\t\t\tExpect(err).To(BeNil())\n747\t\t\t\tExpect(string(written)).NotTo(ContainSubstring(sharedUUID))\n748\t\t\t})\n749\t\n750\t\t\tIt(\"valid unique UUID task_identifier is preserved unchanged\", func() {\n751\t\t\t\tvalidUUID := \"88888888-8888-4888-8888-888888888888\"\n752\t\t\t\tcontent := \"---\\ntask_identifier: \" + validUUID + \"\\nstatus: todo\\nassignee: claude\\n---\\n# Task with valid UUID\"\n753\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"valid-uuid-task.md\")\n754\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n755\t\n756\t\t\t\ts.RunCycle(ctx, results)\n757\t\t\t\tvar result scanner.ScanResult\n758\t\t\t\tExpect(results).To(Receive(&result))\n759\t\t\t\tExpect(result.Changed).To(HaveLen(1))\n760\t\t\t\tExpect(string(result.Changed[0].TaskIdentifier)).To(Equal(validUUID))\n761\t\n762\t\t\t\t// File is unchanged on disk (not rewritten)\n763\t\t\t\tonDisk, err := os.ReadFile(absPath) // #nosec G304 -- test-only path\n764\t\t\t\tExpect(err).To(BeNil())\n765\t\t\t\tExpect(string(onDisk)).To(Equal(content))\n766\t\t\t})\n767\t\n768\t\t\tIt(\"CommitAndPush failure suppresses scanner.ScanResult\", func() {\n769\t\t\t\tfakeGit.commitPushErr = context.DeadlineExceeded\n770\t\n771\t\t\t\tcontent := \"---\\nstatus: todo\\nassignee: claude\\n---\\n# Task without UUID\"\n772\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"no-uuid-task3.md\")\n773\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n774\t\n775\t\t\t\ts.RunCycle(ctx, results)\n776\t\t\t\tConsistently(results, 50*time.Millisecond).ShouldNot(Receive())\n777\t\t\t})\n778\t\t})\n779\t\n780\t\tDescribe(\"SkippedFilesTotal counter\", func() {\n781\t\t\tcounterValue := func(reason string) float64 {\n782\t\t\t\tmfs, err := prometheus.DefaultGatherer.Gather()\n783\t\t\t\tExpect(err).NotTo(HaveOccurred())\n784\t\t\t\tfor _, mf := range mfs {\n785\t\t\t\t\tif mf.GetName() != \"agent_controller_vault_scanner_skipped_files_total\" {\n786\t\t\t\t\t\tcontinue\n787\t\t\t\t\t}\n788\t\t\t\t\tfor _, m := range mf.GetMetric() {\n789\t\t\t\t\t\tfor _, lp := range m.GetLabel() {\n790\t\t\t\t\t\t\tif lp.GetName() == \"reason\" && lp.GetValue() == reason {\n791\t\t\t\t\t\t\t\treturn m.GetCounter().GetValue()\n792\t\t\t\t\t\t\t}\n793\t\t\t\t\t\t}\n794\t\t\t\t\t}\n795\t\t\t\t}\n796\t\t\t\treturn 0\n797\t\t\t}\n798\t\n799\t\t\tContext(\"invalid_frontmatter reason (extractFrontmatter failure)\", func() {\n800\t\t\t\t// Content without frontmatter delimiter fails at extractFrontmatter, not at DeduplicateFrontmatter.\n801\t\t\t\t// The second cycle re-processes (hash not stored), so counter ticks again.\n802\t\t\t\tIt(\n803\t\t\t\t\t\"increments counter on first cycle and again on second cycle (re-scan increments)\",\n804\t\t\t\t\tfunc() {\n805\t\t\t\t\t\t// No frontmatter delimiter - extractFrontmatter fails\n806\t\t\t\t\t\tcontent := \"task_identifier: aaaaaaaa-aaaa-4aaa-8aaa-aaaaaaaaaaaa\\nstatus: todo\\nassignee: claude\\n---\\n# No frontmatter\"\n807\t\t\t\t\t\tabsPath := filepath.Join(tmpDir, taskDir, \"no-frontmatter.md\")\n808\t\t\t\t\t\tExpect(os.WriteFile(absPath, []byte(content), 0600)).To(Succeed())\n809\t\n810\t\t\t\t\t\tinitial := counterValue(metrics.ReasonInvalidFrontmatter)\n811\t\t\t\t\t\tinitialDupInvalid := counterValue(metrics.ReasonDuplicateFrontmatterInvalid)\n812\t\t\t\t\t\tinitialEmptyStatus := counterValue(metrics.ReasonEmptyStatus)\n813\t\t\t\t\t\tinitialInjectFailed := counterValue(metrics.ReasonInjectTaskIdentifierFailed)\n814\t\t\t\t\t\tinitialReadFailed := counterValue(metrics.ReasonReadFailed)\n815\t\n816\t\t\t\t\t\ts.RunCycle(ctx, results)\n817\t\t\t\t\t\tExpect(counterValue(metrics.ReasonInvalidFrontmatter)).To(Equal(initial + 1))\n818\t\n819\t\t\t\t\t\ts.RunCycle(ctx, results)\n820\t\t\t\t\t\tExpect(counterValue(metrics.ReasonInvalidFrontmatter)).To(Equal(initial + 2))\n821\t\n822\t\t\t\t\t\tExpect(\n823\t\t\t\t\t\t\tcounterValue(metrics.ReasonDuplicateFrontmatterInvalid),\n824\t\t\t\t\t\t).To(BeNumerically(\"==\", initialDupInvalid))\n825\t\t\t\t\t\tExpect(\n826\t\t\t\t\t\t\tcounterValue(metrics.ReasonEmptyStatus),\n827\t\t\t\t\t\t).To(BeNumerically(\"==\", initialEmptyStatus))\n828\t\t\t\t\t\tExpect(\n829\t\t\t\t\t\t\tcounterValue(metrics.ReasonInjectTaskIdentifierFailed),\n830\t\t\t\t\t\t).To(BeNumerically(\"==\", initialInjectFailed))\n831\t\t\t\t\t\tExpect(\n832\t\t\t\t\t\t\tcounterValue(metrics.ReasonReadFailed),\n833\t\t\t\t\t\t).To(BeNumerically(\"==\", initialReadFailed))\n834\t\t\t\t\t},\n835\t\t\t\t)\n836\t\t\t})\n837\t\n838\t\t\tContext(\"duplicate_frontmatter_invalid reason\", func() {\n839\t\t\t\t// Bare '[' is valid at the raw frontmatter string level (extractFrontmatter passes),\n840\t\t\t\t// but fails DeduplicateFro