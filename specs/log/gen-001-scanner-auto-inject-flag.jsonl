it iterates through struct fields:\n179\t//   - For slices: validates the slice type first, then falls back to validating each element\n180\t//   - For other types: validates if they implement HasValidation\n181\t//\n182\t// Important: ValidateHasValidation runs on ALL fields that implement HasValidation,\n183\t// regardless of whether they have the `required:\"true\"` tag. This is by design:\n184\t//   - The `required` tag checks if a field is present (non-zero)\n185\t//   - The Validate() method checks if a field's value is valid\n186\t//\n187\t// These are separate concerns. If you have an optional field with a default value,\n188\t// that default value should still be validated. If you want zero values to be valid\n189\t// for optional fields, your Validate() implementation should explicitly handle that:\n190\t//\n191\t//\tfunc (p Port) Validate(ctx context.Context) error {\n192\t//\t    if p == 0 {\n193\t//\t        return nil // zero value is valid for optional ports\n194\t//\t    }\n195\t//\t    if p < 1024 {\n196\t//\t        return fmt.Errorf(\"port must be >= 1024\")\n197\t//\t    }\n198\t//\t    return nil\n199\t//\t}\n200\t//\n201\t// Returns the first validation error encountered.\n202\t//\n203\t// Example usage (automatic validation via Parse):\n204\t//\n205\t//\ttype Port int\n206\t//\tfunc (p Port) Validate(ctx context.Context) error {\n207\t//\t    if p < 1 || p > 65535 {\n208\t//\t        return fmt.Errorf(\"port must be between 1 and 65535, got %d\", p)\n209\t//\t    }\n210\t//\t    return nil\n211\t//\t}\n212\t//\n213\t//\ttype Config struct {\n214\t//\t    Port Port `arg:\"port\" default:\"8080\"`\n215\t//\t}\n216\t//\n217\t//\tvar config Config\n218\t//\tif err := argument.Parse(ctx, &config); err != nil {\n219\t//\t    // Parse automatically calls ValidateHasValidation\n220\t//\t    // Validation error will be returned if port is out of range\n221\t//\t}\n222\t//\n223\t// Example usage (manual validation workflow):\n224\t//\n225\t//\tvar confi