{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01APSMLBDKAQhGeVhVGGkuRx","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage lib\n6\t\n7\timport (\n8\t\t\"time\"\n9\t\n10\t\t\"github.com/bborbe/vault-cli/pkg/domain\"\n11\t)\n12\t\n13\t// TaskFrontmatter is a generic map of frontmatter key-value pairs.\n14\t// Serializable as JSON (Kafka) and YAML (vault file).\n15\t// Typed accessors provide type-safe access to well-known fields.\n16\ttype TaskFrontmatter map[string]interface{}\n17\t\n18\tfunc (f TaskFrontmatter) Status() domain.TaskStatus {\n19\t\tv, _ := f[\"status\"].(string)\n20\t\tif canonical, ok := domain.NormalizeTaskStatus(v); ok {\n21\t\t\treturn canonical\n22\t\t}\n23\t\treturn domain.TaskStatus(v)\n24\t}\n25\t\n26\tfunc (f TaskFrontmatter) Phase() *domain.TaskPhase {\n27\t\tv, ok := f[\"phase\"].(string)\n28\t\tif !ok || v == \"\" {\n29\t\t\treturn nil\n30\t\t}\n31\t\tif canonical, ok := domain.NormalizeTaskPhase(v); ok {\n32\t\t\treturn &canonical\n33\t\t}\n34\t\tp := domain.TaskPhase(v)\n35\t\treturn &p\n36\t}\n37\t\n38\tfunc (f TaskFrontmatter) Assignee() TaskAssignee {\n39\t\tv, _ := f[\"assignee\"].(string)\n40\t\treturn TaskAssignee(v)\n41\t}\n42\t\n43\t// TaskType returns the task_type frontmatter field as a typed TaskType.\n44\t// Returns TaskType(\"\") when the field is absent or holds a non-string value.\n45\tfunc (f TaskFrontmatter) TaskType() TaskType {\n46\t\tv, _ := f[\"task_type\"].(string)\n47\t\treturn TaskType(v)\n48\t}\n49\t\n50\t// Stage returns the execution stage from the \"stage\" key.\n51\t// Returns \"prod\" if the key is absent or empty.\n52\tfunc (f TaskFrontmatter) Stage() string {\n53\t\tv, _ := f[\"stage\"].(string)\n54\t\tif v == \"\" {\n55\t\t\treturn \"prod\"\n56\t\t}\n57\t\treturn v\n58\t}\n59\t\n60\t// RetryCount returns the number of failed attempts recorded in frontmatter.\n61\t// Returns 0 when the field is absent.\n62\tfunc (f TaskFrontmatter) RetryCount() int {\n63\t\tswitch v := f[\"retry_count\"].(type) {\n64\t\tcase int:\n65\t\t\treturn v\n66\t\tcase float64:\n67\t\t\treturn int(v)\n68\t\tdefault:\n69\t\t\treturn 0\n70\t\t}\n71\t}\n72\t\n73\t// MaxRetries returns the maximum number of failures allowed before escalation.\n74\t// Returns 3 when the field is absent (spec default).\n75\tfunc (f TaskFrontmatter) MaxRetries() int {\n76\t\tswitch v := f[\"max_retries\"].(type) {\n77\t\tcase int:\n78\t\t\treturn v\n79\t\tcase float64:\n80\t\t\treturn int(v)\n81\t\tdefault:\n82\t\t\treturn 3\n83\t\t}\n84\t}\n85\t\n86\t// TriggerCount returns the number of spawn-trigger events that have fired for this task.\n87\t// Returns 0 if the field is absent.\n88\tfunc (f TaskFrontmatter) TriggerCount() int {\n89\t\tswitch v := f[\"trigger_count\"].(type) {\n90\t\tcase int:\n91\t\t\treturn v\n92\t\tcase float64:\n93\t\t\treturn int(v)\n94\t\tdefault:\n95\t\t\treturn 0\n96\t\t}\n97\t}\n98\t\n99\t// MaxTriggers returns the maximum number of spawn-trigger events allowed for this task.\n100\t// Returns 3 if the field is absent, matching the default for max_retries.\n101\tfunc (f TaskFrontmatter) MaxTriggers() int {\n102\t\tswitch v := f[\"max_triggers\"].(type) {\n103\t\tcase int:\n104\t\t\treturn v\n105\t\tcase float64:\n106\t\t\treturn int(v)\n107\t\tdefault:\n108\t\t\treturn 3\n109\t\t}\n110\t}\n111\t\n112\t// SpawnNotification returns true when this result is a job-spawn tracking update\n113\t// rather than an agent outcome. The controller skips the retry counter for these.\n114\tfunc (f TaskFrontmatter) SpawnNotification() bool {\n115\t\tv, _ := f[\"spawn_notification\"].(bool)\n116\t\treturn v\n117\t}\n118\t\n119\t// CurrentJob returns the K8s Job name recorded when the executor spawned a Job for this task.\n120\t// Returns an empty string when not set.\n121\tfunc (f TaskFrontmatter) CurrentJob() string {\n122\t\tv, _ := f[\"current_job\"].(string)\n123\t\treturn v\n124\t}\n125\t\n126\t// JobStartedAt parses the job_started_at frontmatter field written by PublishSpawnNotification.\n127\t// Returns (time.Time{}, nil) when the field is absent — callers treat zero time as \"grace elapsed\".\n128\t// Returns (time.Time{}, err) when the field is present but unparseable.\n129\tfunc (f TaskFrontmatter) JobStartedAt() (time.Time, error) {\n130\t\tv, _ := f[\"job_started_at\"].(string)\n131\t\tif v == \"\" {\n132\t\t\treturn time.Time{}, nil\n133\t\t}\n134\t\tt, err := time.Parse(time.RFC3339, v)\n135\t\tif err != nil {\n136\t\t\treturn time.Time{}, err\n137\t\t}\n138\t\treturn t, nil\n139\t}\n140\t\n141\t// String reads a string field by key. ok is false when the key is absent\n142\t// or holds a non-string value. Generic accessor for ad-hoc fields without\n143\t// dedicated typed methods.\n144\tfunc (f TaskFrontmatter) String(key string) (string, bool) {\n145\t\tv, ok := f[key]\n146\t\tif !ok {\n147\t\t\treturn \"\", false\n148\t\t}\n149\t\ts, ok := v.(string)\n150\t\treturn s, ok\n151\t}\n152\t\n153\t// Int reads an integer field by key, accepting both int (JSON-decoded) and\n154\t// float64 (YAML-decoded) underlying types. ok is false when the key is\n155\t// absent or holds a non-numeric value. Generic accessor for ad-hoc fields\n156\t// without dedicated typed methods.\n157\tfunc (f TaskFrontmatter) Int(key string) (int, bool) {\n158\t\tv, ok := f[key]\n159\t\tif !ok {\n160\t\t\treturn 0, false\n161\t\t}\n162\t\tswitch n := v.(type) {\n163\t\tcase int:\n164\t\t\treturn n, true\n165\t\tcase float64:\n166\t\t\treturn int(n), true\n167\t\t}\n168\t\treturn 0, false\n169\t}\n170\t"}]},"parent_tool_use_id":"call_function_xkxpeuzg3f94_1","session_id":"538dadd3-1411-457f-8798-0759f57847fd","uuid":"ac5b4b30-5692-46eb-8a82-507274b6ff90","timestamp":"2026-07-01T12:09:37.451Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
