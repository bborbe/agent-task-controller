{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LBCWSw4aReSw4B27XrZv8M","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage command\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"maps\"\n10\t\t\"path/filepath\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\tlib \"github.com/bborbe/agent\"\n15\t\ttask \"github.com/bborbe/agent/command/task\"\n16\t\t\"github.com/bborbe/cqrs/base\"\n17\t\t\"github.com/bborbe/cqrs/cdb\"\n18\t\t\"github.com/bborbe/errors\"\n19\t\tlibkv \"github.com/bborbe/kv\"\n20\t\tlibtime \"github.com/bborbe/time\"\n21\t\t\"github.com/bborbe/validation\"\n22\t\t\"github.com/golang/glog\"\n23\t\n24\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n25\t\tresult \"github.com/bborbe/agent-task-controller/pkg/result\"\n26\t\t\"github.com/bborbe/agent-task-controller/pkg/routing\"\n27\t)\n28\t\n29\t// NewCreateTaskExecutor creates a cdb.CommandObjectExecutorTx that materializes\n30\t// a new vault task file for the given task_identifier. If cmd.Title passes validation\n31\t// the file is written at tasks/{title}.md; otherwise it falls back to tasks/{task_identifier}.md.\n32\t// If a file already exists at the resolved path the command returns ErrTaskAlreadyExists\n33\t// (a benign Failure on the result topic — no overwrite, no git write).\n34\t// Frontmatter must include \"assignee\" and \"status\"; missing fields return a wrapped validation error.\n35\t// Commands whose effective target vault (cmd.TargetVault or the legacy fallback) does not\n36\t// match vaultName are skipped without side effects (no git write, no error, no result event).\n37\tfunc NewCreateTaskExecutor(\n38\t\tgitClient gitclient.GitClient,\n39\t\ttaskDir string,\n40\t\tvaultName string,\n41\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n42\t) cdb.CommandObjectExecutorTx {\n43\t\treturn cdb.CommandObjectExecutorTxFunc(\n44\t\t\ttask.CreateCommandOperation,\n45\t\t\ttrue,\n46\t\t\tfunc(ctx context.Context, tx libkv.Tx, commandObject cdb.CommandObject) (*base.EventID, base.Event, error) {\n47\t\t\t\tvar cmd task.CreateCommand\n48\t\t\t\tif err := commandObject.Command.Data.MarshalInto(ctx, &cmd); err != nil {\n49\t\t\t\t\treturn nil, nil, errors.Wrapf(\n50\t\t\t\t\t\tctx,\n51\t\t\t\t\t\tcdb.ErrCommandObjectSkipped,\n52\t\t\t\t\t\t\"malformed CreateTaskCommand: %v\",\n53\t\t\t\t\t\terr,\n54\t\t\t\t\t)\n55\t\t\t\t}\n56\t\t\t\tif err := cmd.TaskIdentifier.Validate(ctx); err != nil {\n57\t\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate task_identifier\")\n58\t\t\t\t}\n59\t\t\t\tif !routing.ShouldProcess(cmd, vaultName) {\n60\t\t\t\t\teffective := cmd.TargetVault\n61\t\t\t\t\tif effective == \"\" {\n62\t\t\t\t\t\teffective = routing.LegacyDefaultVault\n63\t\t\t\t\t}\n64\t\t\t\t\tglog.V(2).Infof(\n65\t\t\t\t\t\t\"create-task: skipped vault mismatch target=%q effective=%q vault=%q task=%s\",\n66\t\t\t\t\t\tcmd.TargetVault, effective, vaultName, cmd.TaskIdentifier,\n67\t\t\t\t\t)\n68\t\t\t\t\treturn nil, nil, nil\n69\t\t\t\t}\n70\t\t\t\tif err := validateCreateTaskFrontmatter(ctx, cmd.Frontmatter); err != nil {"}]},"parent_tool_use_id":"call_function_xkxpeuzg3f94_1","session_id":"538dadd3-1411-457f-8798-0759f57847fd","uuid":"e4bc6a0f-666a-470a-9946-c043db7f94f3","timestamp":"2026-07-01T12:11:08.864Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
