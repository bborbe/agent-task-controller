:\"SENTRY_DSN\"                  usage:\"SentryDSN\"                                                                                                                                               display:\"length\"`\n51\t\tSentryProxy              string            `required:\"false\" arg:\"sentry-proxy\"                env:\"SENTRY_PROXY\"                usage:\"Sentry Proxy\"`\n52\t\tListen                   string            `required:\"true\"  arg:\"listen\"                      env:\"LISTEN\"                      usage:\"address to listen to\"`\n53\t\tKafkaBrokers             string            `required:\"true\"  arg:\"kafka-brokers\"               env:\"KAFKA_BROKERS\"               usage:\"comma-separated Kafka broker addresses\"`\n54\t\tBranch                   base.Branch       `required:\"true\"  arg:\"branch\"                      env:\"BRANCH\"                      usage:\"Kafka topic prefix branch (develop/live)\"`\n55\t\tPollInterval             time.Duration     `required:\"false\" arg:\"poll-interval\"               env:\"POLL_INTERVAL\"               usage:\"vault polling interval\"                                                                                                                                                   default:\"60s\"`\n56\t\tTaskDir                  string            `required:\"true\"  arg:\"task-dir\"                    env:\"TASK_DIR\"                    usage:\"task directory within vault (per-vault convention: openclaw=tasks, personal=24 Tasks)\"`\n57\t\tDataDir                  string            `required:\"true\"  arg:\"data-dir\"                    env:\"DATA_DIR\"                    usage:\"directory for BoltDB offset storage\"`\n58\t\tNoSync                   bool              `required:\"false\" arg:\"no-sync\"                     env:\"NO_SYNC\"                     usage:\"disable BoltDB fsync (for testing only)\"`\n59\t\tGitRestURL               string            `required:\"false\" arg:\"git-rest-url\"                env:\"GIT_REST_URL\"                usage:\"git-rest HTTP API base URL\"                                                                                                                                               default:\"http://vault-obsidian-openclaw:9090\"`\n60\t\tGatewaySecret            string            `required:\"false\" arg:\"gateway-secret\"              env:\"GATEWAY_SECRET\"              usage:\"shared secret for git-rest gateway auth (sent as X-Gateway-Secret header)\"                                                                               display:\"length\" default:\"\"`\n61\t\tBuildGitVersion          string            `required:\"false\" arg:\"build-git-version\"           env:\"BUILD_GIT_VERSION\"           usage:\"Build Git version (git describe --tags --always --dirty)\"                                                                                                                 default:\"dev\"`\n62\t\tBuildGitCommit           string            `required:\"false\" arg:\"build-git-commit\"            env:\"BUILD_GIT_COMMIT\"            usage:\"Build Git commit hash\"                                                                                                                                                    default:\"none\"`\n63\t\tBuildDate                *libtime.DateTime `required:\"false\" arg:\"build-date\"                  env:\"BUILD_DATE\"                  usage:\"Build timestamp (RFC3339)\"`\n64\t\tVaultName                string            `required:\"true\"  arg:\"vault-name\"                  env:\"VAULT_NAME\"                  usage:\"vault slug this controller serves (e.g. openclaw, personal); legacy empty targetVault defaults to openclaw\"`\n65\t\tAutoInjectTaskIdentifier string            `required:\"true\"  arg:\"auto-inject-task-identifier\" env:\"AUTO_INJECT_TASK_IDENTIFIER\" usage:\"allow this replica to backfill missing/invalid task_identifier fields (set true on exactly one replica per shared vault; false on all others); required\"`\n66\t}\n67\t\n68\t//nolint:funlen // +6 lines from spec-043 metrics.New() passed to scanner + sync loop; extraction would split tightly-coupled wiring.\n69\tfunc (a *application) Run(ctx context.Context, sentryClient libsentry.Client) error {\n70\t\tif err := routing.ValidateVaultName(ctx, a.VaultName); err != nil {\n71\t\t\treturn err\n72\t\t}\n73\t\tautoInject, err := strconv.ParseBool(a.AutoInjectTaskIdentifier)\n74\t\tif err != nil {\n75\t\t\treturn errors.Errorf(\n76\t\t\t\tctx,\n77\t\t\t\t\"AUTO_INJECT_TASK_IDENTIFIER must be parseable as bool (true/false), got %q\",\n78\t\t\t\ta.AutoInjectTaskIdentifier,\n79\t\t\t)\n80\t\t}\n81\t\tlibmetrics.NewBuildInfoMetrics().SetBuildInfo(a.BuildGitVersion, a.BuildGitCommit, a.BuildDate)\n82\t\tglog.V(1).\n83\t\t\tInfof(\"agent-task-controller started version=%s commit=%s\", a.BuildGitVersion, a.BuildGitCommit)\n84\t\n85\t\tif a.GitRestURL == \"\" {\n86\t\t\treturn errors.Errorf(ctx, \"GIT_REST_URL is required\")\n87\t\t}\n88\t\trestClient := gitrestclient.NewGitRestClient(\n89\t\t\ta.GitRestURL, a.GatewaySecret, \"agent-task-controller\", metrics.New(),\n90\t\t)\n91\t\tgitClient := gitrestclient.NewGitClient(restClient, vaultLocalPath)\n92\t\tif err := gitClient.EnsureCloned(ctx); err != nil {\n93\t\t\treturn errors.Wrapf(ctx, err, \"probe git-rest readiness\")\n94\t\t}\n95\t\tglog.V(1).Infof(\"using git-rest HTTP API at %s\", a.GitRestURL)\n96\t\n97\t\tsyncProducer, err := libkafka.NewSyncProducer(\n98\t\t\tctx,\n99\t\t\tlibkafka.ParseBrokersFromString(a.KafkaBrokers),\n100\t\t)\n101\t\tif err != nil {\n102\t\t\treturn errors.Wrapf(ctx, err, \"create kafka sync producer\")\n103\t\t}\n104\t\tdefer syncProducer.Close()\n105\t\n106\t\teventObjectSender := cdb.NewEventObjectSender(\n107\t\t\tlibkafka.NewJSONSender(syncProducer, log.DefaultSamplerFactory),\n108\t\t\ta.Branch,\n109\t\t\tlog.DefaultSamplerFactory,\n110\t\t)\n111\t\n112\t\tcurrentDateTime := libtime.NewCurrentDateTime()\n113\t\n114\t\ttrigger := make(chan struct{}, 1)\n115\t\tsyncLoop := pkgsync.NewSyncLoop(\n116\t\t\tscanner.NewGitRestVaultScanner(\n117\t\t\t\tgitClient,\n118\t\t\t\ta.TaskDir,\n119\t\t\t\ta.PollInterval,\n120\t\t\t\ttrigger,\n121\t\t\t\tmetrics.New(),\n122\t\t\t\tautoInject,\n123\t\t\t),\n124\t\t\tpublisher.NewTaskPublisher(eventObjectSender, lib.TaskV1SchemaID, currentDateTime),\n125\t\t\ttrigger,\n126\t\t\tmetrics.New(),\n127\t\t)\n128\t\n129\t\tvar boltOptions []boltkv.ChangeOptions\n130\t\tif a.NoSync {\n131\t\t\tboltOptions = append(boltOptions, func(opts *bolt.Options) {\n132\t\t\t\topts.NoSync = true\n133\t\t\t})\n134\t\t}\n135\t\tdb, err := boltkv.OpenDir(ctx, a.DataDir, boltOptions...)\n136\t\tif err != nil {\n137\t\t\treturn errors.Wrapf(ctx, err, \"open boltkv dir %s\", a.DataDir)\n138\t\t}\n139\t\tdefer db.Close()\n140\t\n141\t\tsaramaClientProvider, err := libkafka.NewSaramaClientProviderByType(\n142\t\t\tctx,\n143\t\t\tlibkafka.SaramaClientProviderTypeReused,\n144\t\t\tlibkafka.ParseBrokersFromString(a.KafkaBrokers),\n145\t\t)\n146\t\tif err != nil {\n147\t\t\treturn errors.Wrapf(ctx, err, \"create sarama client provider\")\n148\t\t}\n149\t\tdefer saramaClientProvider.Close()\n150\t\n151\t\tresultWriter := result.NewResultWriter(gitClient, a.TaskDir, currentDateTime)\n152\t\tcommandConsumer := factory.CreateCommandConsumer(\n153\t\t\tsaramaClientProvider,\n154\t\t\tsyncProducer,\n155\t\t\tdb,\n156\t\t\ta.Branch,\n157\t\t\tresultWriter,\n158\t\t\tgitClient,\n159\t\t\ta.TaskDir,\n160\t\t\ta.VaultName,\n161\t\t\tcurrentDateTime,\n162\t\t)\n163\t\n164\t\treturn service.Run(\n165\t\t\tctx,\n166\t\t\tsyncLoop.Run,\n167\t\t\tcommandConsumer,\n168\t\t\ta.createHTTPServer(syncLoop, restClient),\n169\t\t)\n170\t}\n171\t\n172\tfunc (a *application) createHTTPServer(\n173\t\tsyncLoop pkgsync.SyncLoop,\n174\t\tgitRestClient gitrestclient.GitRestClient,\n175\t) run.Func {\n176\t\treturn func(ctx context.Context) error {\n177\t\t\trouter := mux.NewRouter()\n178\t\t\trouter.Path(\"/healthz\").Handler(libhttp.NewPrintHandler(\"OK\"))\n179\t\t\trouter.Path(\"/readiness\").HandlerFunc(func(w http.ResponseWriter, req *http.Request) {\n180\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain\")\n181\t\t\t\tready, err := gitRestClient.IsReady(req.Context())\n182\t\t\t\tif err != nil || !ready {\n183\t\t\t\t\tw.WriteHeader(http.StatusServiceUnavailable)\n184\t\t\t\t\t_, _ = w.Write([]byte(\"git-rest not ready\"))\n185\t\t\t\t\treturn\n186\t\t\t\t}\n187\t\t\t\t_, _ = w.Write([]byte(\"OK\"))\n188\t\t\t})\n189\t\t\trouter.Path(\"/metrics\").Handler(promhttp.Handler())\n190\t\t\trouter.Path(\"/setloglevel/{level}\").\n191\t\t\t\tHandler(log.NewSetLoglevelHandler(ctx, log.NewLogLevelSetter(2, 5*time.Minute)))\n192\t\t\trouter.Path(\"/trigger\").HandlerFunc(func(resp http.ResponseWriter, req *http.Request) {\n193\t\t\t\tsyncLoop.Trigger()\n194\t\t\t\tglog.V(2).Infof(\"trigger fired via HTTP\")\n195\t\t\t\t_, _ = resp.Write([]byte(\"trigger fired\"))\n196\t\t\t})\n197\t\n198\t\t\tglog.V(2).Infof(\"starting http server listen on %s\", a.Listen)\n199\t\t\treturn libhttp.NewServer(\n200\t\t\t\ta.Listen,\n201\t\t\t\trouter,\n202\t\t\t).Run(ctx)\n203\t\t}\n204\t}\n205\t"}]},"parent_tool_use_id":"call_function_xkxpeuzg3f94_1","session_id":"538dadd3-1411-457f-8798-0759f57847fd","uuid":"a9dbc1a0-3c0b-4aac-b4a3-1b3fd3502da2","timestamp":"2026-07-01T12:10:17.236Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
