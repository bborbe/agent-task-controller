{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01StBJ6EUihNxtiyjSfn4ZVi","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage scanner\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"strings\"\n10\t\n11\t\t\"github.com/bborbe/errors\"\n12\t\t\"github.com/google/uuid\"\n13\t)\n14\t\n15\t// isValidUUID returns true if s can be parsed as a valid UUID.\n16\tfunc isValidUUID(s string) bool {\n17\t\t_, err := uuid.Parse(s)\n18\t\treturn err == nil\n19\t}\n20\t\n21\t// isIdentifierUnique returns true if no other file in v.hashes uses the same task identifier.\n22\tfunc (v *vaultScanner) isIdentifierUnique(id string, relPath string) bool {\n23\t\tfor path, entry := range v.hashes {\n24\t\t\tif path != relPath && string(entry.taskIdentifier) == id {\n25\t\t\t\treturn false\n26\t\t\t}\n27\t\t}\n28\t\treturn true\n29\t}\n30\t\n31\t// removeTaskIdentifier removes any existing task_identifier line(s) from the\n32\t// frontmatter so that injectAndStore can safely prepend a fresh value.\n33\tfunc removeTaskIdentifier(content []byte) []byte {\n34\t\ts := string(content)\n35\t\tconst prefix = \"task_identifier:\"\n36\t\tvar out []string\n37\t\tfor _, line := range strings.Split(s, \"\\n\") {\n38\t\t\ttrimmed := strings.TrimRight(line, \"\\r\")\n39\t\t\tif strings.HasPrefix(trimmed, prefix) {\n40\t\t\t\tcontinue\n41\t\t\t}\n42\t\t\tout = append(out, line)\n43\t\t}\n44\t\treturn []byte(strings.Join(out, \"\\n\"))\n45\t}\n46\t\n47\t// InjectTaskIdentifier injects a task_identifier into the frontmatter of content.\n48\tfunc InjectTaskIdentifier(ctx context.Context, content []byte, id string) ([]byte, error) {\n49\t\ts := string(content)\n50\t\tif strings.HasPrefix(s, \"---\\r\\n\") {\n51\t\t\treturn []byte(\"---\\r\\ntask_identifier: \" + id + \"\\r\\n\" + s[5:]), nil\n52\t\t}\n53\t\tif strings.HasPrefix(s, \"---\\n\") {\n54\t\t\treturn []byte(\"---\\ntask_identifier: \" + id + \"\\n\" + s[4:]), nil\n55\t\t}\n56\t\treturn nil, errors.Errorf(\n57\t\t\tctx,\n58\t\t\t\"content does not start with frontmatter delimiter\",\n59\t\t)\n60\t}\n61\t"}]},"parent_tool_use_id":"call_function_xkxpeuzg3f94_1","session_id":"538dadd3-1411-457f-8798-0759f57847fd","uuid":"a187794f-306b-4b71-a01c-9e745734cfb4","timestamp":"2026-07-01T12:10:35.544Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
