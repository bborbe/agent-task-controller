{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011d8hx3HQMbLmheJfWuSe3c","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage metrics\n6\t\n7\timport (\n8\t\t\"github.com/prometheus/client_golang/prometheus\"\n9\t\t\"github.com/prometheus/client_golang/prometheus/promauto\"\n10\t)\n11\t\n12\t//go:generate go run github.com/maxbrunsfeld/counterfeiter/v6 -generate\n13\t//counterfeiter:generate -o ../../mocks/metrics.go --fake-name Metrics . Metrics\n14\t\n15\t// Metrics defines the interface for accessing Prometheus metrics.\n16\t// Use this interface in business logic packages to enable mock injection in tests.\n17\ttype Metrics interface {\n18\t\tScanCyclesTotal(outcome string) prometheus.Counter\n19\t\tTasksPublishedTotal(outcome string) prometheus.Counter\n20\t\tResultsWrittenTotal(outcome string) prometheus.Counter\n21\t\tGitPushTotal(outcome string) prometheus.Counter\n22\t\tConflictResolutionsTotal() prometheus.Counter\n23\t\tFrontmatterCommandsTotal(operation, outcome string) prometheus.Counter\n24\t\tGitRestCallsTotal(operation, status string) prometheus.Counter\n25\t\tKafkaConsumePausedTotal() prometheus.Counter\n26\t\tSkippedFilesTotal(reason string) prometheus.Counter\n27\t}\n28\t\n29\t// defaultMetrics implements Metrics using promauto-registered counters.\n30\ttype defaultMetrics struct{}\n31\t\n32\tvar _ Metrics = &defaultMetrics{}\n33\t\n34\t// New returns a new default Metrics implementation.\n35\tfunc New() Metrics {\n36\t\treturn &defaultMetrics{}\n37\t}\n38\t\n39\tfunc (m *defaultMetrics) ScanCyclesTotal(outcome string) prometheus.Counter {\n40\t\treturn ScanCyclesTotal.WithLabelValues(outcome)\n41\t}\n42\t\n43\tfunc (m *defaultMetrics) TasksPublishedTotal(outcome string) prometheus.Counter {\n44\t\treturn TasksPublishedTotal.WithLabelValues(outcome)\n45\t}\n46\t\n47\tfunc (m *defaultMetrics) ResultsWrittenTotal(outcome string) prometheus.Counter {\n48\t\treturn ResultsWrittenTotal.WithLabelValues(outcome)\n49\t}\n50\t\n51\tfunc (m *defaultMetrics) GitPushTotal(outcome string) prometheus.Counter {\n52\t\treturn GitPushTotal.WithLabelValues(outcome)\n53\t}\n54\t\n55\tfunc (m *defaultMetrics) ConflictResolutionsTotal() prometheus.Counter {\n56\t\treturn ConflictResolutionsTotal.WithLabelValues()\n57\t}\n58\t\n59\tfunc (m *defaultMetrics) FrontmatterCommandsTotal(operation, outcome string) prometheus.Counter {\n60\t\treturn FrontmatterCommandsTotal.WithLabelValues(operation, outcome)\n61\t}\n62\t\n63\tfunc (m *defaultMetrics) GitRestCallsTotal(operation, status string) prometheus.Counter {\n64\t\treturn GitRestCallsTotal.WithLabelValues(operation, status)\n65\t}\n66\t\n67\tfunc (m *defaultMetrics) KafkaConsumePausedTotal() prometheus.Counter {\n68\t\treturn KafkaConsumePausedTotal\n69\t}\n70\t\n71\tfunc (m *defaultMetrics) SkippedFilesTotal(reason string) prometheus.Counter {\n72\t\treturn SkippedFilesTotal.WithLabelValues(reason)\n73\t}\n74\t\n75\t// ScanCyclesTotal counts scan cycle completions by result.\n76\tvar ScanCyclesTotal = promauto.NewCounterVec(\n77\t\tprometheus.CounterOpts{\n78\t\t\tName: \"agent_controller_scan_cycles_total\",\n79\t\t\tHelp: \"Total number of scan cycles completed.\",\n80\t\t},\n81\t\t[]string{\"result\"},\n82\t)\n83\t\n84\t// TasksPublishedTotal counts task events published by type.\n85\tvar TasksPublishedTotal = promauto.NewCounterVec(\n86\t\tprometheus.CounterOpts{\n87\t\t\tName: \"agent_controller_tasks_published_total\",\n88\t\t\tHelp: \"Total number of task events published.\",\n89\t\t},\n90\t\t[]string{\"type\"},\n91\t)\n92\t\n93\t// ResultsWrittenTotal counts result write attempts by outcome.\n94\tvar ResultsWrittenTotal = promauto.NewCounterVec(\n95\t\tprometheus.CounterOpts{\n96\t\t\tName: \"agent_controller_results_written_total\",\n97\t\t\tHelp: \"Total number of task result write attempts.\",\n98\t\t},\n99\t\t[]string{\"result\"},\n100\t)\n101\t\n102\t// GitPushTotal counts git push attempts by outcome.\n103\tvar GitPushTotal = promauto.NewCounterVec(\n104\t\tprometheus.CounterOpts{\n105\t\t\tName: \"agent_controller_git_push_total\",\n106\t\t\tHelp: \"Total number of git push attempts.\",\n107\t\t},\n108\t\t[]string{\"result\"},\n109\t)\n110\t\n111\t// ConflictResolutionsTotal counts per-file conflict resolution attempts by outcome.\n112\tvar ConflictResolutionsTotal = promauto.NewCounterVec(\n113\t\tprometheus.CounterOpts{\n114\t\t\tName: \"agent_controller_conflict_resolutions_total\",\n115\t\t\tHelp: \"Total number of per-file conflict resolution attempts.\",\n116\t\t},\n117\t\t[]string{\"result\"},\n118\t)\n119\t\n120\t// FrontmatterCommandsTotal counts atomic frontmatter command executions\n121\t// by operation (\"increment-frontmatter\" | \"update-frontmatter\") and\n122\t// outcome (\"success\" | \"error\" | \"not_found\").\n123\tvar FrontmatterCommandsTotal = promauto.NewCounterVec(\n124\t\tprometheus.CounterOpts{\n125\t\t\tName: \"agent_controller_frontmatter_commands_total\",\n126\t\t\tHelp: \"Total number of atomic frontmatter commands processed, by operation and outcome.\",\n127\t\t},\n128\t\t[]string{\"operation\", \"outcome\"},\n129\t)\n130\t\n131\t// GitRestCallsTotal counts git-rest HTTP API calls by operation and outcome.\n132\tvar GitRestCallsTotal = promauto.NewCounterVec(\n133\t\tprometheus.CounterOpts{\n134\t\t\tName: \"agent_controller_git_rest_calls_total\",\n135\t\t\tHelp: \"Total number of git-rest HTTP API calls by operation and outcome.\",\n136\t\t},\n137\t\t[]string{\"op\", \"status\"},\n138\t)\n139\t\n140\t// KafkaConsumePausedTotal counts times a Kafka command executor blocked\n141\t// waiting for git-rest to become available (i.e. retry attempts after the first).\n142\tvar KafkaConsumePausedTotal = promauto.NewCounter(prometheus.CounterOpts{\n143\t\tName: \"controller_kafka_consume_paused_total\",\n144\t\tHelp: \"Total number of times Kafka consumption was paused waiting for git-rest.\",\n145\t})\n146\t\n147\tconst (\n148\t\tReasonInvalidFrontmatter          = \"invalid_frontmatter\"\n149\t\tReasonDuplicateFrontmatterInvalid = \"duplicate_frontmatter_invalid\"\n150\t\tReasonEmptyStatus                 = \"empty_status\"\n151\t\tReasonInjectTaskIdentifierFailed  = \"inject_task_identifier_failed\"\n152\t\tReasonReadFailed                  = \"read_failed\"\n153\t\tReasonAutoInjectDisabled          = \"auto_inject_disabled\"\n154\t)\n155\t\n156\t// SkippedFilesTotal counts vault task files the scanner skipped during a scan cycle,\n157\t// labelled by the structured reason for the skip. A non-zero value on any label\n158\t// indicates operator-actionable vault health issues (broken frontmatter, empty status,\n159\t// unreadable files, injection failures); a stuck broken file will keep the relevant\n160\t// label rate-positive until repaired. The closed set of reason values is declared\n161\t// as constants above and pre-initialised in init().\n162\tvar SkippedFilesTotal = promauto.NewCounterVec(\n163\t\tprometheus.CounterOpts{\n164\t\t\tName: \"agent_controller_vault_scanner_skipped_files_total\",\n165\t\t\tHelp: \"Total number of vault task files the scanner skipped during a scan cycle, by reason. Increments exactly once per skipped file per cycle — re-scans of an unrepaired broken file keep the rate positive.\",\n166\t\t},\n167\t\t[]string{\"reason\"},\n168\t)\n169\t\n170\tfunc init() {\n171\t\tScanCyclesTotal.WithLabelValues(\"changes\").Add(0)\n172\t\tScanCyclesTotal.WithLabelValues(\"no_changes\").Add(0)\n173\t\tScanCyclesTotal.WithLabelValues(\"error\").Add(0)\n174\t\n175\t\tTasksPublishedTotal.WithLabelValues(\"changed\").Add(0)\n176\t\tTasksPublishedTotal.WithLabelValues(\"deleted\").Add(0)\n177\t\n178\t\tResultsWrittenTotal.WithLabelValues(\"success\").Add(0)\n179\t\tResultsWrittenTotal.WithLabelValues(\"not_found\").Add(0)\n180\t\tResultsWrittenTotal.WithLabelValues(\"error\").Add(0)\n181\t\n182\t\tGitPushTotal.WithLabelValues(\"success\").Add(0)\n183\t\tGitPushTotal.WithLabelValues(\"retry_success\").Add(0)\n184\t\tGitPushTotal.WithLabelValues(\"conflict_resolved\").Add(0)\n185\t\tGitPushTotal.WithLabelValues(\"error\").Add(0)\n186\t\n187\t\tConflictResolutionsTotal.WithLabelValues(\"success\").Add(0)\n188\t\tConflictResolutionsTotal.WithLabelValues(\"error\").Add(0)\n189\t\n190\t\tfor _, op := range []string{\"increment-frontmatter\", \"update-frontmatter\"} {\n191\t\t\tfor _, outcome := range []string{\"success\", \"error\", \"not_found\"} {\n192\t\t\t\tFrontmatterCommandsTotal.WithLabelValues(op, outcome).Add(0)\n193\t\t\t}\n194\t\t}\n195\t\n196\t\tfor _, op := range []string{\"get\", \"post\", \"delete\", \"list\", \"readiness\"} {\n197\t\t\tfor _, status := range []string{\"success\", \"error\"} {\n198\t\t\t\tGitRestCallsTotal.WithLabelValues(op, status).Add(0)\n199\t\t\t}\n200\t\t}\n201\t\n202\t\tfor _, reason := range []string{\n203\t\t\tReasonInvalidFrontmatter,\n204\t\t\tReasonDuplicateFrontmatterInvalid,\n205\t\t\tReasonEmptyStatus,\n206\t\t\tReasonInjectTaskIdentifierFailed,\n207\t\t\tReasonReadFailed,\n208\t\t\tReasonAutoInjectDisabled,\n209\t\t} {\n210\t\t\tSkippedFilesTotal.WithLabelValues(reason).Add(0)\n211\t\t}\n212\t}\n213\t"}]},"parent_tool_use_id":"call_function_xkxpeuzg3f94_1","session_id":"538dadd3-1411-457f-8798-0759f57847fd","uuid":"847ce00c-27e9-43ae-97dc-598fea9bc21e","timestamp":"2026-07-01T12:09:08.949Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
