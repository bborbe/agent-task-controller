es(operation, status)\n67:func (m *defaultMetrics) KafkaConsumePausedTotal() prometheus.Counter {\n71:func (m *defaultMetrics) SkippedFilesTotal(reason string) prometheus.Counter {\n72:\treturn SkippedFilesTotal.WithLabelValues(reason)\n76:var ScanCyclesTotal = promauto.NewCounterVec(\n85:var TasksPublishedTotal = promauto.NewCounterVec(\n93:// ResultsWrittenTotal counts result write attempts by outcome.\n94:var ResultsWrittenTotal = promauto.NewCounterVec(\n103:var GitPushTotal = promauto.NewCounterVec(\n112:var ConflictResolutionsTotal = promauto.NewCounterVec(\n123:var FrontmatterCommandsTotal = promauto.NewCounterVec(\n132:var GitRestCallsTotal = promauto.NewCounterVec(\n142:var KafkaConsumePausedTotal = promauto.NewCounter(prometheus.CounterOpts{\n162:var SkippedFilesTotal = promauto.NewCounterVec(\n170:func init() {\n171:\tScanCyclesTotal.WithLabelValues(\"changes\").Add(0)\n172:\tScanCyclesTotal.WithLabelValues(\"no_changes\").Add(0)\n173:\tScanCyclesTotal.WithLabelValues(\"error\").Add(0)\n175:\tTasksPublishedTotal.WithLabelValues(\"changed\").Add(0)\n176:\tTasksPublishedTotal.WithLabelValues(\"deleted\").Add(0)\n178:\tResultsWrittenTotal.WithLabelValues(\"success\").Add(0)\n179:\tResultsWrittenTotal.WithLabelValues(\"not_found\").Add(0)\n180:\tResultsWrittenTotal.WithLabelValues(\"error\").Add(0)\n182:\tGitPushTotal.WithLabelValues(\"success\").Add(0)\n183:\tGitPushTotal.WithLabelValues(\"retry_success\").Add(0)\n184:\tGitPushTotal.WithLabelValues(\"conflict_resolved\").Add(0)\n185:\tGitPushTotal.WithLabelValues(\"error\").Add(0)\n187:\tConflictResolutionsTotal.WithLabelValues(\"success\").Add(0)\n188:\tConflictResolutionsTotal.WithLabelValues(\"error\").Add(0)\n192:\t\t\tFrontmatterCommandsTotal.WithLabelValues(op, outcome).Add(0)\n198:\t\t\tGitRestCallsTotal.WithLabelValues(op, status).Add(0)\n210:\t\tSkippedFilesTotal.WithLabelValues(reason).Add(0)\n===SCANNER===\n33:func removeTaskIdentifier(content []byte) []byte {\n48:func InjectTaskIdentifier(ctx context.Context, content []byte, id string) ([]byte, error) {\n===GITREST 298-342===\n//counterfeiter:generate -o ../../mocks/git_client.go --fake-name GitClient . GitClient\n\n// GitClient is the interface for vault file operations used throughout the controller.\ntype GitClient interface {\n\t// EnsureCloned clones the repo if not present, validates if already cloned.\n\tEnsureCloned(ctx context.Context) error\n\t// Pull runs git pull on the local clone.\n\tPull(ctx context.Context) error\n\t// CommitAndPush stages all changes, creates a commit with the given message, and pushes to the remote.\n\tCommitAndPush(ctx context.Context, message string) error\n\t// AtomicWriteAndCommitPush writes content to absPath and commits+pushes under a single lock.\n\t// Atomicity (no interleaving with other writes) is guaranteed by the implementation:\n\t// - gitClient (local-disk): sync.Mutex around the whole sequence.\n\t// - gitRestGitClientAdapter: relies on per-task serialization (Kafka partitioning by task_id).\n\tAtomicWriteAndCommitPush(\n\t\tctx context.Context,\n\t\tabsPath string,\n\t\tcontent []byte,\n\t\tmessage string,\n\t) error\n\t// AtomicReadModifyWriteAndCommitPush reads absPath, calls modify on its contents\n\t// to produce new contents, writes the result, and commits+pushes.\n\t// Atomicity (no interleaving with other writes) is guaranteed by the implementation:\n\t// - gitClient (local-disk): sync.Mutex around the whole sequence.\n\t// - gitRestGitClientAdapter: relies on per-task serialization (Kafka partitioning by task_id).\n\t// modify must return the new file bytes or an error.\n\t// If modify returns an error, the file is not written and no commit is made.\n\tAtomicReadModifyWriteAndCommitPush(\n\t\tctx context.Context,\n\t\tabsPath string,\n\t\tmodify func(current []byte) ([]byte, error),\n\t\tmessage string,\n\t) error\n\t// Path returns the local clone path.\n\tPath() string\n\t// ListFiles returns relative file paths under the repo root matching the single-level\n\t// glob pattern (e.g. \"tasks/*.md\"). Paths are relative to the repo root.\n\tListFiles(ctx context.Context, glob string) ([]string, error)\n\t// ReadFile reads the file at relPath (relative to repo root, e.g. \"tasks/foo.md\")\n\t// and returns its content.\n\tReadFile(ctx context.Context, relPath string) ([]byte, error)\n\t// WriteFile writes content to relPath (relative to repo root) on local disk.\n\t// It does NOT commit or push — use AtomicWriteAndCommitPush for that.\n\tWriteFile(ctx context.Context, relPath string, content []byte) error\n}","is_error":false}]},"parent_tool_use_id":"call_function_9vqzbntzzfo7_1","session_id":"538dadd3-1411-457f-8798-0759f57847fd","uuid":"8f837ad9-74ab-481d-95f2-274b397bf006","timestamp":"2026-07-01T12:19:43.583Z","subagent_type":"dark-factory:prompt-auditor","task_description":"Audit prompt 1"}
