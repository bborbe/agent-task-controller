{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014PpqjBf76cj8DLq48Quyp6","type":"tool_result","content":"295\t\treturn paths, nil\n296\t}\n297\t\n298\t//counterfeiter:generate -o ../../mocks/git_client.go --fake-name GitClient . GitClient\n299\t\n300\t// GitClient is the interface for vault file operations used throughout the controller.\n301\ttype GitClient interface {\n302\t\t// EnsureCloned clones the repo if not present, validates if already cloned.\n303\t\tEnsureCloned(ctx context.Context) error\n304\t\t// Pull runs git pull on the local clone.\n305\t\tPull(ctx context.Context) error\n306\t\t// CommitAndPush stages all changes, creates a commit with the given message, and pushes to the remote.\n307\t\tCommitAndPush(ctx context.Context, message string) error\n308\t\t// AtomicWriteAndCommitPush writes content to absPath and commits+pushes under a single lock.\n309\t\t// Atomicity (no interleaving with other writes) is guaranteed by the implementation:\n310\t\t// - gitClient (local-disk): sync.Mutex around the whole sequence.\n311\t\t// - gitRestGitClientAdapter: relies on per-task serialization (Kafka partitioning by task_id).\n312\t\tAtomicWriteAndCommitPush(\n313\t\t\tctx context.Context,\n314\t\t\tabsPath string,\n315\t\t\tcontent []byte,\n316\t\t\tmessage string,\n317\t\t) error\n318\t\t// AtomicReadModifyWriteAndCommitPush reads absPath, calls modify on its contents\n319\t\t// to produce new contents, writes the result, and commits+pushes.\n320\t\t// Atomicity (no interleaving with other writes) is guaranteed by the implementation:\n321\t\t// - gitClient (local-disk): sync.Mutex around the whole sequence.\n322\t\t// - gitRestGitClientAdapter: relies on per-task serialization (Kafka partitioning by task_id).\n323\t\t// modify must return the new file bytes or an error.\n324\t\t// If modify returns an error, the file is not written and no commit is made.\n325\t\tAtomicReadModifyWriteAndCommitPush(\n326\t\t\tctx context.Context,\n327\t\t\tabsPath string,\n328\t\t\tmodify func(current []byte) ([]byte, error),\n329\t\t\tmessage string,\n330\t\t) error\n331\t\t// Path returns the local clone path.\n332\t\tPath() string\n333\t\t// ListFiles returns relative file paths under the repo root matching the single-level\n334\t\t// glob pattern (e.g. \"tasks/*.md\"). Paths are relative to the repo root.\n335\t\tListFiles(ctx context.Context, glob string) ([]string, error)\n336\t\t// ReadFile reads the file at relPath (relative to repo root, e.g. \"tasks/foo.md\")\n337\t\t// and returns its content.\n338\t\tReadFile(ctx context.Context, relPath string) ([]byte, error)\n339\t\t// WriteFile writes content to relPath (relative to repo root) on local disk.\n340\t\t// It does NOT commit or push — use AtomicWriteAndCommitPush for that.\n341\t\tWriteFile(ctx context.Context, relPath string, content []byte) error\n342\t}\n343\t\n344\t// IsReady checks git-rest's /readiness endpoint."}]},"parent_tool_use_id":"call_function_xkxpeuzg3f94_1","session_id":"538dadd3-1411-457f-8798-0759f57847fd","uuid":"032864bf-0e89-45a0-a6cb-a17a20ca4516","timestamp":"2026-07-01T12:10:16.501Z","subagent_type":"dark-factory:prompt-creator","task_description":"Generate prompts from spec"}
