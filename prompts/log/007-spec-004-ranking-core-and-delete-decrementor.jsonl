tifier)\n298\t\t\treturn nil, nil\n299\t\t}\n300\t\tglog.Warningf(\n301\t\t\t\"auto-supersede: read prior %s failed for %s: %v\",\n302\t\t\tpriorRelPath,\n303\t\t\ttaskIdentifier,\n304\t\t\terr,\n305\t\t)\n306\t\treturn nil, err\n307\t}\n308\t\n309\t// priorIsInProgress parses the prior file's frontmatter and reports whether\n310\t// its status is in_progress. Returns false (no-op) on parse error or any\n311\t// non-in_progress status.\n312\tfunc priorIsInProgress(\n313\t\tctx context.Context,\n314\t\tcontent []byte,\n315\t\tpriorRelPath string,\n316\t\ttaskIdentifier lib.TaskIdentifier,\n317\t) bool {\n318\t\tfrontmatterStr, err := result.ExtractFrontmatter(ctx, content)\n319\t\tif err != nil {\n320\t\t\tglog.Warningf(\n321\t\t\t\t\"auto-supersede: extract frontmatter from prior %s failed for %s: %v\",\n322\t\t\t\tpriorRelPath,\n323\t\t\t\ttaskIdentifier,\n324\t\t\t\terr,\n325\t\t\t)\n326\t\t\treturn false\n327\t\t}\n328\t\tpriorFm, err := parseTaskFrontmatter(frontmatterStr)\n329\t\tif err != nil {\n330\t\t\tglog.Warningf(\n331\t\t\t\t\"auto-supersede: parse prior frontmatter %s failed for %s: %v\",\n332\t\t\t\tpriorRelPath,\n333\t\t\t\ttaskIdentifier,\n334\t\t\t\terr,\n335\t\t\t)\n336\t\t\treturn false\n337\t\t}\n338\t\tstatus, _ := priorFm.String(\"status\")\n339\t\tif status != \"in_progress\" {\n340\t\t\tglog.V(3).\n341\t\t\t\tInfof(\"auto-supersede: prior %s status=%q (not in_progress), no-op for %s\", priorRelPath, status, taskIdentifier)\n342\t\t\treturn false\n343\t\t}\n344\t\treturn true\n345\t}\n346\t\n347\t// transitionPrior performs the read-modify-write that transitions the prior\n348\t// file to aborted. Best-effort: write errors are logged and swallowed.\n349\tfunc transitionPrior(\n350\t\tctx context.Context,\n351\t\tgitClient gitclient.GitClient,\n352\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n353\t\tpriorRelPath string,\n354\t\tpriorTitle string,\n355\t\tnewRelPath string,\n356\t\ttaskIdentifier lib.TaskIdentifier,\n357\t) {"}]},"parent_t