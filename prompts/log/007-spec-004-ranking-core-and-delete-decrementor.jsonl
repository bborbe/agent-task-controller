er) {\n246\t\t\treturn\n247\t\t}\n248\t\ttransitionPrior(\n249\t\t\tctx,\n250\t\t\tgitClient,\n251\t\t\tcurrentDateTime,\n252\t\t\tpriorRelPath,\n253\t\t\tpriorTitle,\n254\t\t\tnewRelPath,\n255\t\t\tcmd.TaskIdentifier,\n256\t\t)\n257\t}\n258\t\n259\t// isEligibleForSupersede reports whether cmd is a recurring-task instance\n260\t// that should auto-supersede its prior. Returns true only when created_by is\n261\t// the recurring-task publisher AND auto_abort_prior is explicitly true (opt-in).\n262\t// Returns false (no supersede) when auto_abort_prior is absent or false — the\n263\t// safe default that prevents accidental supersede of audit-style tasks.\n264\tfunc isEligibleForSupersede(cmd task.CreateCommand) bool {\n265\t\tcreatedBy, _ := cmd.Frontmatter.String(\"created_by\")\n266\t\tif createdBy != \"recurring-task-creator\" {\n267\t\t\tglog.V(3).\n268\t\t\t\tInfof(\"auto-supersede: skip %s (created_by=%q != recurring-task-creator)\", cmd.TaskIdentifier, createdBy)\n269\t\t\treturn false"}]},"parent_tool_use_id":null,"session_id":"d6d0dc8f-bae9-47c6-ac4c-413e60eba441","uuid":"b9339186-1ace-40cb-a2aa-d0b9097b804a","timestamp":"2026-07-08T11:31:33.264Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pkg/command/task_create_task_executor.go","content":"\tmaps.Copy(fm, cmd.Frontmatter)\n\tfm[\"task_identifier\"] = string(cmd.TaskIdentifier)\n\treturn marshalFileContent(ctx, fm, cmd.Body)\n}\n\n// supersedePriorRecurringTask transitions the prior-period recurring-task instance\n// to status: aborted after a new instance is materialized. It is a best-effort\n// hook: every failure path (ineligible, no prior, read/parse/write error) is logged\n// and swallowed so the already-written new instance is never rolled back.\n// newRelPath is the repo-root-relative path of the just-written new instance\n// (used as the superseded_by back-pointer).\nfunc supersedePriorRecurringTask(\n\tctx context.Context,\n\tgitClient gitclient.GitClient,\n\ttaskDir string,\n\t