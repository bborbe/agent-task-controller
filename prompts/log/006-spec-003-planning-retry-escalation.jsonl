okeErr := modify(diskContent); invokeErr != nil {\n283\t\t\t\t\t\t\treturn invokeErr\n284\t\t\t\t\t\t}\n285\t\t\t\t\t\treturn nil\n286\t\t\t\t\t}\n287\t\n288\t\t\t\t\tbefore := testutil.ToFloat64(metrics.PlanningRetryTotal.WithLabelValues(\"retry\"))\n289\t\t\t\t\thandled, err := gate.Handle(ctx, req)\n290\t\t\t\t\tExpect(err).To(BeNil())\n291\t\t\t\t\tExpect(handled).To(BeTrue())\n292\t\n293\t\t\t\t\tresultBytes, _ := capturedModify(diskContent)\n294\t\t\t\t\tresultFM, _ := result.ExtractFrontmatter(ctx, resultBytes)\n295\t\t\t\t\tvar fm lib.TaskFrontmatter\n296\t\t\t\t\tExpect(yaml.Unmarshal([]byte(resultFM), &fm)).To(BeNil())\n297\t\t\t\t\tcount, _ := fm.Int(\"planning_retry_count\")\n298\t\t\t\t\tExpect(count).To(Equal(3))\n299\t\n300\t\t\t\t\tbody := string(resultBytes)\n301\t\t\t\t\tExpect(body).To(ContainSubstring(\"retry 3/3:\"))\n302\t\t\t\t\tExpect(\n303\t\t\t\t\t\ttestutil.ToFloat64(\n304\t\t\t\t\t\t\tmetrics.PlanningRetryTotal.WithLabelValues(\"retry\"),\n305\t\t\t\t\t\t) - before,\n306\t\t\t\t\t).To(Equal(1.0))\n307\t\t\t\t})\n308\t\t\t})\n309\t\t})\n310\t\n311\t\tDescribe(\"cap and defensive cases\", func() {\n312\t\t\tContext(\"counter at cap (3) -> passthrough stub\", func() {\n313\t\t\t\tIt(\"returns handled=false and does not write\", func() {\n314\t\t\t\t\treq := buildPRReviewTask(\n315\t\t\t\t\t\t\"pr-123\",\n316\t\t\t\t\t\t\"planning\",\n317\t\t\t\t\t\t\"## Result\\nStatus: failed\\nMessage: boom\\n\",\n318\t\t\t\t\t)\n319\t\t\t\t\tdiskContent := onDiskFile(\"pr-123\", 3, \"## Objective\\n\\nreview the PR\\n\")\n320\t\t\t\t\tfakeGit.ListFilesReturns([]string{\"tasks/pr-123.md\"}, nil)\n321\t\t\t\t\tfakeGit.ReadFileReturns(diskContent, nil)\n322\t\n323\t\t\t\t\tbefore := testutil.ToFloat64(metrics.PlanningRetryTotal.WithLabelValues(\"retry\"))\n324\t\t\t\t\thandled, err := gate.Handle(ctx, req)\n325\t\t\t\t\tExpect(err).To(BeNil())\n326\t\t\t\t\tExpect(handled).To(BeFalse())\n327\t\t\t\t\tExpect(fakeGit.AtomicReadModifyWriteAndCommitPushCallCount()).To(Equal(0))\n328\t\t\t\t\tExpect(\n329\t\t\t\t\t\ttestutil.ToFloat64(\n330\t\t\t\t\t\t\tmetrics.PlanningRetryTotal.WithLabelValues(\"retry\"),\n331\t\t\t\t\t\t) - before,\n332\t\t\t\t\t).To(Equal(0.0))\n333\t\t\t\t})\n334\t\t\t})\n335\t\n336\t\t\tContext(\"defensive counter > 3 -> passthrough\", func() {\n337\t\t\t\tIt(\"returns handled=false and does not write\", func() {\n338\t\t\t\t\treq := buildPRReviewTask(\n339\t\t\t\t\t\t\"pr-123\",\n340\t\t\t\t\t\t\"planning\",\n341\t\t\t\t\t\t\"## Result\\nStatus: failed\\nMessage: boom\\n\",\n342\t\t\t\t\t)\n343\t\t\t\t\tdiskContent := onDiskFile(\"pr-123\", 5, \"## Objective\\n\\nreview the PR\\n\")\n344\t\t\t\t\tfakeGit.ListFilesReturns([]string{\"tasks/pr-123.md\"}, nil)\n345\t\t\t\t\tfakeGit.ReadFileReturns(diskContent, nil)\n346\t\n347\t\t\t\t\tbefore := testutil.ToFloat64(metrics.PlanningRetryTotal.WithLabelValues(\"retry\"))\n348\t\t\t\t\thandled, err := gate.Handle(ctx, req)\n349\t\t\t\t\tExpect(err).To(BeNil())\n350\t\t\t\t\tExpect(handled).To(BeFalse())\n351\t\t\t\t\tExpect(fakeGit.AtomicReadModifyWriteAndCommitPushCallCount()).To(Equal(0))\n352\t\t\t\t\tExpect(\n353\t\t\t\t\t\ttestutil.ToFloat64(\n354\t\t\t\t\t\t\tmetrics.PlanningRetryTotal.WithLabelValues(\"retry\"),\n355\t\t\t\t\t\t) - before,\n356\t\t\t\t\t).To(Equal(0.0))\n357\t\t\t\t})\n358\t\t\t})\n359\t\n360\t\t\tContext(\"defensive negative counter -> clamped to 0, retry attempt 1\", func() {\n361\t\t\t\tIt(\"bumps counter to 1\", func() {\n362\t\t\t\t\treq := buildPRReviewTask(\n363\t\t\t\t\t\t\"pr-123\",\n364\t\t\t\t\t\t\"planning\",\n365\t\t\t\t\t\t\"## Result\\nStatus: failed\\nMessage: boom\\n\",\n366\t\t\t\t\t)\n367\t\t\t\t\tdiskContent := onDiskFile(\"pr-123\", -2, \"## Objective\\n\\nreview the PR\\n\")\n368\t\t\t\t\tfakeGit.ListFilesReturns([]string{\"tasks/pr-123.md\"}, nil)\n369\t\t\t\t\tfakeGit.ReadFileReturns(diskContent, nil)\n370\t\n371\t\t\t\t\tvar capturedModify func([]byte) ([]byte, error)\n372\t\t\t\t\tfakeGit.AtomicReadModifyWriteAndCommitPushStub = func(_ context.Context, _ string, modify func([]byte) ([]byte, error), _ string) error {\n373\t\t\t\t\t\tcapturedModify = modify\n374\t\t\t\t\t\tif _, invokeErr := modify(diskContent); invokeErr != nil {\n375\t\t\t\t\t\t\treturn invokeErr\n376\t\t\t\t\t\t}\n377\t\t\t\t\t\treturn nil\n378\t\t\t\t\t}\n379\t\n380\t\t\t\t\thandled, err := gate.Handle(ctx, req)\n381\t\t\t\t\tExpect(err).To(BeNil())\n382\t\t\t\t\tExpect(handled).To(BeTrue())\n383\t\n384\t\t\t\t\tresultBytes, _ := capturedModify(diskContent)\n385\t\t\t\t\tresultFM, _ := result.ExtractFrontmatter(ctx, resultBytes)\n386\t\t\t\t\tvar fm lib.TaskFrontmatter\n387\t\t\t\t\tExpect(yaml.Unmarshal([]byte(resultFM), &fm)).To(BeNil())\n388\t\t\t\t\tcount, _ := fm.Int(\"planning_retry_count\")\n389\t\t\t\t\tExpect(count).To(Equal(1))\n390\t\t\t\t})\n391\t\t\t})\n392\t\t})\n393\t\n394\t\tDescribe(\"idempotency\", func() {\n395\t\t\tContext(\"redelivery -> concurrent bump detected, no-op\", func() {\n396\t\t\t\tIt(\"returns handled=true but does not increment counter\", func() {\n397\t\t\t\t\treq := buildPRReviewTask(\n398\t\t\t\t\t\t\"pr-123\",\n399\t\t\t\t\t\t\"planning\",\n400\t\t\t\t\t\t\"## Result\\nStatus: failed\\nMessage: boom\\n\",\n401\t\t\t\t\t)\n402\t\t\t\t\t// FindTaskFilePath reads count=0 from disk\n403\t\t\t\t\tdiskContentCount0 := onDiskFile(\"pr-123\", -1, \"## Objective\\n\\nreview the PR\\n\")\n404\t\t\t\t\tfakeGit.ListFilesReturns([]string{\"tasks/pr-123.md\"}, nil)\n405\t\t\t\t\tfakeGit.ReadFileReturns(diskContentCount0, nil)\n406\t\n407\t\t\t\t\t// But the modify closure's re-read sees count=1 (simulating a concurrent bump)\n408\t\t\t\t\tdiskContentCount1 := onDiskFile(\n409\t\t\t\t\t\t\"pr-123\",\n410\t\t\t\t\t\t1,\n411\t\t\t\t\t\t\"## Objective\\n\\nreview the PR\\n\\n## Progress\\n\\n- retry 1/3: boom at 2026-07-01T11:00:00Z\\n\",\n412\t\t\t\t\t)\n413\t\n414\t\t\t\t\tvar capturedModify func([]byte) ([]byte, error)\n415\t\t\t\t\tfakeGit.AtomicReadModifyWriteAndCommitPushStub = func(_ context.Context, _ string, modify func([]byte) ([]byte, error), _ string) error {\n416\t\t\t\t\t\tcapturedModify = modify\n417\t\t\t\t\t\tif _, invokeErr := modify(diskContentCount1); invokeErr != nil {\n418\t\t\t\t\t\t\treturn invokeErr\n419\t\t\t\t\t\t}\n420\t\t\t\t\t\treturn nil\n421\t\t\t\t\t}\n422\t\n423\t\t\t\t\tbefore := testutil.ToFloat64(metrics.PlanningRetryTotal.WithLabelValues(\"retry\"))\n424\t\t\t\t\thandled, err := gate.Handle(ctx, req)\n425\t\t\t\t\tExpect(err).To(BeNil())\n426\t\t\t\t\tExpect(handled).To(BeTrue())\n427\t\n428\t\t\t\t\t// Feed the modify closure the count=1 content (simulating the re-read)\n429\t\t\t\t\tresultBytes, err := capturedModify(diskContentCount1)\n430\t\t\t\t\tExpect(err).To(BeNil())\n431\t\t\t\t\t// Should return unchanged\n432\t\t\t\t\tExpect(string(resultBytes)).To(Equal(string(diskContentCount1)))\n433\t\n434\t\t\t\t\t// No metric increment since bump was false\n435\t\t\t\t\tExpect(\n436\t\t\t\t\t\ttestutil.ToFloat64(\n437\t\t\t\t\t\t\tmetrics.PlanningRetryTotal.WithLabelValues(\"retry\"),\n438\t\t\t\t\t\t) - before,\n439\t\t\t\t\t).To(Equal(0.0))\n440\t\t\t\t})\n441\t\t\t})\n442\t\t})\n443\t\n444\t\tDescribe(\"reason sanitization\", func() {\n445\t\t\tContext(\"reason with newlines and CR stripped\", func() {\n446\t\t\t\tIt(\"produces retry line without literal newlines in reason\", func() {\n447\t\t\t\t\treq := buildPRReviewTask(\n448\t\t\t\t\t\t\"pr-123\",\n449\t\t\t\t\t\t\"planning\",\n450\t\t\t\t\t\t\"## Result\\nStatus: failed\\nMessage: line one\\rline two\\nmore\\n\",\n451\t\t\t\t\t)\n452\t\t\t\t\tdiskContent := onDiskFile(\"pr-123\", -1, \"## Objective\\n\\nreview the PR\\n\")\n453\t\t\t\t\tfakeGit.ListFilesReturns([]string{\"tasks/pr-123.md\"}, nil)\n454\t\t\t\t\tfakeGit.ReadFileReturns(diskContent, nil)\n455\t\n456\t\t\t\t\tvar capturedModify func([]byte) ([]byte, error)\n457\t\t\t\t\tfakeGit.AtomicReadModifyWriteAndCommitPushStub = func(_ context.Context, _ string, modify func([]byte) ([]byte, error), _ string) error {\n458\t\t\t\t\t\tcapturedModify = modify\n459\t\t\t\t\t\tif _, invokeErr := modify(diskContent); invokeErr != nil {\n460\t\t\t\t\t\t\treturn invokeErr\n461\t\t\t\t\t\t}\n462\t\t\t\t\t\treturn nil\n463\t\t\t\t\t}\n464\t\n465\t\t\t\t\t_, err := gate.Handle(ctx, req)\n466\t\t\t\t\tExpect(err).To(BeNil())\n467\t\n468\t\t\t\t\tresultBytes, _ := capturedModify(diskContent)\n469\t\t\t\t\tbody := string(resultBytes)\n470\t\n471\t\t\t\t\tfor _, line := range strings.Split(body, \"\\n\") {\n472\t\t\t\t\t\tif strings.Contains(line, \"retry 1/3:\") {\n473\t\t\t\t\t\t\tExpect(strings.Contains(line, \"\\n\")).To(BeFalse())\n474\t\t\t\t\t\t\tExpect(strings.Contains(line, \"\\r\")).To(BeFalse())\n475\t\t\t\t\t\t}\n476\t\t\t\t\t}\n477\t\t\t\t})\n478\t\t\t})\n479\t\n480\t\t\tContext(\"reason truncated to 200 runes\", func() {\n481\t\t\t\tIt(\"produces reason portion <= 200 runes\", func() {\n482\t\t\t\t\tlongReason := strings.Repeat(\"x\", 300)\n483\t\t\t\t\treq := buildPRReviewTask(\n484\t\t\t\t\t\t\"pr-123\",\n485\t\t\t\t\t\t\"planning\",\n486\t\t\t\t\t\t\"## Result\\nStatus: failed\\nMessage: \"+longReason+\"\\n\",\n487\t\t\t\t\t)\n488\t\t\t\t\tdiskContent := onDiskFile(\"pr-123\", -1, \"## Objective\\n\\nreview the PR\\n\")\n489\t\t\t\t\tfakeGit.ListFilesReturns([]string{\"tasks/pr-123.md\"}, nil)\n490\t\t\t\t\tfakeGit.ReadFileReturns(diskContent, nil)\n491\t\n492\t\t\t\t\tvar capturedModify func([]byte) ([]byte, error)\n493\t\t\t\t\tfakeGit.AtomicReadModifyWriteAndCommitPushStub = func(_ context.Context, _ string, modify func([]byte) ([]byte, error), _ string) error {\n494\t\t\t\t\t\tcapturedModify = modify\n495\t\t\t\t\t\tif _, invokeErr := modify(diskContent); invokeErr != nil {\n496\t\t\t\t\t\t\treturn invokeErr\n497\t\t\t\t\t\t}\n498\t\t\t\t\t\treturn nil\n499\t\t\t\t\t}\n500\t\n501\t\t\t\t\t_, err := gate.Handle(ctx, req)\n502\t\t\t\t\tExpect(err).To(BeNil())\n503\t\n504\t\t\t\t\tresultBytes, _ := capturedModify(diskContent)\n505\t\t\t\t\tbody := string(resultBytes)\n506\t\n507\t\t\t\t\tfor _, line := range strings.Split(body, \"\\n\") {\n508\t\t\t\t\t\tif strings.Contains(line, \"retry 1/3:\") {\n509\t\t\t\t\t\t\t// Extract reason portion: \"retry 1/3: <reason> at <ts>\"\n510\t\t\t\t\t\t\tprefix := \"retry 1/3: \"\n511\t\t\t\t\t\t\tidx := strings.Index(line, prefix)\n512\t\t\t\t\t\t\tif idx >= 0 {\n513\t\t\t\t\t\t\t\treasonPart := line[idx+len(prefix):]\n514\t\t\t\t\t\t\t\tatIdx := strings.Index(reasonPart, \" at \")\n515\t\t\t\t\t\t\t\tif atIdx >= 0 {\n516\t\t\t\t\t\t\t\t\treasonStr := reasonPart[:atIdx]\n517\t\t\t\t\t\t\t\t\tExpect(\n518\t\t\t\t\t\t\t\t\t\tutf8.RuneCountInString(reasonStr),\n519\t\t\t\t\t\t\t\t\t).To(BeNumerically(\"<=\", 200))\n520\t\t\t\t\t\t\t\t}\n521\t\t\t\t\t\t\t}\n522\t\t\t\t\t\t}\n523\t\t\t\t\t}\n524\t\t\t\t})\n525\t\t\t})\n526\t\t})\n527\t})\n528\t"}]},"parent_tool_use_id":null,"session_id":"ff1960e9-a9a4-4d9f-bade-e958adcecf50","uuid":"08912579-432e-424a-8af5-ce44d6dd4a0a","timestamp":"2026-07-01T13:33:24.991Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pkg/command/planning_retry_test.go","content":"// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n// Use of this source code is governed by a BSD-style\n// license that can be found in the LICENSE file.\n\npackage command_test\n\nimport (\n\t\"context\"\n\t\"regexp\"\n\t\"strings\"\n\t\"time\"\n\t\"unicode/utf8\"\n\n\tlib \"github.com/bborbe/agent\"\n\t\"github.com/bborbe/cqrs/base\"\n\tlibtime \"github.com/bborbe/time\"\n\tlibtimemocks \"github.com/bborbe/time/mocks\"\n\t\"github.com/google/uuid\"\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\t\"github.com/prometheus/client_golang/prometheus/testutil\"\n\t\"gopkg.in/yaml.v3\"\n\n\t\"github.com/bborbe/agent-task-controller/mocks\"\n\t\"github.com/bborbe/agent-task-controller/pkg/command\"\n\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n\t\"github.com/bborbe/agent-task-controller/pkg/result\"\n)\n\nvar _ = Describe(\"PlanningRetryGate\", func() {\n\tvar (\n\t\tctx     context.Context\n\t\tfakeGit *mocks.GitClient\n\t\tclock   libtime.CurrentDateTimeGetter\n\t\tgate    command.PlanningRetryGate\n\t\ttaskDir string\n\t)\n\n\tBeforeEach(func() {\n\t\tctx = context.Background()\n\t\tfakeGit = &mocks.GitClient{}\n\t\tclockVal := &libtimemocks.CurrentDateTimeGetter{}\n\t\tclockVal.NowReturns(libtime.DateTime(time.Date(2026, 7, 1, 12, 0, 0, 0, time.UTC)))\n\t\tclock = clockVal\n\t\ttaskDir = \"tasks\"\n\t\tfakeGit.PathReturns(\"/repo\")\n\t\tgate = command.NewPlanningRetryGate(fakeGit, taskDir, clock)\n\t})\n\n\tbuildPRReviewTask := func(taskID string, phaseVal string, content string) lib.Task {\n\t\tnow := libtime.DateTime(time.Date(2026, 7, 1, 10, 0, 0, 0, time.UTC))\n\t\treturn lib.Task{\n\t\t\tObject: base.Object[base.Identifier]{\n\t\t\t\tIdentifier: base.Identifier(taskID),\n\t\t\t\tCreated:    now,\n\t\t\t\tModified:   now,\n\t\t\t},\n\t\t\tTaskIdentifier: lib.TaskIdentifier(taskID),\n\t\t\tFrontmatter: lib.TaskFrontmatter{\n\t\t\t\t\"task_type\": \"pr-review\",\n\t\t\t\t\"phase\":     phaseVal,\n\t\t\t\t\"assignee\":  \"pr-reviewer-agent\",\n\t\t\t},\n\t\t\tContent: lib.TaskContent(content),\n\t\t}\n\t}\n\n\t// onDiskFile creates a task file content. When retryCount < 0, the\n\t// planning_retry_count key is omitted entirely (absent frontmatter state).\n\tonDiskFile := func(taskID string, retryCount int, body string) []byte {\n\t\tfm := map[string]interface{}{\n\t\t\t\"task_identifier\": taskID,\n\t\t\t\"task_type\":       \"pr-review\",\n\t\t\t\"assignee\":        \"pr-reviewer-agent\",\n\t\t\t\"status\":          \"in_progress\",\n\t\t\t\"phase\":           \"planning\",\n\t\t}\n\t\tif retryCount >= 0 {\n\t\t\tfm[\"planning_retry_count\"] = retryCount\n\t\t}\n\t\tfmBytes, _ := yaml.Marshal(fm)\n\t\treturn []byte(\"---\\n\" + string(fmBytes) + \"\\n---\\n\" + body)\n\t}\n\n\tDescribe(\"passthrough cases\", func() {\n\t\tContext(\"non-planning phase\", func() {\n\t\t\tIt(\"returns handled=false and does not write\", func() {\n\t\t\t\treq := buildPRReviewTask(\n\t\t\t\t\t\"pr-123\",\n\t\t\t\t\t\"execution\",\n\t\t\t\t\t\"## Result\\nStatus: failed\\nMessage: boom\\n\",\n\t\t\t\t)\n\t\t\t\tfakeGit.ListFilesReturns([]string{\"tasks/pr-123.md\"}, nil)\n\t\t\t\tfakeGit.ReadFileReturns(\n\t\t\t\t\tonDiskFile(\"pr-123\", 0, \"## Objective\\nreview the PR\\n\"),\n\t\t\t\t\tnil,\n\t\t\t\t)\n\n\t\t\t\tbefore := testutil.ToFloat64(metrics.PlanningRetryTotal.WithLabelValues(\"retry\"))\n\t\t\t\thandled, err := gate.Handle(ctx, req)\n\t\t\t\tExpect(err).To(BeNil())\n\t\t\t\tExpect(handled).To(BeFalse())\n\t\t\t\tExpect(fakeGit.AtomicReadModifyWriteAndCommitPushCallCount()).To(Equal(0))\n\t\t\t\tExpect(\n\t\t\t\t\ttestutil.ToFloat64(\n\t\t\t\t\t\tmetrics.PlanningRetryTotal.WithLabelValues(\"retry\"),\n\t\t\t\t\t) - before,\n\t\t\t\t).To(Equal(0.0))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"non-pr-review task type\", func() {\n\t\t\tIt(\"returns handled=false\", func() {\n\t\t\t\treq := lib.Task{\n\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"task-llm\"),\n\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n\t\t\t\t\t\t\"task_type\": \"llm\",\n\t\t\t\t\t\t\"phase\":     \"planning\",\n\t\t\t\t\t\t\"assignee\":  \"claude\",\n\t\t\t\t\t},\n\t\t\t\t\tContent: lib.TaskContent(\"## Result\\nStatus: failed\\nMessage: boom\\n\"),\n\t\t\t\t}\n\n\t\t\t\tbefore := testutil.ToFloat64(metrics.PlanningRetryTotal.WithLabelValues(\"retry\"))\n\t\t\t\thandled, err := gate.Handle(ctx, req)\n\t\t\t\tExpect(err).To(BeNil())\n\t\t\t\tExpect(handled).To(BeFalse())\n\t\t\t\tExpect(fakeGit.AtomicReadModifyWriteAndCommitPushCallCount()).To(Equal(0))\n\t\t\t\tExpect(\n\t\t\t\t\ttestutil.ToFloat64(\n\t\t\t\t\t\tmetrics.PlanningRetryTotal.WithLabelValues(\"retry\"),\n\t\t\t\t\t) - before,\n\t\t\t\t).To(Equal(0.0))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"success result\", func() {\n\t\t\tIt(\"returns handled=false and does not write\", func() {\n\t\t\t\treq := buildPRReviewTask(\"pr-123\", \"planning\", \