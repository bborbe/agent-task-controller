{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_y4zurz8x3z1b_1","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage command\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"path/filepath\"\n10\t\t\"strconv\"\n11\t\t\"strings\"\n12\t\t\"unicode/utf8\"\n13\t\n14\t\tlib \"github.com/bborbe/agent\"\n15\t\t\"github.com/bborbe/errors\"\n16\t\tlibtime \"github.com/bborbe/time\"\n17\t\tdomain \"github.com/bborbe/vault-cli/pkg/domain\"\n18\t\t\"github.com/golang/glog\"\n19\t\t\"github.com/google/uuid\"\n20\t\t\"gopkg.in/yaml.v3\"\n21\t\n22\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n23\t\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n24\t\t\"github.com/bborbe/agent-task-controller/pkg/result\"\n25\t)\n26\t\n27\t// maxControllerPlanningRetries is the frozen cap on controller-side planning\n28\t// retries. Invariant per spec 003 — never an env var, CLI flag, config field,\n29\t// or CRD field.\n30\tconst maxControllerPlanningRetries = 3\n31\t\n32\t//counterfeiter:generate -o ../../mocks/planning_retry_gate.go --fake-name PlanningRetryGate . PlanningRetryGate\n33\t\n34\t// PlanningRetryGate decides whether a failed pr-review planning result should be\n35\t// retried controller-side. Handle inspects the incoming result and the on-disk\n36\t// task state and, when the retry gate matches, performs the retry write (counter\n37\t// bump + ## Progress append + phase reset + fresh task_identifier) and returns\n38\t// handled=true. When the gate does not match (non-pr-review, non-planning,\n39\t// success/skipped, no failure marker, or counter already at cap in this prompt),\n40\t// it returns handled=false and the caller falls through to the default\n41\t// WriteResult path.\n42\ttype PlanningRetryGate interface {\n43\t\tHandle(ctx context.Context, req lib.Task) (handled bool, err error)\n44\t}\n45\t\n46\t// NewPlanningRetryGate constructs the gate.\n47\tfunc NewPlanningRetryGate(\n48\t\tgitClient gitclient.GitClient,\n49\t\ttaskDir string,\n50\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n51\t) PlanningRetryGate {\n52\t\treturn &planningRetryGate{\n53\t\t\tgitClient:       gitClient,\n54\t\t\ttaskDir:         taskDir,\n55\t\t\tcurrentDateTime: currentDateTime,\n56\t\t}\n57\t}\n58\t\n59\ttype planningRetryGate struct {\n60\t\tgitClient       gitclient.GitClient\n61\t\ttaskDir         string\n62\t\tcurrentDateTime libtime.CurrentDateTimeGetter\n63\t}\n64\t\n65\tfunc (g *planningRetryGate) Handle(ctx context.Context, req lib.Task) (handled bool, err error) {\n66\t\tif !g.matchesRetryGate(req) {\n67\t\t\treturn false, nil\n68\t\t}\n69\t\n70\t\trelPath, existingFrontmatter, findErr := result.FindTaskFilePath(\n71\t\t\tctx, g.gitClient, g.taskDir, req.TaskIdentifier,\n72\t\t)\n73\t\tif findErr != nil {\n74\t\t\treturn false, errors.Wrapf(ctx, findErr, \"planning-retry: find task file\")\n75\t\t}\n76\t\tif relPath == \"\" {\n77\t\t\tglog.Warningf(\"planning-retry: task file not found for %s; skipping\", req.TaskIdentifier)\n78\t\t\treturn false, nil\n79\t\t}\n80\t\n81\t\tcount, _ := existingFrontmatter.Int(\"planning_retry_count\")\n82\t\tif count < 0 {\n83\t\t\tcount = 0\n84\t\t}\n85\t\n86\t\tif count >= maxControllerPlanningRetries {\n87\t\t\tglog.V(2).\n88\t\t\t\tInfof(\"planning-retry: counter at cap (%d) for %s; exhaustion escalation ships in prompt 2, falling through\", count, req.TaskIdentifier)\n89\t\t\treturn false, nil\n90\t\t}\n91\t\n92\t\treason := g.extractReason(string(req.Content))\n93\t\tbump := false\n94\t\tts := g.currentDateTime.Now().UTC().Format(\"2006-01-02T15:04:05Z07:00\")\n95\t\n96\t\tmsg := \"[agent-task-controller] planning retry \" + strconv.Itoa(\n97\t\t\tcount+1,\n98\t\t) + \"/3 for task \" + string(\n99\t\t\treq.TaskIdentifier,\n100\t\t)\n101\t\tabsPath := filepath.Join(g.gitClient.Path(), relPath)\n102\t\n103\t\tmodifyErr := g.gitClient.AtomicReadModifyWriteAndCommitPush(\n104\t\t\tctx, absPath, g.buildRetryModifyFn(ctx, count, reason, ts, &bump), msg,\n105\t\t)\n106\t\tif modifyErr != nil {\n107\t\t\treturn false, errors.Wrapf(\n108\t\t\t\tctx,\n109\t\t\t\tmodifyErr,\n110\t\t\t\t\"planning-retry: write retry for task %s\",\n111\t\t\t\treq.TaskIdentifier,\n112\t\t\t)\n113\t\t}\n114\t\n115\t\tif bump {\n116\t\t\tmetrics.PlanningRetryTotal.WithLabelValues(\"retry\").Inc()\n117\t\t\tglog.Infof(\n118\t\t\t\t\"planning-retry: attempt %d/3 for task %s (reason=%q)\",\n119\t\t\t\tcount+1,\n120\t\t\t\treq.TaskIdentifier,\n121\t\t\t\treason,\n122\t\t\t)\n123\t\t}\n124\t\treturn true, nil\n125\t}\n126\t\n127\tfunc (g *planningRetryGate) matchesRetryGate(req lib.Task) bool {\n128\t\ttaskType := req.Frontmatter.TaskType()\n129\t\tif taskType != lib.TaskTypePRReview &&\n130\t\t\treq.Frontmatter.Assignee() != lib.TaskAssignee(\"pr-reviewer-agent\") {\n131\t\t\tglog.V(3).\n132\t\t\t\tInfof(\"planning-retry: task %s is not pr-review (task_type=%q, assignee=%q); skipping gate\", req.TaskIdentifier, taskType, req.Frontmatter.Assignee())\n133\t\t\treturn false\n134\t\t}\n135\t\tphase := req.Frontmatter.Phase()\n136\t\tif phase == nil || phase.String() != domain.TaskPhasePlanning.String() {\n137\t\t\tglog.V(3).\n138\t\t\t\tInfof(\"planning-retry: task %s phase is not planning; skipping gate\", req.TaskIdentifier)\n139\t\t\treturn false\n140\t\t}\n141\t\tif !hasFailureMarker(string(req.Content)) {\n142\t\t\tglog.V(2).\n143\t\t\t\tInfof(\"planning-retry: no failure signal; skipping retry gate for task %s\", req.TaskIdentifier)\n144\t\t\treturn false\n145\t\t}\n146\t\treturn true\n147\t}\n148\t\n149\tfunc hasFailureMarker(content string) bool {\n150\t\tfor _, line := range strings.Split(content, \"\\n\") {\n151\t\t\tif strings.HasPrefix(strings.TrimSpace(line), \"Status: failed\") {\n152\t\t\t\treturn true\n153\t\t\t}\n154\t\t}\n155\t\treturn false\n156\t}\n157\t\n158\tfunc (g *planningRetryGate) extractReason(content string) string {\n159\t\tafterMarker := false\n160\t\tfor _, line := range strings.Split(content, \"\\n\") {\n161\t\t\ttrimmed := strings.TrimSpace(line)\n162\t\t\tif afterMarker {\n163\t\t\t\tif trimmed != \"\" {\n164\t\t\t\t\treturn sanitizeReason(trimmed)\n165\t\t\t\t}\n166\t\t\t}\n167\t\t\tif strings.HasPrefix(trimmed, \"Status: failed\") {\n168\t\t\t\tafterMarker = true\n169\t\t\t}\n170\t\t}\n171\t\treturn sanitizeReason(strings.TrimSpace(content))\n172\t}\n173\t\n174\tfunc sanitizeReason(raw string) string {\n175\t\tvar builder strings.Builder\n176\t\tfor _, r := range raw {\n177\t\t\tif r == '\\r' || r == '\\n' {\n178\t\t\t\tbuilder.WriteRune(' ')\n179\t\t\t\tcontinue\n180\t\t\t}\n181\t\t\tif r < 0x20 && r != ' ' {\n182\t\t\t\tcontinue\n183\t\t\t}\n184\t\t\tbuilder.WriteRune(r)\n185\t\t}\n186\t\tsanitized := strings.TrimSpace(builder.String())\n187\t\tif utf8.RuneCountInString(sanitized) > 200 {\n188\t\t\treturn string([]rune(sanitized)[:200])\n189\t\t}\n190\t\treturn sanitized\n191\t}\n192\t\n193\tfunc (g *planningRetryGate) buildRetryModifyFn(\n194\t\tctx context.Context,\n195\t\tcount int,\n196\t\treason string,\n197\t\tts string,\n198\t\tbump *bool,\n199\t) func(current []byte) ([]byte, error) {\n200\t\treturn func(current []byte) ([]byte, error) {\n201\t\t\t*bump = false\n202\t\t\tfmStr, err := result.ExtractFrontmatter(ctx, current)\n203\t\t\tif err != nil {\n204\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract frontmatter\")\n205\t\t\t}\n206\t\t\tbody, err := result.ExtractBody(ctx, current)\n207\t\t\tif err != nil {\n208\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract body\")\n209\t\t\t}\n210\t\t\tvar fm lib.TaskFrontmatter\n211\t\t\tif err := yaml.Unmarshal([]byte(fmStr), &fm); err != nil {\n212\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"unmarshal frontmatter\")\n213\t\t\t}\n214\t\n215\t\t\tonDiskCount, _ := fm.Int(\"planning_retry_count\")\n216\t\t\tif onDiskCount != count {\n217\t\t\t