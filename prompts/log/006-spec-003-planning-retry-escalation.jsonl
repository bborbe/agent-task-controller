{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_y4zurz8x3z1b_6","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage metrics\n6\t\n7\timport (\n8\t\t\"github.com/prometheus/client_golang/prometheus\"\n9\t\t\"github.com/prometheus/client_golang/prometheus/promauto\"\n10\t)\n11\t\n12\t//go:generate go run github.com/maxbrunsfeld/counterfeiter/v6 -generate\n13\t//counterfeiter:generate -o ../../mocks/metrics.go --fake-name Metrics . Metrics\n14\t\n15\t// Metrics defines the interface for accessing Prometheus metrics.\n16\t// Use this interface in business logic packages to enable mock injection in tests.\n17\ttype Metrics interface {\n18\t\tScanCyclesTotal(outcome string) prometheus.Counter\n19\t\tTasksPublishedTotal(outcome string) prometheus.Counter\n20\t\tResultsWrittenTotal(outcome string) prometheus.Counter\n21\t\tGitPushTotal(outcome string) prometheus.Counter\n22\t\tConflictResolutionsTotal() prometheus.Counter\n23\t\tFrontmatterCommandsTotal(operation, outcome string) prometheus.Counter\n24\t\tGitRestCallsTotal(operation, status string) prometheus.Counter\n25\t\tKafkaConsumePausedTotal() prometheus.Counter\n26\t\tSkippedFilesTotal(reason string) prometheus.Counter\n27\t}\n28\t\n29\t// defaultMetrics implements Metrics using promauto-registered counters.\n30\ttype defaultMetrics struct{}\n31\t\n32\tvar _ Metrics = &defaultMetrics{}\n33\t\n34\t// New returns a new default Metrics implementation.\n35\tfunc New() Metrics {\n36\t\treturn &defaultMetrics{}\n37\t}\n38\t\n39\tfunc (m *defaultMetrics) ScanCyclesTotal(outcome string) prometheus.Counter {\n40\t\treturn ScanCyclesTotal.WithLabelValues(outcome)\n41\t}\n42\t\n43\tfunc (m *defaultMetrics) TasksPublishedTotal(outcome string) prometheus.Counter {\n44\t\treturn TasksPublishedTotal.WithLabelValues(outcome)\n45\t}\n46\t\n47\tfunc (m *defaultMetrics) ResultsWrittenTotal(outcome string) prometheus.Counter {\n48\t\treturn ResultsWrittenTotal.WithLabelValues(outcome)\n49\t}\n50\t\n51\tfunc (m *defaultMetrics) GitPushTotal(outcome string) prometheus.Counter {\n52\t\treturn GitPushTotal.WithLabelValues(outcome)\n53\t}\n54\t\n55\tfunc (m *defaultMetrics) ConflictResolutionsTotal() prometheus.Counter {\n56\t\treturn ConflictResolutionsTotal.WithLabelValues()\n57\t}\n58\t\n59\tfunc (m *defaultMetrics) FrontmatterCommandsTotal(operation, outcome string) prometheus.Counter {\n60\t\treturn FrontmatterCommandsTotal.WithLabelValues(operation, outcome)\n61\t}\n62\t\n63\tfunc (m *defaultMetrics) GitRestCallsTotal(operation, status string) prometheus.Counter {\n64\t\treturn GitRestCallsTotal.WithLabelValues(operation, status)\n65\t}\n66\t\n67\tfunc (m *defaultMetrics) KafkaConsumePausedTotal() prometheus.Counter {\n68\t\treturn KafkaConsumePausedTotal\n69\t}\n70\t\n71\tfunc (m *defaultMetrics) SkippedFilesTotal(reason string) prometheus.Counter {\n72\t\treturn SkippedFilesTotal.WithLabelValues(reason)\n73\t}\n74\t\n75\t// ScanCyclesTotal counts scan cycle completions by result.\n76\tvar ScanCyclesTotal = promauto.NewCounterVec(\n77\t\tprometheus.CounterOpts{\n78\t\t\tName: \"agent_controller_scan_cycles_total\",\n79\t\t\tHelp: \"Total number of scan cycles completed.\",\n80\t\t},\n81\t\t[]string{\"result\"},\n82\t)\n83\t\n84\t// TasksPublishedTotal counts task events published by type.\n85\tvar TasksPublishedTotal = promauto.NewCounterVec(\n86\t\tprometheus.CounterOpts{\n87\t\t\tName: \"agent_controller_tasks_published_total\",\n88\t\t\tHelp: \"Total number of task events published.\",\n89\t\t},\n90\t\t[]string{\"type\"},\n91\t)\n92\t\n93\t// PlanningRetryTotal counts controller-side pr-review planning-retry gate outcomes\n94\t// by result (\"retry\" | \"exhausted\"). \"passthrough\" is intentionally NOT a label —\n95\t// the metric fires only when the retry gate matches (spec DB 7).\n96\tvar 