rVec(\n144\t\tprometheus.CounterOpts{\n145\t\t\tName: \"agent_controller_git_rest_calls_total\",\n146\t\t\tHelp: \"Total number of git-rest HTTP API calls by operation and outcome.\",\n147\t\t},\n148\t\t[]string{\"op\", \"status\"},\n149\t)\n150\t\n151\t// KafkaConsumePausedTotal counts times a Kafka command executor blocked\n152\t// waiting for git-rest to become available (i.e. retry attempts after the first).\n153\tvar KafkaConsumePausedTotal = promauto.NewCounter(prometheus.CounterOpts{\n154\t\tName: \"controller_kafka_consume_paused_total\",\n155\t\tHelp: \"Total number of times Kafka consumption was paused waiting for git-rest.\",\n156\t})\n157\t\n158\tconst (\n159\t\tReasonInvalidFrontmatter          = \"invalid_frontmatter\"\n160\t\tReasonDuplicateFrontmatterInvalid = \"duplicate_frontmatter_invalid\"\n161\t\tReasonEmptyStatus                 = \"empty_status\"\n162\t\tReasonInjectTaskIdentifierFailed  = \"inject_task_identifier_failed\"\n163\t\tReasonReadFailed                  = \"read_failed\"\n164\t\tReasonAutoInjectDisabled          = \"auto_inject_disabled\"\n165\t)\n166\t\n167\t// SkippedFilesTotal counts vault task files the scanner skipped during a scan cycle,\n168\t// labelled by the structured reason for the skip. A non-zero value on any label\n169\t// indicates operator-actionable vault health issues (broken frontmatter, empty status,\n170\t// unreadable files, injection failures); a stuck broken file will keep the relevant\n171\t// label rate-positive until repaired. The closed set of reason values is declared\n172\t// as constants above and pre-initialised in init().\n173\tvar SkippedFilesTotal = promauto.NewCounterVec(\n174\t\tprometheus.CounterOpts{\n175\t\t\tName: \"agent_controller_vault_scanner_skipped_files_total\",\n176\t\t\tHelp: \"Total number of vault task files the scanner skipped during a scan cycle, by reason. Increments exactly once per skipped file per cycle — re-scans of an unrepaired broken file keep the rate positive.\",\n177\