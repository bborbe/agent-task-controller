ct: base.Object[base.Identifier]{\n54\t\t\t\t\tIdentifier: base.Identifier(taskID),\n55\t\t\t\t\tCreated:    now,\n56\t\t\t\t\tModified:   now,\n57\t\t\t\t},\n58\t\t\t\tTaskIdentifier: lib.TaskIdentifier(taskID),\n59\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n60\t\t\t\t\t\"task_type\": \"pr-review\",\n61\t\t\t\t\t\"phase\":     phaseVal,\n62\t\t\t\t\t\"assignee\":  \"pr-reviewer-agent\",\n63\t\t\t\t},\n64\t\t\t\tContent: lib.TaskContent(content),\n65\t\t\t}\n66\t\t}\n67\t\n68\t\t// onDiskFile creates a task file content. When retryCount < 0, the\n69\t\t// planning_retry_count key is omitted entirely (absent frontmatter state).\n70\t\tonDiskFile := func(taskID string, retryCount int, body string) []byte {\n71\t\t\tfm := map[string]interface{}{\n72\t\t\t\t\"task_identifier\": taskID,\n73\t\t\t\t\"task_type\":       \"pr-review\",\n74\t\t\t\t\"assignee\":        \"pr-reviewer-agent\",\n75\t\t\t\t\"status\":          \"in_progress\",\n76\t\t\t\t\"phase\":           \"planning\",\n77\t\t\t}\n78\t\t\tif retryCount >= 0 {\n79\t\t\t\tfm[\"planning_retry_count\"] = retryCount\n80\t\t\t}\n81\t\t\tfmBytes, _ := yaml.Marshal(fm)\n82\t\t\treturn []byte(\"---\\n\" + string(fmBytes) + \"\\n---\\n\" + body)\n83\t\t}\n84\t\n85\t\tDescribe(\"passthrough cases\", func() {\n86\t\t\tContext(\"non-planning phase\", func() {\n87\t\t\t\tIt(\"returns handled=false and does not write\", func() {\n88\t\t\t\t\treq := buildPRReviewTask(\n89\t\t\t\t\t\t\"pr-123\",\n90\t\t\t\t\t\t\"execution\",\n91\t\t\t\t\t\t\"## Result\\nStatus: failed\\nMessage: boom\\n\",\n92\t\t\t\t\t)\n93\t\t\t\t\tfakeGit.ListFilesReturns([]string{\"tasks/pr-123.md\"}, nil)\n94\t\t\t\t\tfakeGit.ReadFileReturns(\n95\t\t\t\t\t\tonDiskFile(\"pr-123\", 0, \"## Objective\\nreview the PR\\n\"),\n96\t\t\t\t\t\tnil,\n97\t\t\t\t\t)\n98\t\n99\t\t\t\t\tbefore := testutil.ToFloat64(metrics.PlanningRetryTotal.WithLabelValues(\"retry\"))\n100\t\t\t\t\thandled, err := gate.Handle(ctx, req)\n101\t\t\t\t\tExpect(err).To(BeNil())\n102\t\t\t\t