nless a test overrides ReadFile.\n59\t\t\tfakeGit.ReadFileReturns(nil, errors.New(\"GET file returned 404: not found\"))\n60\t\n61\t\t\tclock = &libtimemocks.CurrentDateTimeGetter{}\n62\t\t\tclock.NowReturns(libtime.DateTime(time.Date(2026, 6, 15, 10, 0, 0, 0, time.UTC)))\n63\t\n64\t\t\texecutor = command.NewCreateTaskExecutor(fakeGit, taskDir, \"openclaw\", clock)\n65\t\t\tschemaID = cdb.SchemaID{Group: \"agent\", Kind: \"task\", Version: \"v1\"}\n66\t\t})\n67\t\n68\t\tAfterEach(func() {\n69\t\t\tExpect(os.RemoveAll(tmpDir)).To(Succeed())\n70\t\t})\n71\t\n72\t\tbuildCmdObj := func(cmd task.CreateCommand) cdb.CommandObject {\n73\t\t\tevent, err := base.ParseEvent(ctx, cmd)\n74\t\t\tExpect(err).NotTo(HaveOccurred())\n75\t\t\treturn cdb.CommandObject{\n76\t\t\t\tCommand: base.Command{\n77\t\t\t\t\tRequestID: base.NewRequestID(),\n78\t\t\t\t\tOperation: task.CreateCommandOperation,\n79\t\t\t\t\tInitiator: \"test\",\n80\t\t\t\t\tData:      event,\n81\t\t\t\t},\n82\t\t\t\tSchemaID: schemaID,\n83\t\t\t}\n84\t\t}\n85\t\n86\t\tDescribe(\"CommandOperation\", func() {\n87\t\t\tIt(\"returns create-task\", func() {\n88\t\t\t\tExpect(executor.CommandOperation()).To(Equal(base.CommandOperation(\"create-task\")))\n89\t\t\t})\n90\t\t})\n91\t\n92\t\tDescribe(\"HandleCommand\", func() {\n93\t\t\tContext(\"malformed command payload\", func() {\n94\t\t\t\tIt(\"returns ErrCommandObjectSkipped without writing\", func() {\n95\t\t\t\t\t// A channel is not JSON-marshalable, so MarshalInto will fail.\n96\t\t\t\t\tcmdObj := cdb.CommandObject{\n97\t\t\t\t\t\tCommand: base.Command{\n98\t\t\t\t\t\t\tRequestID: base.NewRequestID(),\n99\t\t\t\t\t\t\tOperation: task.CreateCommandOperation,\n100\t\t\t\t\t\t\tInitiator: \"test\",\n101\t\t\t\t\t\t\tData:      base.Event{\"taskIdentifier\": make(chan int)},\n102\t\t\t\t\t\t},\n103\t\t\t\t\t\tSchemaID: schemaID,\n104\t\t\t\t\t}\n105\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n106\t\t\t\t\tExpect(err).To(HaveOccurred())\n107\t\t\t\t\tExpect(errors.Is(err, cdb.ErrCommandObjectSkipped)).To(BeTrue())\n108\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n109\t\t\t\t})\n110\t\t\t})\n111\t\n112\t\t\tContext(\"empty TaskIdentifier\", func() {\n113\t\t\t\tIt(\"returns a validation error without writing\", func() {\n114\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n115\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"\"),\n116\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n117\t\t\t\t\t\t\t\"assignee\": \"claude\",\n118\t\t\t\t\t\t\t\"status\":   \"next\",\n119\t\t\t\t\t\t},\n120\t\t\t\t\t})\n121\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n122\t\t\t\t\tExpect(err).To(HaveOccurred())\n123\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n124\t\t\t\t})\n125\t\t\t})\n126\t\n127\t\t\tContext(\"missing assignee in frontmatter\", func() {\n128\t\t\t\tIt(\"returns a validation error without writing\", func() {\n129\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n130\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"my-task-id\"),\n131\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n132\t\t\t\t\t\t\t\"status\": \"next\",\n133\t\t\t\t\t\t},\n134\t\t\t\t\t})\n135\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n136\t\t\t\t\tExpect(err).To(HaveOccurred())\n137\t\t\t\t\tExpect(err.Error()).To(ContainSubstring(\"assignee\"))\n138\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n139\t\t\t\t})\n140\t\t\t})\n141\t\n142\t\t\tContext(\"missing status in frontmatter\", func() {\n143\t\t\t\tIt(\"returns a validation error without writing\", func() {\n144\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n145\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"my-task-id\"),\n146\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n147\t\t\t\t\t\t\t\"assignee\": \"claude\",\n148\t\t\t\t\t\t},\n149\t\t\t\t\t})\n150\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n151\t\t\t\t\tExpect(err).To(HaveOccurred())\n152\t\t\t\t\tExpect(err.Error()).To(ContainSubstring(\"status\"))\n153\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n154\t\t\t\t})\n155\t\t\t})\n156\t\n157\t\t\tContext(\"title path already occupied (collision)\", func() {\n158\t\t\t\tIt(\"returns ErrTaskAlreadyExists and does not write (AC2)\", func() {\n159\t\t\t\t\t// Second ReadFile call returns existing content → collision on replay.\n160\t\t\t\t\tfakeGit.ReadFileReturnsOnCall(0,\n161\t\t\t\t\t\tnil, errors.New(\"GET 24 Tasks/Replay Task.md returned 404: not found\"))\n162\t\t\t\t\tfakeGit.ReadFileReturnsOnCall(\n163\t\t\t\t\t\t1,\n164\t\t\t\t\t\t[]byte(\n165\t\t\t\t\t\t\t\"---\\ntask_identifier: replay-task\\nassignee: claude\\nstatus: next\\n---\\n\",\n166\t\t\t\t\t\t),\n167\t\t\t\t\t\tnil,\n168\t\t\t\t\t)\n169\t\n170\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n171\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"replay-task\"),\n172\t\t\t\t\t\tTitle:          \"Replay Task\",\n173\t\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\", \"status\": \"next\"},\n174\t\t\t\t\t})\n175\t\n176\t\t\t\t\t// First create: file not found → writes.\n177\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n178\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n179\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n180\t\n181\t\t\t\t\t// Replay: file now exists → sentinel, no second write.\n182\t\t\t\t\t_, _, err = executor.HandleCommand(ctx, nil, cmdObj)\n183\t\t\t\t\tExpect(err).To(HaveOccurred())\n184\t\t\t\t\tExpect(errors.Is(err, task.ErrTaskAlreadyExists)).To(BeTrue())\n185\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1)) // still 1\n186\t\t\t\t})\n187\t\t\t})\n188\t\n189\t\t\tContext(\"new filename\", func() {\n190\t\t\t\tIt(\"writes exactly once and returns nil when ReadFile reports not-found (AC3)\", func() {\n191\t\t\t\t\tfakeGit.ReadFileReturns(\n192\t\t\t\t\t\tnil,\n193\t\t\t\t\t\terrors.New(\"GET 24 Tasks/Brand New.md returned 404: not found\"),\n194\t\t\t\t\t)\n195\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n196\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"brand-new\"),\n197\t\t\t\t\t\tTitle:          \"Brand New\",\n198\t\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\", \"status\": \"next\"},\n199\t\t\t\t\t})\n200\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n201\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n202\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n203\t\t\t\t})\n204\t\t\t})\n205\t\n206\t\t\tContext(\"collision with a different task_identifier\", func() {\n207\t\t\t\tIt(\"returns ErrTaskAlreadyExists and does not write (AC4)\", func() {\n208\t\t\t\t\t// Existing file at the title path belongs to a DIFFERENT task — filename owns the\n209\t\t\t\t\t// slot; the executor must not consult frontmatter, must not write.\n210\t\t\t\t\tfakeGit.ReadFileReturns(\n211\t\t\t\t\t\t[]byte(\n212\t\t\t\t\t\t\t\"---\\ntask_identifier: someone-else\\nassignee: alice\\nstatus: todo\\n---\\n\",\n213\t\t\t\t\t\t),\n214\t\t\t\t\t\tnil,\n215\t\t\t\t\t)\n216\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n217\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"new-task-id\"),\n218\t\t\t\t\t\tTitle:          \"My Colliding Task\",\n219\t\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\", \"status\": \"next\"},\n220\t\t\t\t\t})\n221\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n222\t\t\t\t\tExpect(err).To(HaveOccurred())\n223\t\t\t\t\tExpect(errors.Is(err, task.ErrTaskAlreadyExists)).To(BeTrue())\n224\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n225\t\t\t\t})\n226\t\t\t})\n227\t\n228\t\t\tContext(\"transient git-rest read error\", func() {\n229\t\t\t\tIt(\"propagates the wrapped error and does not write (AC5)\", func() {\n230\t\t\t\t\tfakeGit.ReadFileReturns(\n231\t\t\t\t\t\tnil,\n232\t\t\t\t\t\terrors.New(\"GET 24 Tasks/Flaky.md returned 503: service unavailable\"),\n233\t\t\t\t\t)\n234\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n235\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"flaky-task\"),\n236\t\t\t\t\t\tTitle:          \"Flaky\",\n237\t\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\", \"status\": \"next\"},\n238\t\t\t\t\t})\n239\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n240\t\t\t\t\tExpect(err).To(HaveOccurred())\n241\t\t\t\t\tExpect(errors.Is(err, task.ErrTaskAlreadyExists)).To(BeFalse())\n242\t\t\t\t\tExpect(err.Error()).To(ContainSubstring(\"503\"))\n243\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n244\t\t\t\t})\n245\t\t\t})\n246\t\n247\t\t\tContext(\"success: new file created\", func() {\n248\t\t\t\tIt(\"calls AtomicWriteAndCommitPush with correct content and commit message\", func() {\n249\t\t\t\t\ttaskID := lib.TaskIdentifier(\"new-task-abc\")\n250\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n251\t\t\t\t\t\tTaskIdentifier: taskID,\n252\t\t\t\t\t\tTitle:          \"New Task ABC\",\n253\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n254\t\t\t\t\t\t\t\"assignee\": \"claude\",\n255\t\t\t\t\t\t\t\"status\":   \"next\",\n256\t\t\t\t\t\t},\n257\t\t\t\t\t\tBody: \"This is the task body.\\n\",\n258\t\t\t\t\t})\n259\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n260\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n261\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n262\t\n263\t\t\t\t\t_, absPath, content, message := fakeGit.AtomicWriteAndCommitPushArgsForCall(0)\n264\t\t\t\t\tExpect(absPath).To(HaveSuffix(\"New Task ABC.md\"))\n265\t\t\t\t\tExpect(message).To(ContainSubstring(string(taskID)))\n266\t\n267\t\t\t\t\tcontentStr := string(content)\n268\t\t\t\t\tExpect(contentStr).To(HavePrefix(\"---\\n\"))\n269\t\t\t\t\tExpect(strings.Count(contentStr, \"---\")).To(BeNumerically(\">=\", 2))\n270\t\t\t\t\tExpect(contentStr).To(ContainSubstring(\"task_identifier:\"))\n271\t\t\t\t\tExpect(contentStr).To(ContainSubstring(\"assignee:\"))\n272\t\t\t\t\tExpect(contentStr).To(ContainSubstring(\"status:\"))\n273\t\t\t\t\tExpect(contentStr).To(ContainSubstring(\"This is the task body.\"))\n274\t\t\t\t})\n275\t\t\t})\n276\t\n277\t\t\tContext(\"git write error\", func() {\n278\t\t\t\tIt(\"returns a wrapped error when AtomicWriteAndCommitPush fails\", func() {\n279\t\t\t\t\tfakeGit.AtomicWriteAndCommitPushStub = nil\n280\t\t\t\t\tfakeGit.AtomicWriteAndCommitPushReturns(errors.New(\"git push failed\"))\n281\t\n282\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n283\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"error-task\"),\n284\t\t\t\t\t\tTitle:          \"Error Task\",\n285\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n286\t\t\t\t\t\t\t\"assignee\": \"claude\",\n287\t\t\t\t\t\t\t\"status\":   \"next\",\n288\t\t\t\t\t\t},\n289\t\t\t\t\t})\n290\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n291\t\t\t\t\tExpect(err).To(HaveOccurred())\n292\t\t\t\t\tExpect(err.Error()).To(ContainSubstring(\"git push failed\"))\n293\t\t\t\t})\n294\t\t\t})\n295\t\n296\t\t\tContext(\"valid title\", func() {\n297\t\t\t\tIt(\"writes the task file at tasks/{title}.md\", func() {\n298\t\t\t\t\ttaskID := lib.TaskIdentifier(\"uuid-1234\")\n299\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n300\t\t\t\t\t\tTaskIdentifier: taskID,\n301\t\t\t\t\t\tTitle:          \"My Feature Task\",\n302\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n303\t\t\t\t\t\t\t\"assignee\": \"claude\",\n304\t\t\t\t\t\t\t\"status\":   \"next\",\n305\t\t\t\t\t\t},\n306\t\t\t\t\t\tBody: \"Task description.\\n\",\n307\t\t\t\t\t})\n308\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n309\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n310\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n311\t\t\t\t\t_, absPath, _, _ := fakeGit.AtomicWriteAndCommitPushArgsForCall(0)\n312\t\t\t\t\tExpect(absPath).To(HaveSuffix(\"My Feature Task.md\"))\n313\t\t\t\t\tExpect(absPath).NotTo(ContainSubstring(string(taskID)))\n314\t\t\t\t})\n315\t\t\t})\n316\t\n317\t\t\tContext(\"invalid title (contains forbidden char)\", func() {\n318\t\t\t\tIt(\"logs WARN and writes the task file at tasks/{task_identifier}.md\", func() {\n319\t\t\t\t\ttaskID := lib.TaskIdentifier(\"uuid-5678\")\n320\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n321\t\t\t\t\t\tTaskIdentifier: taskID,\n322\t\t\t\t\t\tTitle:          \"bad/title\",\n323\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n324\t\t\t\t\t\t\t\"assignee\": \"claude\",\n325\t\t\t\t\t\t\t\"status\":   \"next\",\n326\t\t\t\t\t\t},\n327\t\t\t\t\t})\n328\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n329\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n330\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n331\t\t\t\t\t_, absPath, _, _ := fakeGit.AtomicWriteAndCommitPushArgsForCall(0)\n332\t\t\t\t\tExpect(absPath).To(HaveSuffix(string(taskID) + \".md\"))\n333\t\t\t\t})\n334\t\t\t})\n335\t\n336\t\t\tContext(\"empty title\", func() {\n337\t\t\t\tIt(\"logs WARN and writes the task file at tasks/{task_identifier}.md\", func() {\n338\t\t\t\t\ttaskID := lib.TaskIdentifier(\"uuid-empty-title\")\n339\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n340\t\t\t\t\t\tTaskIdentifier: taskID,\n341\t\t\t\t\t\tTitle:          \"\",\n342\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n343\t\t\t\t\t\t\t\"assignee\": \"claude\",\n344\t\t\t\t\t\t\t\"status\":   \"next\",\n345\t\t\t\t\t\t},\n346\t\t\t\t\t})\n347\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n348\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n349\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n350\t\t\t\t\t_, absPath, _, _ := fakeGit.AtomicWriteAndCommitPushArgsForCall(0)\n351\t\t\t\t\tExpect(absPath).To(HaveSuffix(string(taskID) + \".md\"))\n352\t\t\t\t})\n353\t\t\t})\n354\t\n355\t\t\tContext(\"vault routing\", func() {\n356\t\t\t\tIt(\n357\t\t\t\t\t\"skips a command whose TargetVault is openclaw when vaultName=personal (no git write, no error)\",\n358\t\t\t\t\tfunc() {\n359\t\t\t\t\t\texecutor := command.NewCreateTaskExecutor(fakeGit, taskDir, \"personal\", clock)\n360\t\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n361\t\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"task-1\"),\n362\t\t\t\t\t\t\tTitle:          \"Personal Task\",\n363\t\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n364\t\t\t\t\t\t\t\t\"assignee\": \"claude\",\n365\t\t\t\t\t\t\t\t\"status\":   \"next\",\n366\t\t\t\t\t\t\t},\n367\t\t\t\t\t\t\tTargetVault: \"openclaw\",\n368\t\t\t\t\t\t})\n369\t\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n370\t\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n371\t\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n372\t\t\t\t\t},\n373\t\t\t\t)\n374\t\n375\t\t\t\tIt(\n376\t\t\t\t\t\"processes a command whose TargetVault is openclaw when vaultName=openclaw (one git write)\",\n377\t\t\t\t\tfunc() {\n378\t\t\t\t\t\texecutor := command.NewCreateTaskExecutor(fakeGit, taskDir, \"openclaw\", clock)\n379\t\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n380\t\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"task-1\"),\n381\t\t\t\t\t\t\tTitle:          \"Openclaw Task\",\n382\t\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n383\t\t\t\t\t\t\t\t\"assignee\": \"claude\",\n384\t\t\t\t\t\t\t\t\"status\":   \"next\",\n385\t\t\t\t\t\t\t},\n386\t\t\t\t\t\t\tTargetVault: \"openclaw\",\n387\t\t\t\t\t\t})\n388\t\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n389\t\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n390\t\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n391\t\t\t\t\t},\n392\t\t\t\t)\n393\t\n394\t\t\t\tIt(\n395\t\t\t\t\t\"processes a command with empty TargetVault when vaultName=openclaw (legacy fallback)\",\n396\t\t\t\t\tfunc() {\n397\t\t\t\t\t\texecutor := command.NewCreateTaskExecutor(fakeGit, taskDir, \"openclaw\", clock)\n398\t\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n399\t\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"task-1\"),\n400\t\t\t\t\t\t\tTitle:          \"Legacy Task\",\n401\t\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n402\t\t\t\t\t\t\t\t\"assignee\": \"claude\",\n403\t\t\t\t\t\t\t\t\"status\":   \"next\",\n404\t\t\t\t\t\t\t},\n405\t\t\t\t\t\t\t// TargetVault deliberately empty — legacy producer.\n406\t\t\t\t\t\t})\n407\t\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n408\t\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n409\t\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n410\t\t\t\t\t},\n411\t\t\t\t)\n412\t\n413\t\t\t\tIt(\n414\t\t\t\t\t\"skips a command with empty TargetVault when vaultName=personal (legacy fallback is openclaw, not personal)\",\n415\t\t\t\t\tfunc() {\n416\t\t\t\t\t\texecutor := command.NewCreateTaskExecutor(fakeGit, taskDir, \"personal\", clock)\n417\t\t\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n418\t\t\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"task-1\"),\n419\t\t\t\t\t\t\tTitle:          \"Legacy Task\",\n420\t\t\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n421\t\t\t\t\t\t\t\t\"assignee\": \"claude\",\n422\t\t\t\t\t\t\t\t\"status\":   \"next\",\n423\t\t\t\t\t\t\t},\n424\t\t\t\t\t\t\t// TargetVault deliberately empty.\n425\t\t\t\t\t\t})\n426\t\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n427\t\t\t\t\t\tExpect(err).NotTo(HaveOccurred())\n428\t\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n429\t\t\t\t\t},\n430\t\t\t\t)\n431\t\t\t})\n432\t\t})\n433\t})\n434\t"}]},"parent_tool_use_id":null,"session_id":"a6e3f841-7b7a-45d9-bc18-60677fa654f3","uuid":"e92d4ed4-946a-4c9c-84d2-a60a04123891","timestamp":"2026-07-08T11:38:10.550Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pkg/command/task_create_task_executor_test.go","content":"// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n// Use of this source code is governed by a BSD-style\n// license that can be found in the LICENSE file.\n\npackage command_test\n\nimport (\n\t\"context\"\n\t\"errors\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tlib \"github.com/bborbe/agent\"\n\ttask \"github.com/bborbe/agent/command/task\"\n\t\"github.com/bborbe/cqrs/base\"\n\t\"github.com/bborbe/cqrs/cdb\"\n\tlibtime \"github.com/bborbe/time\"\n\tlibtimemocks \"github.com/bborbe/time/mocks\"\n\t. \"github.com/onsi/ginkgo/v2\"\n\t. \"github.com/onsi/gomega\"\n\n\t\"github.com/bborbe/agent-task-controller/mocks\"\n\t\"github.com/bborbe/agent-task-controller/pkg/command\"\n)\n\nvar _ = Describe(\"NewCreateTaskExecutor\", func() {\n\tvar (\n\t\tctx      context.Context\n\t\ttmpDir   string\n\t\ttaskDir  string\n\t\tfakeGit  *mocks.GitClient\n\t\texecutor cdb.CommandObjectExecutorTx\n\t\tschemaID cdb.SchemaID\n\t\tclock    *libtimemocks.CurrentDateTimeGetter\n\t)\n\n\tBeforeEach(func() {\n\t\tctx = context.Background()\n\t\tvar err error\n\t\ttmpDir, err = os.MkdirTemp(\"\", \"create-task-test-*\")\n\t\tExpect(err).NotTo(HaveOccurred())\n\n\t\ttaskDir = \"tasks\"\n\t\tExpect(os.MkdirAll(filepath.Join(tmpDir, taskDir), 0750)).To(Succeed())\n\n\t\tfakeGit = &mocks.GitClient{}\n\t\tfakeGit.PathReturns(tmpDir)\n\t\tfakeGit.AtomicWriteAndCommitPushStub = func(\n\t\t\tctx context.Context,\n\t\t\tabsPath string,\n\t\t\tcontent []byte,\n\t\t\tmessage string,\n\t\t) error {\n\t\t\treturn os.WriteFile(absPath, content, 0600) // #nosec G306 -- test helper\n\t\t}\n\t\t// Default: every title path is free unless a test overrides ReadFile.\n\t\tfakeGit.ReadFileReturns(nil, errors.New(\"GET file returned 404: not found\"))\n\n\t\tclock = &libtimemocks.CurrentDateTimeGetter{}\n\t\tclock.NowReturns(libtime.DateTime(time.Date(2026, 6, 15, 10, 0, 0, 0, time.UTC)))\n\n\t\texecutor = command.NewCreateTaskExecutor(fakeGit, taskDir, \"openclaw\", clock)\n\t\tschemaID = cdb.SchemaID{Group: \"agent\", Kind: \"task\", Version: \"v1\"}\n\t})\n\n\tAfterEach(func() {\n\t\tExpect(os.RemoveAll(tmpDir)).To(Succeed())\n\t})\n\n\tbuildCmdObj := func(cmd task.CreateCommand) cdb.CommandObject {\n\t\tevent, err := base.ParseEvent(ctx, cmd)\n\t\tExpect(err).NotTo(HaveOccurred())\n\t\treturn cdb.CommandObject{\n\t\t\tCommand: base.Command{\n\t\t\t\tRequestID: base.NewRequestID(),\n\t\t\t\tOperation: task.CreateCommandOperation,\n\t\t\t\tInitiator: \"test\",\n\t\t\t\tData:      event,\n\t\t\t},\n\t\t\tSchemaID: schemaID,\n\t\t}\n\t}\n\n\tDescribe(\"CommandOperation\", func() {\n\t\tIt(\"returns create-task\", func() {\n\t\t\tExpect(executor.CommandOperation()).To(Equal(base.CommandOperation(\"create-task\")))\n\t\t})\n\t})\n\n\tDescribe(\"HandleCommand\", func() {\n\t\tContext(\"malformed command payload\", func() {\n\t\t\tIt(\"returns ErrCommandObjectSkipped without writing\", func() {\n\t\t\t\t// A channel is not JSON-marshalable, so MarshalInto will fail.\n\t\t\t\tcmdObj := cdb.CommandObject{\n\t\t\t\t\tCommand: base.Command{\n\t\t\t\t\t\tRequestID: base.NewRequestID(),\n\t\t\t\t\t\tOperation: task.CreateCommandOperation,\n\t\t\t\t\t\tInitiator: \"test\",\n\t\t\t\t\t\tData:      base.Event{\"taskIdentifier\": make(chan int)},\n\t\t\t\t\t},\n\t\t\t\t\tSchemaID: schemaID,\n\t\t\t\t}\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).To(HaveOccurred())\n\t\t\t\tExpect(errors.Is(err, cdb.ErrCommandObjectSkipped)).To(BeTrue())\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"empty TaskIdentifier\", func() {\n\t\t\tIt(\"returns a validation error without writing\", func() {\n\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"\"),\n\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n\t\t\t\t\t\t\"assignee\": \"claude\",\n\t\t\t\t\t\t\"status\":   \"next\",\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).To(HaveOccurred())\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"missing assignee in frontmatter\", func() {\n\t\t\tIt(\"returns a validation error without writing\", func() {\n\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"my-task-id\"),\n\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n\t\t\t\t\t\t\"status\": \"next\",\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).To(HaveOccurred())\n\t\t\t\tExpect(err.Error()).To(ContainSubstring(\"assignee\"))\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"missing status in frontmatter\", func() {\n\t\t\tIt(\"returns a validation error without writing\", func() {\n\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"my-task-id\"),\n\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n\t\t\t\t\t\t\"assignee\": \"claude\",\n\t\t\t\t\t},\n\t\t\t\t})\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).To(HaveOccurred())\n\t\t\t\tExpect(err.Error()).To(ContainSubstring(\"status\"))\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"title path already occupied (collision)\", func() {\n\t\t\tIt(\"returns ErrTaskAlreadyExists and does not write (AC2)\", func() {\n\t\t\t\t// Second ReadFile call returns existing content → collision on replay.\n\t\t\t\tfakeGit.ReadFileReturnsOnCall(0,\n\t\t\t\t\tnil, errors.New(\"GET 24 Tasks/Replay Task.md returned 404: not found\"))\n\t\t\t\tfakeGit.ReadFileReturnsOnCall(\n\t\t\t\t\t1,\n\t\t\t\t\t[]byte(\n\t\t\t\t\t\t\"---\\ntask_identifier: replay-task\\nassignee: claude\\nstatus: next\\n---\\n\",\n\t\t\t\t\t),\n\t\t\t\t\tnil,\n\t\t\t\t)\n\n\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"replay-task\"),\n\t\t\t\t\tTitle:          \"Replay Task\",\n\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\", \"status\": \"next\"},\n\t\t\t\t})\n\n\t\t\t\t// First create: file not found → writes.\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n\n\t\t\t\t// Replay: file now exists → sentinel, no second write.\n\t\t\t\t_, _, err = executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).To(HaveOccurred())\n\t\t\t\tExpect(errors.Is(err, task.ErrTaskAlreadyExists)).To(BeTrue())\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1)) // still 1\n\t\t\t})\n\t\t})\n\n\t\tContext(\"new filename\", func() {\n\t\t\tIt(\"writes exactly once and returns nil when ReadFile reports not-found (AC3)\", func() {\n\t\t\t\tfakeGit.ReadFileReturns(\n\t\t\t\t\tnil,\n\t\t\t\t\terrors.New(\"GET 24 Tasks/Brand New.md returned 404: not found\"),\n\t\t\t\t)\n\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"brand-new\"),\n\t\t\t\t\tTitle:          \"Brand New\",\n\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\", \"status\": \"next\"},\n\t\t\t\t})\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(1))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"collision with a different task_identifier\", func() {\n\t\t\tIt(\"returns ErrTaskAlreadyExists and does not write (AC4)\", func() {\n\t\t\t\t// Existing file at the title path belongs to a DIFFERENT task — filename owns the\n\t\t\t\t// slot; the executor must not consult frontmatter, must not write.\n\t\t\t\tfakeGit.ReadFileReturns(\n\t\t\t\t\t[]byte(\n\t\t\t\t\t\t\"---\\ntask_identifier: someone-else\\nassignee: alice\\nstatus: todo\\n---\\n\",\n\t\t\t\t\t),\n\t\t\t\t\tnil,\n\t\t\t\t)\n\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"new-task-id\"),\n\t\t\t\t\tTitle:          \"My Colliding Task\",\n\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\", \"status\": \"next\"},\n\t\t\t\t})\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).To(HaveOccurred())\n\t\t\t\tExpect(errors.Is(err, task.ErrTaskAlreadyExists)).To(BeTrue())\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"transient git-rest read error\", func() {\n\t\t\tIt(\"propagates the wrapped error and does not write (AC5)\", func() {\n\t\t\t\tfakeGit.ReadFileReturns(\n\t\t\t\t\tnil,\n\t\t\t\t\terrors.New(\"GET 24 Tasks/Flaky.md returned 503: service unavailable\"),\n\t\t\t\t)\n\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n\t\t\t\t\tTaskIdentifier: lib.TaskIdentifier(\"flaky-task\"),\n\t\t\t\t\tTitle:          \"Flaky\",\n\t\t\t\t\tFrontmatter:    lib.TaskFrontmatter{\"assignee\": \"claude\", \"status\": \"next\"},\n\t\t\t\t})\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).To(HaveOccurred())\n\t\t\t\tExpect(errors.Is(err, task.ErrTaskAlreadyExists)).To(BeFalse())\n\t\t\t\tExpect(err.Error()).To(ContainSubstring(\"503\"))\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n\t\t\t})\n\t\t})\n\n\t\tContext(\"success: new file created\", func() {\n\t\t\tIt(\"calls AtomicWriteAndCommitPush with correct content and commit message\", func() {\n\t\t\t\ttaskID := lib.TaskIdentifier(\"new-task-abc\")\n\t\t\t\tcmdObj := buildCmdObj(task.CreateCommand{\n\t\t\t\t\tTaskIdentifier: taskID,\n\t\t\t\t\tTitle:          \"New Task ABC\",\n\t\t\t\t\tFrontmatter: lib.TaskFrontmatter{\n\t\t\t\t\t\t\"assignee\": \"claude\",\n\t\t\t\t\t\t\"status\":   \"next\",\n\t\t\t\t\t},\n\t\t\t\t\tBody: \"This is the task body.\\n\",\n\t\t\t\t})\n\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n\t\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitP