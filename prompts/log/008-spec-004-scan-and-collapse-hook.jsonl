{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_xed53qmcblc1_1","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage command\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"maps\"\n10\t\t\"path/filepath\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\tlib \"github.com/bborbe/agent\"\n15\t\ttask \"github.com/bborbe/agent/command/task\"\n16\t\t\"github.com/bborbe/cqrs/base\"\n17\t\t\"github.com/bborbe/cqrs/cdb\"\n18\t\t\"github.com/bborbe/errors\"\n19\t\tlibkv \"github.com/bborbe/kv\"\n20\t\tlibtime \"github.com/bborbe/time\"\n21\t\t\"github.com/bborbe/validation\"\n22\t\t\"github.com/golang/glog\"\n23\t\n24\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n25\t\tresult \"github.com/bborbe/agent-task-controller/pkg/result\"\n26\t\t\"github.com/bborbe/agent-task-controller/pkg/routing\"\n27\t)\n28\t\n29\t// NewCreateTaskExecutor creates a cdb.CommandObjectExecutorTx that materializes\n30\t// a new vault task file for the given task_identifier. If cmd.Title passes validation\n31\t// the file is written at tasks/{title}.md; otherwise it falls back to tasks/{task_identifier}.md.\n32\t// If a file already exists at the resolved path the command returns ErrTaskAlreadyExists\n33\t// (a benign Failure on the result topic — no overwrite, no git write).\n34\t// Frontmatter must include \"assignee\" and \"status\"; missing fields return a wrapped validation error.\n35\t// Commands whose effective target vault (cmd.TargetVault or the legacy fallback) does not\n36\t// match vaultName are skipped without side effects (no git write, no error, no result event).\n37\tfunc NewCreateTaskExecutor(\n38\t\tgitClient gitclient.GitClient,\n39\t\ttaskDir string,\n40\t\tvaultName string,\n41\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n42\t) cdb.CommandObjectExecutorTx {\n43\t\treturn cdb.CommandObjectExecutorTxFunc(\n44\t\t\ttask.CreateCommandOperation,\n45\t\t\ttrue,\n46\t\t\tfunc(ctx context.Context, tx libkv.Tx, commandObject cdb.CommandObject) (*base.EventID, base.Event, error) {\n47\t\t\t\tvar cmd task.CreateCommand\n48\t\t\t\tif err := commandObject.Command.Data.MarshalInto(ctx, &cmd); err != nil {\n49\t\t\t\t\treturn nil, nil, errors.Wrapf(\n50\t\t\t\t\t\tctx,\n51\t\t\t\t\t\tcdb.ErrCommandObjectSkipped,\n52\t\t\t\t\t\t\"malformed CreateTaskCommand: %v\",\n53\t\t\t\t\t\terr,\n54\t\t\t\t\t)\n55\t\t\t\t}\n56\t\t\t\tif err := cmd.TaskIdentifier.Validate(ctx); err != nil {\n57\t\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate task_identifier\")\n58\t\t\t\t}\n59\t\t\t\tif !routing.ShouldProcess(cmd, vaultName) {\n60\t\t\t\t\teffective := cmd.TargetVault\n61\t\t\t\t\tif effective == \"\" {\n62\t\t\t\t\t\teffective = routing.LegacyDefaultVault\n63\t\t\t\t\t}\n64\t\t\t\t\tglog.V(2).Infof(\n65\t\t\t\t\t\t\"create-task: skipped vault mismatch target=%q effective=%q vault=%q task=%s\",\n66\t\t\t\t\t\tcmd.TargetVault, effective, vaultName, cmd.TaskIdentifier,\n67\t\t\t\t\t)\n68\t\t\t\t\treturn nil, nil, nil\n69\t\t\t\t}\n70\t\t\t\tif err := validateCreateTaskFrontmatter(ctx, cmd.Frontmatter); err != nil {\n71\t\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate frontmatter\")\n72\t\t\t\t}\n73\t\t\t\trelPath := resolveCreateTaskRelPath(ctx, taskDir, cmd)\n74\t\t\t\tif err := checkTitlePathFree(ctx, gitClient, relPath, cmd.TaskIdentifier); err != nil {\n75\t\t\t\t\treturn nil, nil, err\n76\t\t\t\t}\n77\t\t\t\tif err := writeTaskFile(ctx, gitClient, relPath, cmd); err != nil {\n78\t\t\t\t\treturn nil, nil, err\n79\t\t\t\t}\n80\t\t\t\tsupersedePriorRecurringTask(ctx, gitClient, taskDir, currentDateTime, cmd, relPath)\n81\t\t\t\treturn nil, nil, nil\n82\t\t\t},\n83\t\t)\n84\t}\n85\t\n86\t// checkTitlePathFree returns ErrTaskAlreadyExists when the title path is\n87\t// already occupied (benign Failure on the result topic — no overwrite, no\n88\t// git write). A transient git-rest read error is propagated. A \"not found\"\n89\t// read error is swallowed (title path is free).\n90\tfunc checkTitlePathFree(\n91\t\tctx context.Context,\n92\t\tgitClient gitclient.GitClient,\n93\t\trelPath string,\n94\t\ttaskIdentifier lib.TaskIdentifier,\n95\t) error {\n96\t\texisting, err := gitClient.ReadFile(ctx, relPath)\n97\t\tif err == nil {\n98\t\t\tglog.V(2).Infof(\n99\t\t\t\t\"create-task: title path %s already occupied (%d bytes), returning ErrTaskAlreadyExists for %s\",\n100\t\t\t\trelPath,\n101\t\t\t\tlen(existing),\n102\t\t\t\ttaskIdentifier,\n103\t\t\t)\n104\t\t\treturn errors.Wrapf(\n105\t\t\t\tctx, task.ErrTaskAlreadyExists, \"title path %s occupied\", relPath,\n106\t\t\t)\n107\t\t}\n108\t\tif !isNotFoundReadError(err) {\n109\t\t\treturn errors.Wrapf(\n110\t\t\t\tctx, err, \"check existing task file at %s for %s\", relPath, taskIdentifier,\n111\t\t\t)\n112\t\t}\n113\t\treturn nil\n114\t}\n115\t\n116\t// writeTaskFile builds the task content and writes it atomically to the vault\n117\t// via git-rest, then logs the creation.\n118\tfunc writeTaskFile(\n119\t\tctx context.Context,\n120\t\tgitClient gitclient.GitClient,\n121\t\trelPath string,\n122\t\tcmd task.CreateCommand,\n123\t) error {\n124\t\tcontent, err := buildCreateTaskContent(ctx, cmd)\n125\t\tif err != nil {\n126\t\t\treturn errors.Wrapf(ctx, err, \"build task file content for %s\", cmd.TaskIdentifier)\n127\t\t}\n128\t\tabsPath := filepath.Join(gitClient.Path(), relPath)\n129\t\tif err := gitClient.AtomicWriteAndCommitPush(\n130\t\t\tctx,\n131\t\t\tabsPath,\n132\t\t\tcontent,\n133\t\t\t\"[agent-task-controller] create task \"+string(cmd.TaskIdentifier),\n134\t\t); err != nil {\n135\t\t\treturn errors.Wrapf(ctx, err, \"atomic write and push for task %s\", cmd.TaskIdentifier)\n136\t\t}\n137\t\tglog.V(2).Infof(\"create-task: created task file at %s for %s\", relPath, cmd.TaskIdentifier)\n138\t\treturn nil\n139\t}\n140\t\n141\t// resolveCreateTaskRelPath returns the repo-root-relative path where the task\n142\t// file should be written. If cmd.Title passes validation and contains no path\n143\t// separators, the title-derived path is returned; otherwise a WARN is logged and\n144\t// the UUID-derived path is returned as fallback so the task is always materialized.\n145\t// Filename-collision detection is the caller's job (via gitClient.ReadFile) — this\n146\t// function no longer reads the vault or compares task_identifier.\n147\tfunc resolveCreateTaskRelPath(\n148\t\tctx context.Context,\n149\t\ttaskDir string,\n150\t\tcmd task.CreateCommand,\n151\t) string {\n152\t\tuuidRelPath := filepath.Join(taskDir, string(cmd.TaskIdentifier)+\".md\")\n153\t\n154\t\t// Re-validate the command (defense-in-depth: sender may have been bypassed).\n155\t\tif err := cmd.Validate(ctx); err != nil {\n156\t\t\tglog.Warningf(\n157\t\t\t\t\"create-task: Title validation failed for task %s (%v); falling back to UUID path\",\n158\t\t\t\tcmd.TaskIdentifier, err,\n159\t\t\t)\n160\t\t\treturn uuidRelPath\n161\t\t}\n162\t\n163\t\t// Reject titles containing path separators to prevent path traversal.\n164\t\tif strings.ContainsAny(cmd.Title, \"/\\\\\") {\n165\t\t\tglog.Warningf(\n166\t\t\t\t\"create-task: Title %q contains path separator; falling back to UUID path\",\n167\t\t\t\tcmd.Title,\n168\t\t\t)\n169\t\t\treturn uuidRelPath\n170\t\t}\n171\t\n172\t\treturn filepath.Join(taskDir, cmd.Title+\".md\")\n173\t}\n174\t\n175\t// isNotFoundReadError reports whether a gitClient.ReadFile error means the file\n176\t// does not exist (git-rest returns HTTP 404). git-rest's Get does not expose a\n177\t// typed not-found sentinel, so this matches the \"404\" status embedded in the\n178\t// wrapped error message produced by gitRestClient.Get\n179\t// (\"GET <path> returned 404: ...\"). A nil error is NOT a not-found error and must\n180\t// be handled by the caller before calling this helper.\n181\tfunc isNotFoundReadError(err error) bool {\n182\t\tif err == nil {\n183\t\t\treturn false\n184\t\t}\n185\t\treturn strings.Contains(err.Error(), \"returned 404\")\n186\t}\n187\t\n188\tfunc validateCreateTaskFrontmatter(ctx context.Context, fm lib.TaskFrontmatter) error {\n189\t\tif fm.Assignee() == \"\" {\n190\t\t\treturn errors.Wrap(ctx, validation.Error, \"frontmatter missing required field: assignee\")\n191\t\t}\n192\t\tif s, _ := fm.String(\"status\"); s == \"\" {\n193\t\t\treturn errors.Wrap(ctx, validation.Error, \"frontmatter missing required field: status\")\n194\t\t}\n195\t\treturn nil\n196\t}\n197\t\n198\tfunc buildCreateTaskContent(ctx context.Context, cmd task.CreateCommand) ([]byte, error) {\n199\t\tfm := make(lib.TaskFrontmatter)\n200\t\tmaps.Copy(fm, cmd.Frontmatter)\n201\t\tfm[\"task_identifier\"] = string(cmd.TaskIdentifier)\n202\t\treturn marshalFileContent(ctx, fm, cmd.Body)\n203\t}\n204\t\n205\t// supersedePriorRecurringTask transitions the prior-period recurring-task instance\n206\t// to status: aborted after a new instance is materialized. It is a best-effort\n207\t// hook: every failure path (ineligible, no prior, read/parse/write error) is logged\n208\t// and swallowed so the already-written new instance is never rolled back.\n209\t// newRelPath is the repo-root-relative path of the just-written new instance\n210\t// (used as the superseded_by back-pointer).\n211\t//\n212\t//nolint:unparam // Parameters kept for prompt 2 rewrite; body is a transitional no-op.\n213\tfunc supersedePriorRecurringTask(\n214\t\tctx context.Context,\n215\t\tgitClient gitclient.GitClient,\n216\t\ttaskDir string,\n217\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n218\t\tcmd task.CreateCommand,\n219\t\tnewRelPath string,\n220\t) {\n221\t\tif !isEligibleForSupersede(cmd) {\n222\t\t\treturn\n223\t\t}\n224\t\t// Scan-and-collapse lands in spec-004 prompt 2; until then this hook is a no-op.\n225\t\tglog.V(3).\n226\t\t\tInfof(\"auto-supersede: scan-and-collapse not yet wired for %s (spec-004 prompt 2)\", cmd.TaskIdentifier)\n227\t\t// Interim references so `unused`/`unparam` stay green while the scan (prompt 2)\n228\t\t// is not yet wired. Prompt 2 rewrites this whole body and deletes this block.\n229\t\t_, _, _, _, _ = ctx, gitClient, taskDir, currentDateTime, newRelPath\n230\t\t_ = []any{readPriorForSupersede, priorIsInProgress, transitionPrior, buildSupersedeModifyFn}\n231\t}\n232\t\n233\t// isEligibleForSupersede reports whether cmd is a recurring-task instance\n234\t// that should auto-supersede its prior. Returns true only when created_by is\n235\t// the recurring-task publisher AND auto_abort_prior is explicitly true (opt-in).\n236\t// Returns false (no supersede) when auto_abort_prior is absent or false — the\n237\t// safe default that prevents accidental supersede of audit-style tasks.\n238\tfunc isEligibleForSupersede(cmd task.CreateCommand) bool {\n239\t\tcreatedBy, _ := cmd.Frontmatter.String(\"created_by\")\n240\t\tif createdBy != \"recurring-task-creator\" {\n241\t\t\tglog.V(3).\n242\t\t\t\tInfof(\"auto-supersede: skip %s (created_by=%q != recurring-task-creator)\", cmd.TaskIdentifier, createdBy)\n243\t\t\treturn false\n244\t\t}\n245\t\tif b, _ := cmd.Frontmatter[\"auto_abort_prior\"].(bool); b {\n246\t\t\treturn true\n247\t\t}\n248\t\tif s, _ := cmd.Frontmatter[\"auto_abort_prior\"].(string); s == \"true\" {\n249\t\t\treturn true\n250\t\t}\n251\t\tglog.V(3).\n252\t\t\tInfof(\"auto-supersede: skip %s (auto_abort_prior not true — opt-in required)\", cmd.TaskIdentifier)\n253\t\treturn false\n254\t}\n255\t\n256\t// readPriorForSupersede reads the prior file. Returns (nil, nil) on a\n257\t// not-found (first-ever instance — benign no-op). Returns (nil, err) on a\n258\t// transient git-rest error (logged by caller).\n259\tfunc readPriorForSupersede(\n260\t\tctx context.Context,\n261\t\tgitClient gitclient.GitClient,\n262\t\tpriorRelPath string,\n263\t\ttaskIdentifier lib.TaskIdentifier,\n264\t) ([]byte, error) {\n265\t\tcontent, err := gitClient.ReadFile(ctx, priorRelPath)\n266\t\tif err == nil {\n267\t\t\treturn content, nil\n268\t\t}\n269\t\tif isNotFoundReadError(err) {\n270\t\t\tglog.V(3).\n271\t\t\t\tInfof(\"auto-supersede: no prior instance at %s for %s (first-ever instance)\", priorRelPath, taskIdentifier)\n272\t\t\treturn nil, nil\n273\t\t}\n274\t\tglog.Warningf(\n275\t\t\t\"auto-supersede: read prior %s failed for %s: %v\",\n276\t\t\tpriorRelPath,\n277\t\t\ttaskIdentifier,\n278\t\t\terr,\n279\t\t)\n280\t\treturn nil, err\n281\t}\n282\t\n283\t// priorIsInProgress parses the prior file's frontmatter and reports whether\n284\t// its status is in_progress. Returns false (no-op) on parse error or any\n285\t// non-in_progress status.\n286\tfunc priorIsInProgress(\n287\t\tctx context.Context,\n288\t\tcontent []byte,\n289\t\tpriorRelPath string,\n290\t\ttaskIdentifier lib.TaskIdentifier,\n291\t) bool {\n292\t\tfrontmatterStr, err := result.ExtractFrontmatter(ctx, content)\n293\t\tif err != nil {\n294\t\t\tglog.Warningf(\n295\t\t\t\t\"auto-supersede: extract frontmatter from prior %s failed for %s: %v\",\n296\t\t\t\tpriorRelPath,\n297\t\t\t\ttaskIdentifier,\n298\t\t\t\terr,\n299\t\t\t)\n300\t\t\treturn false\n301\t\t}\n302\t\tpriorFm, err := parseTaskFrontmatter(frontmatterStr)\n303\t\tif err != nil {\n304\t\t\tglog.Warningf(\n305\t\t\t\t\"auto-supersede: parse prior frontmatter %s failed for %s: %v\",\n306\t\t\t\tpriorRelPath,\n307\t\t\t\ttaskIdentifier,\n308\t\t\t\terr,\n309\t\t\t)\n310\t\t\treturn false\n311\t\t}\n312\t\tstatus, _ := priorFm.String(\"status\")\n313\t\tif status != \"in_progress\" {\n314\t\t\tglog.V(3).\n315\t\t\t\tInfof(\"auto-supersede: prior %s status=%q (not in_progress), no-op for %s\", priorRelPath, status, taskIdentifier)\n316\t\t\treturn false\n317\t\t}\n318\t\treturn true\n319\t}\n320\t\n321\t// transitionPrior performs the read-modify-write that transitions the prior\n322\t// file to aborted. Best-effort: write errors are logged and swallowed.\n323\tfunc transitionPrior(\n324\t\tctx context.Context,\n325\t\tgitClient gitclient.GitClient,\n326\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n327\t\tpriorRelPath string,\n328\t\tpriorTitle string,\n329\t\tnewRelPath string,\n330\t\ttaskIdentifier lib.TaskIdentifier,\n331\t) {\n332\t\tts := currentDateTime.Now().UTC().Format(time.RFC3339)\n333\t\tpriorAbsPath := filepath.Join(gitClient.Path(), priorRelPath)\n334\t\tmodify := buildSupersedeModifyFn(ctx, newRelPath, ts)\n335\t\tmsg := \"[agent-task-controller] auto-supersede prior recurring task \" + priorTitle\n336\t\tif err := gitClient.AtomicReadModifyWriteAndCommitPush(ctx, priorAbsPath, modify, msg); err != nil {\n337\t\t\tglog.Warningf(\n338\t\t\t\t\"auto-supersede: write prior %s failed for %s: %v\",\n339\t\t\t\tpriorRelPath,\n340\t\t\t\ttaskIdentifier,\n341\t\t\t\terr,\n342\t\t\t)\n343\t\t\treturn\n344\t\t}\n345\t\tglog.Infof(\n346\t\t\t\"auto-supersede: %s -> %s (prior superseded by new instance)\",\n347\t\t\tpriorRelPath,\n348\t\t\tnewRelPath,\n349\t\t)\n350\t}\n351\t\n352\t// buildSupersedeModifyFn builds the modify closure for AtomicReadModifyWriteAndCommitPush\n353\t// that transitions a prior-period recurring-task instance to aborted.\n354\tfunc buildSupersedeModifyFn(\n355\t\tctx context.Context,\n356\t\tnewRelPath string,\n357\t\tts string,\n358\t) func([]byte) ([]byte, error) {\n359\t\treturn func(current []byte) ([]byte, error) {\n360\t\t\tfmStr, err := result.ExtractFrontmatter(ctx, current)\n361\t\t\tif err != nil {\n362\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract frontmatter\")\n363\t\t\t}\n364\t\t\tbody, err := result.ExtractBody(ctx, current)\n365\t\t\tif err != nil {\n366\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract body\")\n367\t\t\t}\n368\t\t\tfm, err := parseTaskFrontmatter(fmStr)\n369\t\t\tif err != nil {\n370\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"parse frontmatter\")\n371\t\t\t}\n372\t\t\tfm[\"status\"] = \"aborted\"\n373\t\t\tfm[\"phase\"] = \"done\"\n374\t\t\tfm[\"completed_date\"] = ts\n375\t\t\tfm[\"superseded_by\"] = newRelPath\n376\t\t\tfm[\"created_by\"] = \"recurring-task-creator\"\n377\t\t\treturn marshalFileContent(ctx, fm, body)\n378\t\t}\n379\t}\n380\t"}]},"parent_tool_use_id":null,"session_id":"a6e3f841-7b7a-45d9-bc18-60677fa654f3","uuid":"6cb894c9-90b6-494a-8abf-59c3833c4c3c","timestamp":"2026-07-08T11:38:06.300Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pkg/command/task_create_task_executor.go","content":"// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n// Use of this source code is governed by a BSD-style\n// license that can be found in the LICENSE file.\n\npackage command\n\nimport (\n\t\"context\"\n\t\"maps\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tlib \"github.com/bborbe/agent\"\n\ttask \"github.com/bborbe/agent/command/task\"\n\t\"github.com/bborbe/cqrs/base\"\n\t\"github.com/bborbe/cqrs/cdb\"\n\t\"github.com/bborbe/errors\"\n\tlibkv \"github.com/bborbe/kv\"\n\tlibtime \"github.com/bborbe/time\"\n\t\"github.com/bborbe/validation\"\n\t\"github.com/golang/glog\"\n\n\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n\tresult \"github.com/bborbe/agent-task-controller/pkg/result\"\n\t\"github.com/bborbe/agent-task-controller/pkg/routing\"\n)\n\n// NewCreateTaskExecutor creates a cdb.CommandObjectExecutorTx that materializes\n// a new vault task file for the given task_identifier. If cmd.Title passes validation\n// the file is written at tasks/{title}.md; otherwise it falls back to tasks/{task_identifier}.md.\n// If a file already exists at the resolved path the command returns ErrTaskAlreadyExists\n// (a benign Failure on the result topic — no overwrite, no git write).\n// Frontmatter must include \"assignee\" and \"status\"; missing fields return a wrapped validation error.\n// Commands whose effective target vault (cmd.TargetVault or the legacy fallback) does not\n// match vaultName are skipped without side effects (no git write, no error, no result event).\nfunc NewCreateTaskExecutor(\n\tgitClient gitclient.GitClient,\n\ttaskDir string,\n\tvaultName string,\n\tcurrentDateTime libtime.CurrentDateTimeGetter,\n) cdb.CommandObjectExecutorTx {\n\treturn cdb.CommandObjectExecutorTxFunc(\n\t\ttask.CreateCommandOperation,\n\t\ttrue,\n\t\tfunc(ctx context.Context, tx libkv.Tx, commandObject cdb.CommandObject) (*base.EventID, base.Event, error) {\n\t\t\tvar cmd task.CreateCommand\n\t\t\tif err := commandObject.Command.Data.MarshalInto(ctx, &cmd); err != nil {\n\t\t\t\treturn nil, nil, errors.Wrapf(\n\t\t\t\t\tctx,\n\t\t\t\t\tcdb.ErrCommandObjectSkipped,\n\t\t\t\t\t\"malformed CreateTaskCommand: %v\",\n\t\t\t\t\terr,\n\t\t\t\t)\n\t\t\t}\n\t\t\tif err := cmd.TaskIdentifier.Validate(ctx); err != nil {\n\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate task_identifier\")\n\t\t\t}\n\t\t\tif !routing.ShouldProcess(cmd, vaultName) {\n\t\t\t\teffective := cmd.TargetVault\n\t\t\t\tif effective == \"\" {\n\t\t\t\t\teffective = routing.LegacyDefaultVault\n\t\t\t\t}\n\t\t\t\tglog.V(2).Infof(\n\t\t\t\t\t\"create-task: skipped vault mismatch target=%q effective=%q vault=%q task=%s\",\n\t\t\t\t\tcmd.TargetVault, effective, vaultName, cmd.TaskIdentifier,\n\t\t\t\t)\n\t\t\t\treturn nil, nil, nil\n\t\t\t}\n\t\t\tif err := validateCreateTaskFrontmatter(ctx, cmd.Frontmatter); err != nil {\n\t\t\t\treturn nil, nil, errors.Wrapf(ctx, err, \"validate frontmatter\")\n\t\t\t}\n\t\t\trelPath := resolveCreateTaskRelPath(ctx, taskDir, cmd)\n\t\t\tif err := checkTitlePathFree(ctx, gitClient, relPath, cmd.TaskIdentifier); err != nil {\n\t\t\t\treturn nil, nil, err\n\t\t\t}\n\t\t\tif err := writeTaskFile(ctx, gitClient, relPath, cmd); err != nil {\n\t\t\t\treturn nil, nil, err\n\t\t\t}\n\t\t\tsupersedePriorRecurringTask(ctx, gitClient, taskDir, currentDateTime, cmd, relPath)\n\t\t\treturn nil, nil, nil\n\t\t},\n\t)\n}\n\n// checkTitlePathFree returns ErrTaskAlreadyExists when the title path is\n// already occupied (benign Failure on the result topic — no overwrite, no\n// git write). A transient git-rest read error is propagated. A \"not found\"\n// read error is swallowed (title path is free).\nfunc checkTitlePathFree(\n\tctx context.Context,\n\tgitClient gitclient.GitClient,\n\trelPath string,\n\ttaskIdentifier lib.TaskIdentifier,\n) error {\n\texisting, err := gitClient.ReadFile(ctx, relPath)\n\tif err == nil {\n\t\tglog.V(2).Infof(\n\t\t\t\"create-task: title path %s already occupied (%d bytes), returning ErrTaskAlreadyExists for %s\",\n\t\t\trelPath,\n\t\t\tlen(existing),\n\t\t\ttaskIdentifier,\n\t\t)\n\t\treturn errors.Wrapf(\n\t\t\tctx, task.ErrTaskAlreadyExists, \"title path %s occupied\", relPath,\n\t\t)\n\t}\n\tif !isNotFoundReadError(err) {\n\t\treturn errors.Wrapf(\n\t\t\tctx, err, \"check existing task file at %s for %s\", relPath, taskIdentifier,\n\t\t)\n\t}\n\treturn nil\n}\n\n// writeTaskFile builds the task content and writes it atomically to the vault\n// via git-rest, then logs the creation.\nfunc writeTaskFile(\n\tctx context.Context,\n\tgitClient gitclient.GitClient,\n\trelPath string,\n\tcmd task.CreateCommand,\n) error {\n\tcontent, err := buildCreateTaskContent(ctx, cmd)\n\tif err != nil {\n\t\treturn errors.Wrapf(ctx, err, \"build task file content for %s\", cmd.TaskIdentifier)\n\t}\n\tabsPath := filepath.Join(gitClient.Path(), relPath)\n\tif err := gitClient.AtomicWriteAndCommitPush(\n\t\tctx,\n\t\tabsPath,\n\t\tcontent,\n\t\t\"[agent-task-controller] create task \"+string(cmd.TaskIdentifier),\n\t); err != nil {\n\t\treturn errors.Wrapf(ctx, err, \"atomic write and push for task %s\", cmd.TaskIdentifier)\n\t}\n\tglog.V(2).Infof(\"create-task: created task file at %s for %s\", relPath, cmd.TaskIdentifier)\n\treturn nil\n}\n\n// resolveCreateTaskRelPath returns the repo-root-relative path where the task\n// file should be written. If cmd.Title passes validation and contains no path\n// separators, the title-derived path is returned; otherwise a WARN is logged and\n// the UUID-derived path is returned as fallback so the task is always materialized.\n// Filename-collision detection is the caller's job (via gitClient.ReadFile) — this\n// function no longer reads the vault or compares task_identifier.\nfunc resolveCreateTaskRelPath(\n\tctx context.Context,\n\ttaskDir string,\n\tcmd task.CreateCommand,\n) string {\n\tuuidRelPath := filepath.Join(taskDir, string(cmd.TaskIdentifier)+\".md\")\n\n\t// Re-validate the command (defense-in-depth: sender may have been bypassed).\n\tif err := cmd.Validate(ctx); err != nil {\n\t\tglog.Warningf(\n\t\t\t\"create-task: Title validation failed for task %s (%v); falling back to UUID path\",\n\t\t\tcmd.TaskIdentifier, err,\n\t\t)\n\t\treturn uuidRelPath\n\t}\n\n\t// Reject titles containing path separators to prevent path traversal.\n\tif strings.ContainsAny(cmd.Title, \"/\\\\\") {\n\t\tglog.Warningf(\n\t\t\t\"create-task: Title %q contains path separator; falling back to UUID path\",\n\t\t\tcmd.Title,\n\t\t)\n\t\treturn uuidRelPath\n\t}\n\n\treturn filepath.Join(taskDir, cmd.Title+\".md\")\n}\n\n// isNotFoundReadError reports whether a gitClient.ReadFile error means the file\n// does not exist (git-rest returns HTTP 404). git-rest's Get does not expose a\n// typed not-found sentinel, so this matches the \"404\" status embedded in the\n// wrapped error message produced by gitRestClient.Get\n// (\"GET <path> returned 404: ...\"). A nil error is NOT a not-found error and must\n// be handled by the caller before calling this helper.\nfunc isNotFoundReadError(err error) bool {\n\tif err == nil {\n\t\treturn false\n\t}\n\treturn strings.Contains(err.Error(), \"returned 404\")\n}\n\nfunc validateCreateTaskFrontmatter(ctx context.Context, fm lib.TaskFrontmatter) error {\n\tif fm.Assignee() == \"\" {\n\t\treturn errors.Wrap(ctx, validation.Error, \"frontmatter missing required field: assignee\")\n\t}\n\tif s, _ := fm.String(\"status\"); s == \"\" {\n\t\treturn errors.Wrap(ctx, validation.Error, \"frontmatter missing required field: status\")\n\t}\n\treturn nil\n}\n\nfunc buildCreateTaskContent(ctx context.Context, cmd task.CreateCommand) ([]byte, error) {\n\tfm := make(lib.TaskFrontmatter)\n\tmaps.Copy(fm, cmd.Frontmatter)\n\tfm[\"task_identifier\"] = string(cmd.TaskIdentifier)\n\treturn marshalFileContent(ctx, fm, cmd.Body)\n}\n\n// supersedePriorRecurringTask transitions the prior-period recurring-task instance\n// to status: aborted after a new instance is materialized. It is a best-effort\n// hook: every failure path (ineligible, no prior, read/parse/write error) is logged\n// and swallowed so the already-written new instance is never rolled back.\n// newRelPath is the repo-root-relative path of the just-written new instance\n// (used as the superseded_by back-pointer).\n//\n//nolint:unparam // Parameters kept for prompt 2 rewrite; body is a transitional no-op.\nfunc supersedePriorRecurringTask(\n\tctx context.Context,\n\tgitClient gitclient.GitClient,\n\ttaskDir string,\n\tcurrentDateTime libtime.CurrentDateTimeGetter,\n\tcmd task.CreateCommand,\n\tnewRelPath string,\n) {\n\tif !isEligibleForSupersede(cmd) {\n\t\treturn\n\t}\n\t// Scan-and-collapse lands in spec-004 prompt 2; until then this hook is a no-op.\n\tglog.V(3).\n\t\tInfof(\"auto-supersede: scan-and-collapse not yet wired for %s (spec-004 prompt 2)\", cmd.TaskIdentifier)\n\t// Interim references so `unused`/`unparam` stay green while the scan (prompt 2)\n\t// is not yet wired. Prompt 2 rewrites this whole body and deletes this block.\n\t_, _, _, _, _ = ctx, gitClient, taskDir, currentDateTime, newRelPath\n\t_ = []any{readPriorForSupersede, priorIsInProgress, transitionPrior, buildSupersedeModifyFn}\n}\n\n// isEligibleForSupersede reports whether cmd is a recurring-task instance\n// that should auto-supersede its prior. Returns true only when created_by is\n// the recurring-task publisher AND auto_abort_prior is explicitly true (opt-in).\n// Returns false (no supersede) when auto_abort_prior is absent or false — the\n// safe default that prevents accidental supersede of audit-style tasks.\nfunc isEligibleForSupersede(cmd task.CreateCommand) bool {\n\tcreatedBy, _ := cmd.Frontmatter.String(\"created_by\")\n\tif createdBy != \"recurring-task-creator\" {\n\t\tglog.V(3).\n\t\t\tInfof(\"auto-supersede: skip %s (created_by=%q != recurring-task-creator)\", cmd.TaskIdentifier, createdBy)\n\t\treturn false\n\t}\n\tif b, _ := cmd.Frontmatter[\"auto_abort_prior\"].(bool); b {\n\t\treturn true\n\t}\n\tif s, _ := cmd.Frontmatter[\"auto_abort_prior\"].(string); s == \"true\" {\n\t\treturn true\n\t}\n\tglog.V(3).\n\t\tInfof(\"auto-supersede: skip %s (auto_abort_prior not true — opt-in required)\", cmd.TaskIdentifier)\n\treturn false\n}\n\n// readPriorForSupersede reads the prior file. Returns (nil, nil) on a\n// not-found (first-ever instance — benign no-op). Returns (nil, err) on a\n// transient git-rest error (logged by caller).\nfunc readPriorForSupersede(\n\tctx context.Context,\n\tgitClient gitclient.GitClient,\n\tpriorRelPath string,\n\ttaskIdentifier lib.TaskIdentifier,\n) ([]byte, error) {\n\tcontent, err := gitClient.ReadFile(ctx, priorRelPath)\n\tif err == nil {\n\t\treturn content, nil\n\t}\n\tif isNotFoundReadError(err) {\n\t\tglog.V(3).\n\t\t\tInfof(\"auto-supersede: no prior instance at %s for %s (first-ever instance)\", priorRelPath, taskIdentifier)\n\t\treturn nil, nil\n\t}\n\tglog.Warningf(\n\t\t\"auto-supersede: read prior %s failed for %s: %v\",\n\t\tpriorRelPath,\n\t\ttaskIdentifier,\n\t\terr,\n\t)\n\treturn nil, err\n}\n\n// priorIsInProgress parses the prior file's frontmatter and reports whether\n// its status is in_progress. Returns false (no-op) on parse error or any\n// non-in_progress status.\nfunc priorIsInProgress(\n\tctx context.Context,\n\tcontent []byte,\n\tpriorRelPath string,\n\ttaskIdentifier lib.TaskIdentifier,\n) bool {\n\tfrontmatterStr, err := result.ExtractFrontmatter(ctx, content)\n\tif err != nil {\n\t\tglog.Warningf(\n\t\t\t\"auto-supersede: extract frontmatter from prior %s failed for %s: %v\",\n\t\t\tpriorRelPath,\n\t\t\ttaskIdentifier,\n\t\t\terr,\n\t\t)\n\t\treturn false\n\t}\n\tpriorFm, err := parseTaskFrontmatter(frontmatterStr)\n\tif err != nil {\n\t\tglog.Warningf(\n\t\t\t\"auto-supersede: parse prior frontmatter %s failed for %s: %v\",\n\t\t\tpriorRelPath,\n\t\t\ttaskIdentifier,\n\t\t\terr,\n\t\t)\n\t\treturn false\n\t}\n\tstatus, _ := priorFm.String(\"status\")\n\tif status != \"in_progress\" {\n\t\tglog.V(3).\n\t\t\tInfof(\"auto-supersede: prior %s status=%q (not in_progress), no-op for %s\", priorRelPath, status, taskIdentifier)\n\t\treturn false\n\t}\n\treturn true\n}\n\n// transitionPrior performs the read-modify-write that transitions the prior\n// file to aborted. Best-effort: write errors are logged and swallowed.\nfunc transitionPrior(\n\tctx context.Context,\n\tgitClient gitclient.GitClient,\n\tcurrentDateTime libtime.CurrentDateTimeGetter,\n\tpriorRelPath string,\n\tpriorTitle string,\n\tnewRelPath string,\n\ttaskIdentifier lib.TaskIdentifier,\n) {\n\tts := currentDateTime.Now().UTC().Format(time.RFC3339)\n\tpriorAbsPath := filepath.Join(gitClient.Path(), priorRelPath)\n\tmodify := buildSupersedeModifyFn(ctx, newRelPath, ts)\n\tmsg := \"[agent-task-controller] auto-supersede prior recurring task \" + priorTitle\n\tif err := gitClient.AtomicReadModifyWriteAndCommitPush(ctx, priorAbsPath, modify, msg); err != nil {\n\t\tglog.Warningf(\n\t\t\t\"auto-supersede: write prior %s failed for %s: %v\",\n\t\t\tpriorRelPath,\n\t\t\ttaskIdentifier,\n\t\t\terr,\n\t\t)\n\t\treturn\n\t}\n\tglog.Infof(\n\t\t\"auto-supersede: %s -> %s (prior superseded by new instance)\",\n\t\tpriorRelPath,\n\t\tnewRelPath,\n\t)\n}\n\n// buildSupersedeModifyFn builds the modify closure for AtomicReadModifyWriteAndCommitPush\n// that transitions a prior-period recurring-task instance to aborted.\nfunc buildSupersedeModifyFn(\n\tctx context.Context,\n\tnewRelPath string,\n\tts string,\n) func([]byte) ([]byte, error) {\n\treturn func(current []byte) ([]byte, error) {\n\t\tfmStr, err := result.ExtractFrontmatter(ctx, current)\n\t\tif err != nil {\n\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract frontmatter\")\n\t\t}\n\t\tbody, err := result.ExtractBody(ctx, current)\n\t\tif err != nil {\n\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract body\")\n\t\t}\n\t\tfm, err := parseTaskFrontmatter(fmStr)\n\t\tif err != nil {\n\t\t\treturn nil, errors.Wrapf(ctx, err, \"parse frontmatter\")\n\t\t}\n\t\tfm[\"status\"] = \"aborted\"\n\t\tfm[\"phase\"] = \"done\"\n\t\tfm[\"completed_date\"] = ts\n\t\tfm[\"superseded_by\"] = newRelPath\n\t\tfm[\"created_by\"] = \"recurring-task-creator\"\n\t\treturn marshalFileContent(ctx, fm, body)\n\t}\n}\n","numLines":380,"startLine":1,"totalLines":380}}}
