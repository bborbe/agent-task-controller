ndidates).\n48\tfunc parsePeriodTokenOrdinal(ctx context.Context, token string) (int64, error) {\n49\t\t// Daily: YYYY-MM-DD\n50\t\tif m := dailyRe.FindStringSubmatch(token); m != nil {\n51\t\t\tyear, _ := strconv.Atoi(m[1])\n52\t\t\tmonth, _ := strconv.Atoi(m[2])\n53\t\t\tday, _ := strconv.Atoi(m[3])\n54\t\t\tt := time.Date(year, time.Month(month), day, 0, 0, 0, 0, time.UTC)\n55\t\t\treturn t.UTC().Unix(), nil\n56\t\t}\n57\t\n58\t\t// Weekday (list): YYYYWww-<3-letter-abbrev>\n59\t\tif m := weekdayRe.FindStringSubmatch(token); m != nil {\n60\t\t\tisoYear, _ := strconv.Atoi(m[1])\n61\t\t\tweek, _ := strconv.Atoi(m[2])\n62\t\t\t// Abbrev is ignored for ordering — all weekdays of the same week rank\n63\t\t\t// together by their week's Monday; ties are broken by the caller's\n64\t\t\t// stable sort on descending Title.\n65\t\t\treturn isoWeekMonday(isoYear, week).UTC().Unix(), nil\n66\t\t}\n67\t\n68\t\t// Weekly: YYYYWww\n69\t\tif m := weeklyRe.FindStringSubmatch(token); m != nil {\n70\t\t\tisoYear, _ := strconv.Atoi(m[1])\n71\t\t\tweek, _ := strconv.Atoi(m[2])\n72\t\t\treturn isoWeekMonday(isoYear, week).UTC().Unix(), nil\n73\t\t}\n74\t\n75\t\t// Monthly: YYYY-MM\n76\t\tif m := monthlyRe.FindStringSubmatch(token); m != nil {\n77\t\t\tyear, _ := strconv.Atoi(m[1])\n78\t\t\tmonth, _ := strconv.Atoi(m[2])\n79\t\t\treturn time.Date(year, time.Month(month), 1, 0, 0, 0, 0, time.UTC).Unix(), nil\n80\t\t}\n81\t\n82\t\t// Quarterly: YYYYQq\n83\t\tif m := quarterlyRe.FindStringSubmatch(token); m != nil {\n84\t\t\tyear, _ := strconv.Atoi(m[1])\n85\t\t\tq, _ := strconv.Atoi(m[2])\n86\t\t\treturn time.Date(year, time.Month((q-1)*3+1), 1, 0, 0, 0, 0, time.UTC).Unix(), nil\n87\t\t}\n88\t\n89\t\t// Yearly: YYYY\n90\t\tif m := yearlyRe.FindStringSubmatch(token); m != nil {\n91\t\t\tyear, _ := strconv.Atoi(m[1])\n92\t\t\treturn time.Date(year, time.January, 1, 0, 0, 0, 0, time.UTC).Unix(), nil\n93\t\t}\n94\t\n95\t\treturn 0, errors.Errorf(ctx, \"period token %q matches no recognized shape\", token)\n96\t}\n97\t\n98\t// rankedCandidate pairs a candidate title with its parsed period-token ordinal.\n99\ttype rankedCandidate struct {\n100\t\tTitle   string\n101\t\tOrdinal int64\n102\t}\n103\t\n104\t// splitTitleToken splits a recurring-task title into its slug prefix and\n105\t// period-token suffix on the FINAL \" - \" separator. Returns ok=false when the\n106\t// title has no \" - <token>\" suffix. The slug may itself contain \" - \".\n107\tfunc splitTitleToken(title string) (slug string, token string, ok bool) {\n108\t\tidx := strings.LastIndex(title, \" - \")\n109\t\tif idx < 0 {\n110\t\t\treturn \"\", \"\", false\n111\t\t}\n112\t\treturn title[:idx], title[idx+len(\" - \"):], true\n113\t}\n114\t\n115\t// rankSameSlugCandidatesDescending parses each candidate title's period-token\n116\t// ordinal and returns the candidates whose token is a recognized shape, sorted\n117\t// most-recent-first (largest ordinal first). Candidates whose token matches no\n118\t// shape are dropped (logged at V(3)). The sort is stable; equal ordinals keep a\n119\t// deterministic order by descending Title so redelivery is idempotent.\n120\tfunc rankSameSlugCandidatesDescending(ctx context.Context, titles []string) []rankedCandidate {\n121\t\tvar ranked []rankedCandidate\n122\t\tfor _, title := range titles {\n123\t\t\tslug, token, ok := splitTitleToken(title)\n124\t\t\tif !ok {\n125\t\t\t\tglog.V(3).\n126\t\t\t\t\tInfof(\"auto-supersede: candidate %q has no period-token suffix, skipping\", title)\n127\t\t\t\tcontinue\n128\t\t\t}\n129\t\t\tordinal, err := parsePeriodTokenOrdinal(ctx, token)\n130\t\t\tif err != nil {\n131\t\t\t\tglog.V(3).\n132\t\t\t\t\tInfof(\"auto-supersede: candidate %q token unrecognized, skipping: %v\", title, err)\n133\t\t\t\tcontinue\n134\t\t\t}\n135\t\t\tranked = append(ranked, rankedCandidate{Title: title, Ordinal: ordinal})\n136\t\t\t_ = slug // slug retained for future scan use; ordinal is sufficient for ranking\n137\t\t}\n138\t\tsort.SliceStab