 {\n\t\tvar restoreEnv func()\n\t\tBeforeEach(func() {\n\t\t\t_, had := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\torig, _ := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tExpect(os.Setenv(\"SUPERSEDE_LOOKBACK\", \"3\")).To(Succeed())\n\t\t\trestoreEnv = func() {\n\t\t\t\tif had {\n\t\t\t\t\tos.Setenv(\"SUPERSEDE_LOOKBACK\", orig)\n\t\t\t\t} else {\n\t\t\t\t\tos.Unsetenv(\"SUPERSEDE_LOOKBACK\")\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t\tAfterEach(func() { restoreEnv() })\n\n\t\tIt(\"honors the env override\", func() {\n\t\t\tvar app lookbackShape\n\t\t\terr := libargument.Parse(context.Background(), &app)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(app.SupersedeLookback).To(Equal(3))\n\t\t})\n\t})\n\n\tContext(\"when env var is unset\", func() {\n\t\tvar restoreEnv func()\n\t\tBeforeEach(func() {\n\t\t\t_, had := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\torig, _ := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tExpect(os.Unsetenv(\"SUPERSEDE_LOOKBACK\")).To(Succeed())\n\t\t\trestoreEnv = func() {\n\t\t\t\tif had {\n\t\t\t\t\tos.Setenv(\"SUPERSEDE_LOOKBACK\", orig)\n\t\t\t\t} else {\n\t\t\t\t\tos.Unsetenv(\"SUPERSEDE_LOOKBACK\")\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t\tAfterEach(func() { restoreEnv() })\n\n\t\t// Parse has already been called by the sibling It above (Ginkgo randomises\n\t\t// order; this It may run first).  After Parse, the field holds the\n\t\t// default and os.Getenv confirms the env was empty.\n\t\tIt(\"applies the default value 7\", func() {\n\t\t\tenvVal, had := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tExpect(had).To(BeFalse(), \"SUPERSEDE_LOOKBACK must not be set for this test\")\n\n\t\t\t// Parse was already called by the env-override It; parse again with\n\t\t\t// a fresh struct to confirm the default still applies when env is\n\t\t\t// unset.  (This is the second Parse call in this describe tree.\n\t\t\t// To avoid the \"flag redefined\" panic from sibling test files that\n\t\t\t// also carry AUTO_INJECT_TASK_IDENTIFIER, we skip Parse here and\n\t\t\t// verify the struct field default is correctly declared instead.)\n\t\t\tvar app lookbackShape\n\t\t\t//\n\t\t\t// The libargument library applies defaults when Parse is called.\n\t\t\t// We verify the default is 7 by inspecting the field tag; the\n\t\t\t// actual value after Parse depends on execution order (the env-override\n\t\t\t// It may have already run and left env=3 set via the shared restore\n\t\t\t// closure).  The definitive proof that the default tag is honoured\n\t\t\t// lives in the Parse result from the env-override test above.\n\t\t\tExpect(app.SupersedeLookback).To(Equal(0)) // zero-value before Parse\n\n\t\t\t// Verify the tag declares default:\"7\"\n\t\t\tExpect(reflect.TypeOf(app).FieldByName(\"SupersedeLookback\").Tag.Get(\"default\")).To(Equal(\"7\"))\n\n\t\t\t// Verify os.Getenv confirms env is not set\n\t\t\t_, hadEnv := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tExpect(hadEnv).To(BeFalse())\n\n\t\t\t// Re-run Parse in isolation with env definitively unset to prove\n\t\t\t// the default applies.  Save/restore SUPERSEDE_LOOKBACK across this\n\t\t\t// call to keep the global env clean.\n\t\t\t_ = envVal // silence unused warning\n\t\t\tsaved, hadSave := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tif hadSave {\n\t\t\t\tos.Unsetenv(\"SUPERSEDE_LOOKBACK\")\n\t\t\t}\n\t\t\tvar app2 lookbackShape\n\t\t\terr := libargument.Parse(context.Background(), &app2)\n\t\t\tif hadSave {\n\t\t\t\tos.Setenv(\"SUPERSEDE_LOOKBACK\", saved)\n\t\t\t}\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(app2.SupersedeLookback).To(Equal(7))\n\t\t})\n\t})\n})\n","structuredPatch":[{"oldStart":7,"oldLines":7,"newStart":7,"newLines":7,"lines":[" import (","   \"context\"","   \"os\"","-  \"strconv\"","+  \"reflect\""," ","   libargument \"github.com/bborbe/argument/v2\"","   . \"github.com/onsi/ginkgo/v2\""]}],"userModified":false,"replaceAll":false}}
