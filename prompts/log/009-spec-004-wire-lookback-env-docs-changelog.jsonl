he struct field.\n\tContext(\"with SUPERSEDE_LOOKBACK=3 set\", func() {\n\t\tvar restoreEnv func()\n\t\tBeforeEach(func() {\n\t\t\t_, had := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\torig, _ := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tExpect(os.Setenv(\"SUPERSEDE_LOOKBACK\", \"3\")).To(Succeed())\n\t\t\trestoreEnv = func() {\n\t\t\t\tif had {\n\t\t\t\t\tos.Setenv(\"SUPERSEDE_LOOKBACK\", orig)\n\t\t\t\t} else {\n\t\t\t\t\tos.Unsetenv(\"SUPERSEDE_LOOKBACK\")\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t\tAfterEach(func() { restoreEnv() })\n\n\t\tIt(\"honors the env override\", func() {\n\t\t\tvar app lookbackShape\n\t\t\terr := libargument.Parse(context.Background(), &app)\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(app.SupersedeLookback).To(Equal(3))\n\t\t})\n\t})\n\n\tContext(\"when env var is unset\", func() {\n\t\tvar restoreEnv func()\n\t\tBeforeEach(func() {\n\t\t\t_, had := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\torig, _ := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tExpect(os.Unsetenv(\"SUPERSEDE_LOOKBACK\")).To(Succeed())\n\t\t\trestoreEnv = func() {\n\t\t\t\tif had {\n\t\t\t\t\tos.Setenv(\"SUPERSEDE_LOOKBACK\", orig)\n\t\t\t\t} else {\n\t\t\t\t\tos.Unsetenv(\"SUPERSEDE_LOOKBACK\")\n\t\t\t\t}\n\t\t\t}\n\t\t})\n\t\tAfterEach(func() { restoreEnv() })\n\n\t\t// Parse has already been called by the sibling It above (Ginkgo randomises\n\t\t// order; this It may run first).  After Parse, the field holds the\n\t\t// default and os.Getenv confirms the env was empty.\n\t\tIt(\"applies the default value 7\", func() {\n\t\t\t// The env is definitively unset here (BeforeEach ran os.Unsetenv above).\n\t\t\t// Confirm os.Getenv agrees so the test precondition is clear.\n\t\t\t_, hadEnv := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tExpect(hadEnv).To(BeFalse())\n\n\t\t\t// Verify the struct field tag declares default:\"7\"\n\t\t\tExpect(reflect.TypeOf(lookbackShape{}).FieldByName(\"SupersedeLookback\").Tag.Get(\"default\")).To(Equal(\"7\"))\n\n\t\t\t// Parse has been called by the env-override It (Ginkgo randomises order;\n\t\t\t// this It may run first or second).  Confirm that when Parse IS called\n\t\t\t// with env unset, the default 7 is applied.  Save/restore SUPERSEDE_LOOKBACK\n\t\t\t// across this call to avoid contaminating the global flag state.\n\t\t\tsaved, hadSave := os.LookupEnv(\"SUPERSEDE_LOOKBACK\")\n\t\t\tif hadSave {\n\t\t\t\tos.Unsetenv(\"SUPERSEDE_LOOKBACK\")\n\t\t\t}\n\t\t\tvar app lookbackShape\n\t\t\terr := libargument.Parse(context.Background(), &app)\n\t\t\tif hadSave {\n\t\t\t\tos.Setenv(\"SUPERSEDE_LOOKBACK\", saved)\n\t\t\t}\n\t\t\tExpect(err).NotTo(HaveOccurred())\n\t\t\tExpect(app.SupersedeLookback).To(Equal(7))\n\t\t})\n\t})\n})\n","structuredPatch":[{"oldStart":75,"oldLines":7,"newStart":75,"newLines":9,"lines":["       Expect(hadEnv).To(BeFalse())"," ","       // Verify the struct field tag declares default:\"7\"","-      Expect(reflect.TypeOf(lookbackShape{}).FieldByName(\"SupersedeLookback\").Tag.Get(\"default\")).To(Equal(\"7\"))","+      f, ok := reflect.TypeOf(lookbackShape{}).FieldByName(\"SupersedeLookback\")","+      Expect(ok).To(BeTrue())","+      Expect(f.Tag.Get(\"default\")).To(Equal(\"7\"))"," ","       // Parse has been called by the env-override It (Ginkgo randomises order;","       // this It may run first or second).  Confirm that when Parse IS called"]}],"userModified":false,"replaceAll":false}}
