dle(ctx context.Context, req lib.Task) (handled bool, err error)\n46\t}\n47\t\n48\t// NewPlanningRetryGate constructs the gate.\n49\tfunc NewPlanningRetryGate(\n50\t\tgitClient gitclient.GitClient,\n51\t\ttaskDir string,\n52\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n53\t) PlanningRetryGate {\n54\t\treturn &planningRetryGate{\n55\t\t\tgitClient:       gitClient,\n56\t\t\ttaskDir:         taskDir,\n57\t\t\tcurrentDateTime: currentDateTime,\n58\t\t}\n59\t}\n60\t\n61\ttype planningRetryGate struct {\n62\t\tgitClient       gitclient.GitClient\n63\t\ttaskDir         string\n64\t\tcurrentDateTime libtime.CurrentDateTimeGetter\n65\t}\n66\t\n67\t// retryLineRE matches the frozen \"retry N/3: <reason> at <timestamp>\" bullet line.\n68\t// The leading \"- \" bullet marker is stripped before matching.\n69\tvar retryLineRE = regexp.MustCompile(`(?m)^- retry \\d+/3: .* at [0-9T:+-]+$`)\n70\t\n71\tfunc (g *planningRetryGate) Handle(ctx context.Context, req lib.Task) (handled bool, err error) {\n72\t\tif !g.matchesRetryGate(req) {\n73\t\t\treturn false, nil\n74\t\t}\n75\t\n76\t\trelPath, existingFrontmatter, findErr := result.FindTaskFilePath(\n77\t\t\tctx, g.gitClient, g.taskDir, req.TaskIdentifier,\n78\t\t)\n79\t\tif findErr != nil {\n80\t\t\treturn false, errors.Wrapf(ctx, findErr, \"planning-retry: find task file\")\n81\t\t}\n82\t\tif relPath == \"\" {\n83\t\t\tglog.Warningf(\"planning-retry: task file not found for %s; skipping\", req.TaskIdentifier)\n84\t\t\treturn false, nil\n85\t\t}\n86\t\n87\t\tcount, _ := existingFrontmatter.Int(\"planning_retry_count\")\n88\t\tif count < 0 {\n89\t\t\tcount = 0\n90\t\t}\n91\t\n92\t\tif count >= maxControllerPlanningRetries {\n93\t\t\tglog.V(2).Infof(\"planning-retry: counter at cap (%d) for %s; exhaustion escalation ships in prompt 2, falling through\", count, req.TaskIdentifier)\n94\t\t\treturn false, nil\n95\t\t}\n96\t\n97\t\treason := g.extractReason(req.Content)\n98\t\tbump := false\n99\t\tts := g.currentDateTime.Now().UTC().