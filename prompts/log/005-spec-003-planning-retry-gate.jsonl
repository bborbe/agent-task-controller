{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_fkon1sckyoar_3","type":"tool_result","content":"1\t// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n2\t// Use of this source code is governed by a BSD-style\n3\t// license that can be found in the LICENSE file.\n4\t\n5\tpackage result\n6\t\n7\timport (\n8\t\t\"context\"\n9\t\t\"fmt\"\n10\t\t\"path/filepath\"\n11\t\t\"strings\"\n12\t\t\"time\"\n13\t\n14\t\tlib \"github.com/bborbe/agent\"\n15\t\t\"github.com/bborbe/errors\"\n16\t\tlibtime \"github.com/bborbe/time\"\n17\t\t\"github.com/golang/glog\"\n18\t\t\"gopkg.in/yaml.v3\"\n19\t\n20\t\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n21\t\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n22\t)\n23\t\n24\t//counterfeiter:generate -o ../../mocks/result_writer.go --fake-name ResultWriter . ResultWriter\n25\t\n26\t// ResultWriter writes a Task back to the vault task file.\n27\ttype ResultWriter interface {\n28\t\tWriteResult(ctx context.Context, req lib.Task) error\n29\t}\n30\t\n31\t// NewResultWriter creates a ResultWriter that locates task files in the vault\n32\t// and writes the result, committing via gitClient.\n33\tfunc NewResultWriter(\n34\t\tgitClient gitclient.GitClient,\n35\t\ttaskDir string,\n36\t\tcurrentDateTime libtime.CurrentDateTimeGetter,\n37\t) ResultWriter {\n38\t\treturn &resultWriter{\n39\t\t\tgitClient:       gitClient,\n40\t\t\ttaskDir:         taskDir,\n41\t\t\tcurrentDateTime: currentDateTime,\n42\t\t}\n43\t}\n44\t\n45\ttype resultWriter struct {\n46\t\tgitClient       gitclient.GitClient\n47\t\ttaskDir         string\n48\t\tcurrentDateTime libtime.CurrentDateTimeGetter\n49\t}\n50\t\n51\t// FindTaskFilePath lists files in taskDir via gitClient and returns the relative path of\n52\t// the .md file whose frontmatter has task_identifier == id, plus the parsed existing frontmatter.\n53\t// Returns (\"\", nil, nil) when no match is found (not an error).\n54\tfunc FindTaskFilePath(\n55\t\tctx context.Context,\n56\t\tgitClient gitclient.GitClient,\n57\t\ttaskDir string,\n58\t\tid lib.TaskIdentifier,\n59\t) (string, lib.TaskFrontmatter, error) {\n60\t\tglob := taskDir + \"/*.md\"\n61\t\tpaths, err := gitClient.ListFiles(ctx, glob)\n62\t\tif err != nil {\n63\t\t\treturn \"\", nil, errors.Wrapf(ctx, err, \"list task files with glob %s\", glob)\n64\t\t}\n65\t\tvar matchedRelPath string\n66\t\tvar existingFrontmatter lib.TaskFrontmatter\n67\t\tfor _, relPath := range paths {\n68\t\t\tcontent, readErr := gitClient.ReadFile(ctx, relPath)\n69\t\t\tif readErr != nil {\n70\t\t\t\tglog.V(3).Infof(\"FindTaskFilePath: skip %s (read error: %v)\", relPath, readErr)\n71\t\t\t\tcontinue\n72\t\t\t}\n73\t\t\tfrontmatter, fmErr := ExtractFrontmatter(ctx, content)\n74\t\t\tif fmErr != nil {\n75\t\t\t\tglog.V(3).Infof(\"FindTaskFilePath: skip %s (frontmatter error: %v)\", relPath, fmErr)\n76\t\t\t\tcontinue\n77\t\t\t}\n78\t\t\tvar fm struct {\n79\t\t\t\tTaskIdentifier string `yaml:\"task_identifier\"`\n80\t\t\t}\n81\t\t\tif umErr := yaml.Unmarshal([]byte(frontmatter), &fm); umErr != nil {\n82\t\t\t\tglog.V(3).Infof(\"FindTaskFilePath: skip %s (unmarshal error: %v)\", relPath, umErr)\n83\t\t\t\tcontinue\n84\t\t\t}\n85\t\t\tglog.V(3).\n86\t\t\t\tInfof(\"FindTaskFilePath: file %s has task_identifier=%s\", relPath, fm.TaskIdentifier)\n87\t\t\tif lib.TaskIdentifier(fm.TaskIdentifier) == id {\n88\t\t\t\tmatchedRelPath = relPath\n89\t\t\t\tglog.V(2).Infof(\"FindTaskFilePath: matched file %s for task %s\", matchedRelPath, id)\n90\t\t\t\tvar existingFm lib.TaskFrontmatter\n91\t\t\t\tif umErr := yaml.Unmarshal([]byte(frontmatter), &existingFm); umErr != nil {\n92\t\t\t\t\tglog.V(3).\n93\t\t\t\t\t\tInfof(\"FindTaskFilePath: could not unmarshal existing frontmatter for %s: %v\", relPath, umErr)\n94\t\t\t\t} else {\n95\t\t\t\t\texistingFrontmatter = existingFm\n96\t\t\t\t}\n97\t\t\t}\n98\t\t}\n99\t\treturn matchedRelPath, existingFrontmatter, nil\n100\t}\n101\t\n102\tfunc (r *resultWriter) WriteResult(ctx context.Context, req lib.Task) error {\n103\t\tglog.V(2).Infof(\"WriteResult: starting for task %s\", req.TaskIdentifier)\n104\t\tglog.V(3).Infof(\"WriteResult: scanning taskDir=%s\", r.taskDir)\n105\t\n106\t\tmatchedRelPath, _, err := FindTaskFilePath(\n107\t\t\tctx,\n108\t\t\tr.gitClient,\n109\t\t\tr.taskDir,\n110\t\t\treq.TaskIdentifier,\n111\t\t)\n112\t\tif err != nil {\n113\t\t\treturn errors.Wrapf(ctx, err, \"find task file path failed\")\n114\t\t}\n115\t\n116\t\tif matchedRelPath == \"\" {\n117\t\t\tglog.Warningf(\"task file not found for identifier %s, skipping\", req.TaskIdentifier)\n118\t\t\tmetrics.ResultsWrittenTotal.WithLabelValues(\"not_found\").Inc()\n119\t\t\treturn nil\n120\t\t}\n121\t\n122\t\tabsPath := filepath.Join(r.gitClient.Path(), matchedRelPath)\n123\t\tcommitMessage := fmt.Sprintf(\n124\t\t\t\"[agent-task-controller] write result for task %s\",\n125\t\t\treq.TaskIdentifier,\n126\t\t)\n127\t\tglog.V(2).Infof(\"WriteResult: writing and pushing for task %s\", req.TaskIdentifier)\n128\t\tif err := r.gitClient.AtomicReadModifyWriteAndCommitPush(\n129\t\t\tctx,\n130\t\t\tabsPath,\n131\t\t\tr.buildResultModifyFn(ctx, req),\n132\t\t\tcommitMessage,\n133\t\t); err != nil {\n134\t\t\tmetrics.ResultsWrittenTotal.WithLabelValues(\"error\").Inc()\n135\t\t\treturn errors.Wrapf(ctx, err, \"atomic read-modify-write and push failed\")\n136\t\t}\n137\t\n138\t\tglog.V(2).Infof(\"WriteResult: completed successfully for task %s\", req.TaskIdentifier)\n139\t\tmetrics.ResultsWrittenTotal.WithLabelValues(\"success\").Inc()\n140\t\treturn nil\n141\t}\n142\t\n143\t// buildResultModifyFn returns a modify callback for AtomicReadModifyWriteAndCommitPush\n144\t// that re-reads the on-disk frontmatter+body on every git retry, then applies the\n145\t// merge / retry-counter / cap rules. Re-reading per retry eliminates the read-then-write\n146\t// race against the partial-update executor (task_update_frontmatter_executor.go) that\n147\t// previously caused stale-snapshot writes to roll back terminal status.\n148\tfunc (r *resultWriter) buildResultModifyFn(\n149\t\tctx context.Context,\n150\t\treq lib.Task,\n151\t) func(current []byte) ([]byte, error) {\n152\t\treturn func(current []byte) ([]byte, error) {\n153\t\t\tfrontmatterStr, err := ExtractFrontmatter(ctx, current)\n154\t\t\tif err != nil {\n155\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract frontmatter\")\n156\t\t\t}\n157\t\t\tbodyStr, err := ExtractBody(ctx, current)\n158\t\t\tif err != nil {\n159\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract body\")\n160\t\t\t}\n161\t\t\tvar currentOnDisk lib.TaskFrontmatter\n162\t\t\t// NOTE: inlined yaml ops mirror the pre-race version of WriteResult; pkg/command/ helpers\n163\t\t\t// are unexported and the lift-and-share is out of scope for this race fix.\n164\t\t\tif err := yaml.Unmarshal([]byte(frontmatterStr), &currentOnDisk); err != nil {\n165\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"unmarshal current frontmatter\")\n166\t\t\t}\n167\t\n168\t\t\tmerged := mergeFrontmatter(currentOnDisk, req.Frontmatter)\n169\t\t\tbody := r.applyRetryCounter(merged, currentOnDisk, string(req.Content))\n170\t\n171\t\t\tmarshaledFrontmatter, err := yaml.Marshal(map[string]any(merged))\n172\t\t\tif err != nil {\n173\t\t\t\treturn nil, errors.Wrapf(ctx, err, \"marshal frontmatter\")\n174\t\t\t}\n175\t\t\t// Discard the on-disk body — WriteResult fully replaces body with req.Content\n176\t\t\t// (post-applyRetryCounter modifications), matching the prior single-write\n177\t\t\t// semantics. bodyStr is read above only to validate the file has well-formed\n178\t\t\t// delimiters; an extraction error must surface so we do not silently overwrite a\n179\t\t\t// corrupted file.\n180\t\t\t_ = bodyStr\n181\t\t\treturn []byte(\"---\\n\" + string(marshaledFrontmatter) + \"---\\n\" + body), nil\n182\t\t}\n183\t}\n184\t\n185\tfunc (r *resultWriter) applyRetryCounter(merged, existing lib.TaskFrontmatter, body string) string {\n186\t\tif string(merged.Status()) == \"completed\" {\n187\t\t\treturn body\n188\t\t}\n189\t\n190\t\t// Trigger-count cap enforcement runs unconditionally before any early\n191\t\t// returns below: it is a derived invariant on the on-disk state that\n192\t\t// must hold after every WriteResult. Placing it here also prevents the\n193\t\t// spawn_notification short-circuit below from silently skipping\n194\t\t// escalation on agent result writes that inherited spawn_notification\n195\t\t// from a previous merge (observed live on dev 2026-04-24, task\n196\t\t// ba1bad61: spawn-notification update set spawn_notification=true,\n197\t\t// then the agent's result publish inherited it via mergeFrontmatter\n198\t\t// and skipped the cap check, reverting phase: human_review to\n199\t\t// ai_review). The triggerCount > 0 guard prevents degenerate\n200\t\t// escalation of brand-new tasks where trigger_count is absent.\n201\t\ttriggerCount := merged.TriggerCount()\n202\t\tbody = r.applyTriggerCap(merged, existing, triggerCount, body)\n203\t\n204\t\t// human_review assignee-clear guard runs BEFORE the spawn_notification\n205\t\t// early return below. On a pr-reviewer agent's first post-spawn write, the merged\n206\t\t// frontmatter carries spawn_notification: true (inherited from the executor's\n207\t\t// spawn-time UpdateFrontmatterCommand) AND incoming phase: human_review (from\n208\t\t// Result.NextPhase via resolveNextPhase). If this guard were below the\n209\t\t// spawn_notification early return, clearAssignee would never fire and the\n210\t\t// operator inbox filter (assignee == \"\") would miss the task. Same bug class\n211\t\t// as prompt 075 (2026-04-24 applyTriggerCap precedent, task ba1bad61); spec 041\n212\t\t// fixes the 2026-05-25 prod incident (task bborbe-agent #3).\n213\t\t// needs_input: agent explicitly requested human review — clear assignee so task surfaces in operator inbox.\n214\t\t// Routes through ClearAssigneeIfHumanReview (spec 042) so the partial-update executor shares the same chokepoint.\n215\t\tClearAssigneeIfHumanReview(merged)\n216\t\n217\t\tif merged.SpawnNotification() {\n218\t\t\tdelete(merged, \"spawn_notification\")\n219\t\t\treturn body\n220\t\t}\n221\t\n222\t\t// retry_count is authoritative in the task file — the executor bumped it\n223\t\t// at spawn time (spec 011). The writer only applies escalation.\n224\t\tretryCount := merged.RetryCount()\n225\t\tbody = r.applyRetryCap(merged, existing, retryCount, body)\n226\t\n227\t\treturn body\n228\t}\n229\t\n230\t// applyTriggerCap enforces the trigger-count cap. The triggerCount > 0 guard prevents\n231\t// degenerate escalation of brand-new tasks where trigger_count is absent. When the task\n232\t// is already parked (section present), existing.Phase() restores the on-disk lifecycle\n233\t// phase to prevent stale-result phase clobber (cap stickiness).\n234\tfunc (r *resultWriter) applyTriggerCap(\n235\t\tmerged, existing lib.TaskFrontmatter,\n236\t\ttriggerCount int,\n237\t\tbody string,\n238\t) string {\n239\t\tif triggerCount == 0 || triggerCount < merged.MaxTriggers() {\n240\t\t\treturn body\n241\t\t}\n242\t\tagentName := clearAssignee(merged)\n243\t\tif containsEscalationSection(body, \"## Trigger Cap Escalation\") {\n244\t\t\trestoreExistingPhase(existing, merged)\n245\t\t\treturn body\n246\t\t}\n247\t\treturn body + r.triggerEscalationSection(triggerCount, agentName, merged)\n248\t}\n249\t\n250\t// applyRetryCap enforces the retry-count cap. When the task is already parked (section\n251\t// present), existing.Phase() restores the on-disk lifecycle phase (cap stickiness).\n252\tfunc (r *resultWriter) applyRetryCap(\n253\t\tmerged, existing lib.TaskFrontmatter,\n254\t\tretryCount int,\n255\t\tbody string,\n256\t) string {\n257\t\tif retryCount < merged.MaxRetries() {\n258\t\t\treturn body\n259\t\t}\n260\t\tagentName := clearAssignee(merged)\n261\t\tif containsEscalationSection(body, \"## Retry Escalation\") {\n262\t\t\trestoreExistingPhase(existing, merged)\n263\t\t\treturn body\n264\t\t}\n265\t\treturn body + r.escalationSection(retryCount, agentName)\n266\t}\n267\t\n268\t// clearAssignee sets previous_assignee to the current assignee value (if non-empty),\n269\t// then clears assignee to \"\". Returns the captured name for use in escalation body text.\n270\t// This is the single chokepoint for all assignee-clear operations in the result writer.\n271\tfunc clearAssignee(merged lib.TaskFrontmatter) string {\n272\t\tagentName := string(merged.Assignee())\n273\t\tif agentName != \"\" {\n274\t\t\tmerged[\"previous_assignee\"] = agentName\n275\t\t}\n276\t\tmerged[\"assignee\"] = \"\"\n277\t\treturn agentName\n278\t}\n279\t\n280\t// ClearAssigneeIfHumanReview enforces the spec-039 / spec-042 doctrine:\n281\t// when merged frontmatter has phase == \"human_review\", clear assignee via\n282\t// clearAssignee (which captures the prior assignee into previous_assignee\n283\t// if non-empty, then sets assignee to \"\"). Returns the prior assignee\n284\t// name (empty string when no clear happened OR when the prior assignee\n285\t// was already empty). This is the single chokepoint for the human_review\n286\t// assignee-clear invariant; both the result writer and the partial-update\n287\t// executor (spec 042) route through here.\n288\tfunc ClearAssigneeIfHumanReview(merged lib.TaskFrontmatter) string {\n289\t\tif phase, ok := merged[\"phase\"].(string); ok && phase == \"human_review\" {\n290\t\t\treturn clearAssignee(merged)\n291\t\t}\n292\t\treturn \"\"\n293\t}\n294\t\n295\t// restoreExistingPhase writes the on-disk phase back into merged when the existing\n296\t// frontmatter has a phase value. Used to enforce cap stickiness on repeated writes.\n297\tfunc restoreExistingPhase(existing, merged lib.TaskFrontmatter) {\n298\t\tif p := existing.Phase(); p != nil {\n299\t\t\tmerged[\"phase\"] = string(*p)\n300\t\t}\n301\t}\n302\t\n303\tfunc (r *resultWriter) escalationSection(retryCount int, agentName string) string {\n304\t\tts := r.currentDateTime.Now().UTC().Format(time.RFC3339)\n305\t\treturn fmt.Sprintf(\n306\t\t\t\"\\n## Retry Escalation\\n\\n- **Timestamp:** %s\\n- **Attempts:** %d\\n- **Assignee:** %s\\n- **Last error:** see agent output above\\n\",\n307\t\t\tts,\n308\t\t\tretryCount,\n309\t\t\tagentName,\n310\t\t)\n311\t}\n312\t\n313\tfunc (r *resultWriter) triggerEscalationSection(\n314\t\ttriggerCount int,\n315\t\tagentName string,\n316\t\tmerged lib.TaskFrontmatter,\n317\t) string {\n318\t\tts := r.currentDateTime.Now().UTC().Format(time.RFC3339)\n319\t\treturn fmt.Sprintf(\n320\t\t\t\"\\n## Trigger Cap Escalation\\n\\n- **Timestamp:** %s\\n- **Trigger count:** %d\\n- **Max triggers:** %d\\n- **Assignee:** %s\\n- **Last agent output:** see `## Result` above\\n\",\n321\t\t\tts,\n322\t\t\ttriggerCount,\n323\t\t\tmerged.MaxTriggers(),\n324\t\t\tagentName,\n325\t\t)\n326\t}\n327\t\n328\t// containsEscalationSection reports whether body already has the given\n329\t// escalation header on its own line. Used to prevent duplicate escalation\n330\t// sections when WriteResult runs multiple times on a task that is already\n331\t// at cap (e.g. agent publishes another result while the task sits in\n332\t// phase: human_review).\n333\tfunc containsEscalationSection(body, header string) bool {\n334\t\treturn strings.Contains(body, \"\\n\"+header+\"\\n\")\n335\t}\n336\t\n337\t// mergeFrontmatter returns a new frontmatter map with all keys from existing,\n338\t// overridden by all keys from incoming. Neither input map is modified.\n339\tfunc mergeFrontmatter(existing, incoming lib.TaskFrontmatter) lib.TaskFrontmatter {\n340\t\tmerged := make(lib.TaskFrontmatter, len(existing)+len(incoming))\n341\t\tfor k, v := range existing {\n342\t\t\tmerged[k] = v\n343\t\t}\n344\t\tfor k, v := range incoming {\n345\t\t\tmerged[k] = v\n346\t\t}\n347\t\treturn merged\n348\t}\n349\t\n350\t// ExtractFrontmatter returns the YAML frontmatter string between the opening and\n351\t// closing \"---\" delimiters. Returns an error if delimiters are missing.\n352\tfunc ExtractFrontmatter(ctx context.Context, content []byte) (string, error) {\n353\t\ts := string(content)\n354\t\tconst delim = \"---\"\n355\t\tif !strings.HasPrefix(s, delim) {\n356\t\t\treturn \"\", errors.Errorf(ctx, \"no frontmatter delimiter found\")\n357\t\t}\n358\t\trest := strings.TrimPrefix(s, delim)\n359\t\tif strings.HasPrefix(rest, \"\\r\\n\") {\n360\t\t\trest = rest[2:]\n361\t\t} else if strings.HasPrefix(rest, \"\\n\") {\n362\t\t\trest = rest[1:]\n363\t\t}\n364\t\tbefore, _, found := strings.Cut(rest, \"\\n---\")\n365\t\tif !found {\n366\t\t\treturn \"\", errors.Errorf(ctx, \"frontmatter not closed\")\n367\t\t}\n368\t\treturn before, nil\n369\t}\n370\t\n371\t// ExtractBody returns the file body — the bytes after the closing \"---\\n\" delimiter.\n372\t// Returns an empty string if the body is empty; error if delimiters are missing.\n373\tfunc ExtractBody(ctx context.Context, content []byte) (string, error) {\n374\t\ts := string(content)\n375\t\tconst delim = \"---\"\n376\t\tif !strings.HasPrefix(s, delim) {\n377\t\t\treturn \"\", errors.Errorf(ctx, \"no frontmatter delimiter found\")\n378\t\t}\n379\t\trest := strings.TrimPrefix(s, delim)\n380\t\tif strings.HasPrefix(rest, \"\\r\\n\") {\n381\t\t\trest = rest[2:]\n382\t\t} else if strings.HasPrefix(rest, \"\\n\") {\n383\t\t\trest = rest[1:]\n384\t\t}\n385\t\t_, after, found := strings.Cut(rest, \"\\n---\\n\")\n386\t\tif !found {\n387\t\t\treturn \"\", errors.Errorf(ctx, \"frontmatter not closed\")\n388\t\t}\n389\t\treturn after, nil\n390\t}\n391\t"}]},"parent_tool_use_id":null,"session_id":"f5cbbde6-249d-4959-8c10-2d095dee03df","uuid":"c0df8d9f-70bf-4f8b-bbf5-9ee0d03e8dca","timestamp":"2026-07-01T12:26:54.051Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pkg/result/result_writer.go","content":"// Copyright (c) 2026 Benjamin Borbe All rights reserved.\n// Use of this source code is governed by a BSD-style\n// license that can be found in the LICENSE file.\n\npackage result\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tlib \"github.com/bborbe/agent\"\n\t\"github.com/bborbe/errors\"\n\tlibtime \"github.com/bborbe/time\"\n\t\"github.com/golang/glog\"\n\t\"gopkg.in/yaml.v3\"\n\n\tgitclient \"github.com/bborbe/agent-task-controller/pkg/gitrestclient\"\n\t\"github.com/bborbe/agent-task-controller/pkg/metrics\"\n)\n\n//counterfeiter:generate -o ../../mocks/result_writer.go --fake-name ResultWriter . ResultWriter\n\n// ResultWriter writes a Task back to the vault task file.\ntype ResultWriter interface {\n\tWriteResult(ctx context.Context, req lib.Task) error\n}\n\n// NewResultWriter creates a ResultWriter that locates task files in the vault\n// and writes the result, committing via gitClient.\nfunc NewResultWriter(\n\tgitClient gitclient.GitClient,\n\ttaskDir string,\n\tcurrentDateTime libtime.CurrentDateTimeGetter,\n) ResultWriter {\n\treturn &resultWriter{\n\t\tgitClient:       gitClient,\n\t\ttaskDir:         taskDir,\n\t\tcurrentDateTime: currentDateTime,\n\t}\n}\n\ntype resultWriter struct {\n\tgitClient       gitclient.GitClient\n\ttaskDir         string\n\tcurrentDateTime libtime.CurrentDateTimeGetter\n}\n\n// FindTaskFilePath lists files in taskDir via gitClient and returns the relative path of\n// the .md file whose frontmatter has task_identifier == id, plus the parsed existing frontmatter.\n// Returns (\"\", nil, nil) when no match is found (not an error).\nfunc FindTaskFilePath(\n\tctx context.Context,\n\tgitClient gitclient.GitClient,\n\ttaskDir string,\n\tid lib.TaskIdentifier,\n) (string, lib.TaskFrontmatter, error) {\n\tglob := taskDir + \"/*.md\"\n\tpaths, err := gitClient.ListFiles(ctx, glob)\n\tif err != nil {\n\t\treturn \"\", nil, errors.Wrapf(ctx, err, \"list task files with glob %s\", glob)\n\t}\n\tvar matchedRelPath string\n\tvar existingFrontmatter lib.TaskFrontmatter\n\tfor _, relPath := range paths {\n\t\tcontent, readErr := gitClient.ReadFile(ctx, relPath)\n\t\tif readErr != nil {\n\t\t\tglog.V(3).Infof(\"FindTaskFilePath: skip %s (read error: %v)\", relPath, readErr)\n\t\t\tcontinue\n\t\t}\n\t\tfrontmatter, fmErr := ExtractFrontmatter(ctx, content)\n\t\tif fmErr != nil {\n\t\t\tglog.V(3).Infof(\"FindTaskFilePath: skip %s (frontmatter error: %v)\", relPath, fmErr)\n\t\t\tcontinue\n\t\t}\n\t\tvar fm struct {\n\t\t\tTaskIdentifier string `yaml:\"task_identifier\"`\n\t\t}\n\t\tif umErr := yaml.Unmarshal([]byte(frontmatter), &fm); umErr != nil {\n\t\t\tglog.V(3).Infof(\"FindTaskFilePath: skip %s (unmarshal error: %v)\", relPath, umErr)\n\t\t\tcontinue\n\t\t}\n\t\tglog.V(3).\n\t\t\tInfof(\"FindTaskFilePath: file %s has task_identifier=%s\", relPath, fm.TaskIdentifier)\n\t\tif lib.TaskIdentifier(fm.TaskIdentifier) == id {\n\t\t\tmatchedRelPath = relPath\n\t\t\tglog.V(2).Infof(\"FindTaskFilePath: matched file %s for task %s\", matchedRelPath, id)\n\t\t\tvar existingFm lib.TaskFrontmatter\n\t\t\tif umErr := yaml.Unmarshal([]byte(frontmatter), &existingFm); umErr != nil {\n\t\t\t\tglog.V(3).\n\t\t\t\t\tInfof(\"FindTaskFilePath: could not unmarshal existing frontmatter for %s: %v\", relPath, umErr)\n\t\t\t} else {\n\t\t\t\texistingFrontmatter = existingFm\n\t\t\t}\n\t\t}\n\t}\n\treturn matchedRelPath, existingFrontmatter, nil\n}\n\nfunc (r *resultWriter) WriteResult(ctx context.Context, req lib.Task) error {\n\tglog.V(2).Infof(\"WriteResult: starting for task %s\", req.TaskIdentifier)\n\tglog.V(3).Infof(\"WriteResult: scanning taskDir=%s\", r.taskDir)\n\n\tmatchedRelPath, _, err := FindTaskFilePath(\n\t\tctx,\n\t\tr.gitClient,\n\t\tr.taskDir,\n\t\treq.TaskIdentifier,\n\t)\n\tif err != nil {\n\t\treturn errors.Wrapf(ctx, err, \"find task file path failed\")\n\t}\n\n\tif matchedRelPath == \"\" {\n\t\tglog.Warningf(\"task file not found for identifier %s, skipping\", req.TaskIdentifier)\n\t\tmetrics.ResultsWrittenTotal.WithLabelValues(\"not_found\").Inc()\n\t\treturn nil\n\t}\n\n\tabsPath := filepath.Join(r.gitClient.Path(), matchedRelPath)\n\tcommitMessage := fmt.Sprintf(\n\t\t\"[agent-task-controller] write result for task %s\",\n\t\treq.TaskIdentifier,\n\t)\n\tglog.V(2).Infof(\"WriteResult: writing and pushing for task %s\", req.TaskIdentifier)\n\tif err := r.gitClient.AtomicReadModifyWriteAndCommitPush(\n\t\tctx,\n\t\tabsPath,\n\t\tr.buildResultModifyFn(ctx, req),\n\t\tcommitMessage,\n\t); err != nil {\n\t\tmetrics.ResultsWrittenTotal.WithLabelValues(\"error\").Inc()\n\t\treturn errors.Wrapf(ctx, err, \"atomic read-modify-write and push failed\")\n\t}\n\n\tglog.V(2).Infof(\"WriteResult: completed successfully for task %s\", req.TaskIdentifier)\n\tmetrics.ResultsWrittenTotal.WithLabelValues(\"success\").Inc()\n\treturn nil\n}\n\n// buildResultModifyFn returns a modify callback for AtomicReadModifyWriteAndCommitPush\n// that re-reads the on-disk frontmatter+body on every git retry, then applies the\n// merge / retry-counter / cap rules. Re-reading per retry eliminates the read-then-write\n// race against the partial-update executor (task_update_frontmatter_executor.go) that\n// previously caused stale-snapshot writes to roll back terminal status.\nfunc (r *resultWriter) buildResultModifyFn(\n\tctx context.Context,\n\treq lib.Task,\n) func(current []byte) ([]byte, error) {\n\treturn func(current []byte) ([]byte, error) {\n\t\tfrontmatterStr, err := ExtractFrontmatter(ctx, current)\n\t\tif err != nil {\n\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract frontmatter\")\n\t\t}\n\t\tbodyStr, err := ExtractBody(ctx, current)\n\t\tif err != nil {\n\t\t\treturn nil, errors.Wrapf(ctx, err, \"extract body\")\n\t\t}\n\t\tvar currentOnDisk lib.TaskFrontmatter\n\t\t// NOTE: inlined yaml ops mirror the pre-race version of WriteResult; pkg/command/ helpers\n\t\t// are unexported and the lift-and-share is out of scope for this race fix.\n\t\tif err := yaml.Unmarshal([]byte(frontmatterStr), &currentOnDisk); err != nil {\n\t\t\treturn nil, errors.Wrapf(ctx, err, \"unmarshal current frontmatter\")\n\t\t}\n\n\t\tmerged := mergeFrontmatter(currentOnDisk, req.Frontmatter)\n\t\tbody := r.applyRetryCounter(merged, currentOnDisk, string(req.Content))\n\n\t\tmarshaledFrontmatter, err := yaml.Marshal(map[string]any(merged))\n\t\tif err != nil {\n\t\t\treturn nil, errors.Wrapf(ctx, err, \"marshal frontmatter\")\n\t\t}\n\t\t// Discard the on-disk body — WriteResult fully replaces body with req.Content\n\t\t// (post-applyRetryCounter modifications), matching the prior single-write\n\t\t// semantics. bodyStr is read above only to validate the file has well-formed\n\t\t// delimiters; an extraction error must surface so we do not silently overwrite a\n\t\t// corrupted file.\n\t\t_ = bodyStr\n\t\treturn []byte(\"---\\n\" + string(marshaledFrontmatter) + \"---\\n\" + body), nil\n\t}\n}\n\nfunc (r *resultWriter) applyRetryCounter(merged, existing lib.TaskFrontmatter, body string) string {\n\tif string(merged.Status()) == \"completed\" {\n\t\treturn body\n\t}\n\n\t// Trigger-count cap enforcement runs unconditionally before any early\n\t// returns below: it is a derived invariant on the on-disk state that\n\t// must hold after every WriteResult. Placing it here also prevents the\n\t// spawn_notification short-circuit below from silently skipping\n\t// escalation on agent result writes that inherited spawn_notification\n\t// from a previous merge (observed live on dev 2026-04-24, task\n\t// ba1bad61: spawn-notification update set spawn_notification=true,\n\t// then the agent's result publish inherited it via mergeFrontmatter\n\t// and skipped the cap check, reverting phase: human_review to\n\t// ai_review). The triggerCount > 0 guard prevents degenerate\n\t// escalation of brand-new tasks where trigger_count is absent.\n\ttriggerCount := merged.TriggerCount()\n\tbody = r.applyTriggerCap(merged, existing, triggerCount, body)\n\n\t// human_review assignee-clear guard runs BEFORE the spawn_notification\n\t// early return below. On a pr-reviewer agent's first post-spawn write, the merged\n\t// frontmatter carries spawn_notification: true (inherited from the executor's\n\t// spawn-time UpdateFrontmatterCommand) AND incoming phase: human_review (from\n\t// Result.NextPhase via resolveNextPhase). If this guard were below the\n\t// spawn_notification early return, clearAssignee would never fire and the\n\t// operator inbox filter (assignee == \"\") would miss the task. Same bug class\n\t// as prompt 075 (2026-04-24 applyTriggerCap precedent, task ba1bad61); spec 041\n\t// fixes the 2026-05-25 prod incident (task bborbe-agent #3).\n\t// needs_input: agent explicitly requested human review — clear assignee so task surfaces in operator inbox.\n\t// Routes through ClearAssigneeIfHumanReview (spec 042) so the partial-update executor shares the same chokepoint.\n\tClearAssigneeIfHumanReview(merged)\n\n\tif merged.SpawnNotification() {\n\t\tdelete(merged, \"spawn_notification\")\n\t\treturn body\n\t}\n\n\t// retry_count is authoritative in the task file — the executor bumped it\n\t// at spawn time (spec 011). The writer only applies escalation.\n\tretryCount := merged.RetryCount()\n\tbody = r.applyRetryCap(merged, existing, retryCount, body)\n\n\treturn body\n}\n\n// applyTriggerCap enforces the trigger-count cap. The triggerCount > 0 guard prevents\n// degenerate escalation of brand-new tasks where trigger_count is absent. When the task\n// is already parked (section present), existing.Phase() restores the on-disk lifecycle\n// phase to prevent stale-result phase clobber (cap stickiness).\nfunc (r *resultWriter) applyTriggerCap(\n\tmerged, existing lib.TaskFrontmatter,\n\ttriggerCount int,\n\tbody string,\n) string {\n\tif triggerCount == 0 || triggerCount < merged.MaxTriggers() {\n\t\treturn body\n\t}\n\tagentName := clearAssignee(merged)\n\tif containsEscalationSection(body, \"## Trigger Cap Escalation\") {\n\t\trestoreExistingPhase(existing, merged)\n\t\treturn body\n\t}\n\treturn body + r.triggerEscalationSection(triggerCount, agentName, merged)\n}\n\n// applyRetryCap enforces the retry-count cap. When the task is already parked (section\n// present), existing.Phase() restores the on-disk lifecycle phase (cap stickiness).\nfunc (r *resultWriter) applyRetryCap(\n\tmerged, existing lib.TaskFrontmatter,\n\tretryCount int,\n\tbody string,\n) string {\n\tif retryCount < merged.MaxRetries() {\n\t\treturn body\n\t}\n\tagentName := clearAssignee(merged)\n\tif containsEscalationSection(body, \"## Retry Escalation\") {\n\t\trestoreExistingPhase(existing, merged)\n\t\treturn body\n\t}\n\treturn body + r.escalationSection(retryCount, agentName)\n}\n\n// clearAssignee sets previous_assignee to the current assignee value (if non-empty),\n// then clears assignee to \"\". Returns the captured name for use in escalation body text.\n// This is the single chokepoint for all assignee-clear operations in the result writer.\nfunc clearAssignee(merged lib.TaskFrontmatter) string {\n\tagentName := string(merged.Assignee())\n\tif agentName != \"\" {\n\t\tmerged[\"previous_assignee\"] = agentName\n\t}\n\tmerged[\"assignee\"] = \"\"\n\treturn agentName\n}\n\n// ClearAssigneeIfHumanReview enforces the spec-039 / spec-042 doctrine:\n// when merged frontmatter has phase == \"human_review\", clear assignee via\n// clearAssignee (which captures the prior assignee into previous_assignee\n// if non-empty, then sets assignee to \"\"). Returns the prior assignee\n// name (empty string when no clear happened OR when the prior assignee\n// was already empty). This is the single chokepoint for the human_review\n// assignee-clear invariant; both the result writer and the partial-update\n// executor (spec 042) route through here.\nfunc ClearAssigneeIfHumanReview(merged lib.TaskFrontmatter) string {\n\tif phase, ok := merged[\"phase\"].(string); ok && phase == \"human_review\" {\n\t\treturn clearAssignee(merged)\n\t}\n\treturn \"\"\n}\n\n// restoreExistingPhase writes the on-disk phase back into merged when the existing\n// frontmatter