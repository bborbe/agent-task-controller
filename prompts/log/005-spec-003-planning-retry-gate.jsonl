n per-task serialization (Kafka partitioning by task_id).\n323\t\t// modify must return the new file bytes or an error.\n324\t\t// If modify returns an error, the file is not written and no commit is made.\n325\t\tAtomicReadModifyWriteAndCommitPush(\n326\t\t\tctx context.Context,\n327\t\t\tabsPath string,\n328\t\t\tmodify func(current []byte) ([]byte, error),\n329\t\t\tmessage string,\n330\t\t) error\n331\t\t// Path returns the local clone path.\n332\t\tPath() string\n333\t\t// ListFiles returns relative file paths under the repo root matching the single-level\n334\t\t// glob pattern (e.g. \"tasks/*.md\"). Paths are relative to the repo root.\n335\t\tListFiles(ctx context.Context, glob string) ([]string, error)\n336\t\t// ReadFile reads the file at relPath (relative to repo root, e.g. \"tasks/foo.md\")\n337\t\t// and returns its content.\n338\t\tReadFile(ctx context.Context, relPath string) ([]byte, error)\n339\t\t// WriteFile writes content to relPath (relative to repo root) on local disk.\n340\t\t// It does NOT commit or push — use AtomicWriteAndCommitPush for that.\n341\t\tWriteFile(ctx context.Context, relPath string, content []byte) error\n342\t}\n343\t\n344\t// IsReady checks git-rest's /readiness endpoint.\n345\tfunc (g *gitRestClient) IsReady(ctx context.Context) (bool, error) {\n346\t\treqURL := g.baseURL + \"/readiness\"\n347\t\treq, err := http.NewRequestWithContext(ctx, http.MethodGet, reqURL, nil)\n348\t\tif err != nil {\n349\t\t\tg.metrics.GitRestCallsTotal(\"readiness\", \"error\").Inc()"}]},"parent_tool_use_id":null,"session_id":"f5cbbde6-249d-4959-8c10-2d095dee03df","uuid":"1e208735-8a18-4617-8154-40ea742b1a98","timestamp":"2026-07-01T12:27:02.988Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/pkg/gitrestclient/git_rest_client.go","content":"\tif err := json.Unmarshal(body, &paths); err != nil {\n\t\tg.metrics.GitRestCallsTotal(\"list\", \"error\").Inc()\n\t\treturn nil, errors.Wrapf(ctx, err, \"parse LIST response for glob %s\", 