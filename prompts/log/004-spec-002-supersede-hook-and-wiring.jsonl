askExecutor(fakeGit, taskDir, \"openclaw\")\n58\t\t\tschemaID = cdb.SchemaID{Group: \"agent\", Kind: \"task\", Version: \"v1\"}\n59\t\t})\n60\t\n61\t\tAfterEach(func() {\n62\t\t\tExpect(os.RemoveAll(tmpDir)).To(Succeed())\n63\t\t})\n64\t\n65\t\tbuildCmdObj := func(cmd task.CreateCommand) cdb.CommandObject {\n66\t\t\tevent, err := base.ParseEvent(ctx, cmd)\n67\t\t\tExpect(err).NotTo(HaveOccurred())\n68\t\t\treturn cdb.CommandObject{\n69\t\t\t\tCommand: base.Command{\n70\t\t\t\t\tRequestID: base.NewRequestID(),\n71\t\t\t\t\tOperation: task.CreateCommandOperation,\n72\t\t\t\t\tInitiator: \"test\",\n73\t\t\t\t\tData:      event,\n74\t\t\t\t},\n75\t\t\t\tSchemaID: schemaID,\n76\t\t\t}\n77\t\t}\n78\t\n79\t\tDescribe(\"CommandOperation\", func() {\n80\t\t\tIt(\"returns create-task\", func() {\n81\t\t\t\tExpect(executor.CommandOperation()).To(Equal(base.CommandOperation(\"create-task\")))\n82\t\t\t})\n83\t\t})\n84\t\n85\t\tDescribe(\"HandleCommand\", func() {\n86\t\t\tContext(\"malformed command payload\", func() {\n87\t\t\t\tIt(\"returns ErrCommandObjectSkipped without writing\", func() {\n88\t\t\t\t\t// A channel is not JSON-marshalable, so MarshalInto will fail.\n89\t\t\t\t\tcmdObj := cdb.CommandObject{\n90\t\t\t\t\t\tCommand: base.Command{\n91\t\t\t\t\t\t\tRequestID: base.NewRequestID(),\n92\t\t\t\t\t\t\tOperation: task.CreateCommandOperation,\n93\t\t\t\t\t\t\tInitiator: \"test\",\n94\t\t\t\t\t\t\tData:      base.Event{\"taskIdentifier\": make(chan int)},\n95\t\t\t\t\t\t},\n96\t\t\t\t\t\tSchemaID: schemaID,\n97\t\t\t\t\t}\n98\t\t\t\t\t_, _, err := executor.HandleCommand(ctx, nil, cmdObj)\n99\t\t\t\t\tExpect(err).To(HaveOccurred())\n100\t\t\t\t\tExpect(errors.Is(err, cdb.ErrCommandObjectSkipped)).To(BeTrue())\n101\t\t\t\t\tExpect(fakeGit.AtomicWriteAndCommitPushCallCount()).To(Equal(0))\n102\t\t\t\t})\n103\t\t\t})\n104\t\n105\t\t\tContext(\"empty TaskIdentifier\", func() {\n106\t\t\t\tIt(\"returns a validation error without writing\", func() {\n107\t\t\t\t\tcmdObj := bui