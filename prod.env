# Per-stage build/runtime config sourced by Makefile.env and Makefile.k8s.
#
# Secrets convention: see dev.env header.

export NAMESPACE=prod
export BRANCH=prod
export STAGE=prod
export SENTRY_PROXY_URL=http://sentry-proxy.prod.svc.cluster.local:9090
export SENTRY_DSN_KEY=xwXZjL

# DRY_RUN=false on prod: every scheduled tick publishes CreateCommands to Kafka.
# This is the production-of-record instance.
export DRY_RUN=false

# Vault-scanner UUID-injection gate. true on prod = sole replica backfills
# UUID-less task files. Dev replica runs with false to prevent the dev+prod
# race documented in vault [[Dev+prod vault-scanners mint conflicting UUIDs on
# same task file]]. REQUIRED env (envconfig:"AUTO_INJECT_TASK_IDENTIFIER,required")
# — pod refuses to start if missing. Pick prod=true / dev=false; never both true.
export AUTO_INJECT_TASK_IDENTIFIER=true
